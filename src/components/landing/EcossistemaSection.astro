---
/**
 * EcossistemaSection — IV · Ecossistema
 * Teaser-propaganda da página /casos. Mesma lógica do IaSection: 4 cards
 * que apontam todos pra /casos (hub real). Função aqui é convidar pro
 * ecossistema, não rotear pra destinos específicos.
 */

interface Card {
  id: string;
  badge: string;
  eyebrow: string;
  title: string;
}

const cards: Card[] = [
  {
    id: '/01',
    badge: 'Mapa',
    eyebrow: 'Quem está em campo',
    title: 'LISP Brasil e outros mapas de labs',
  },
  {
    id: '/02',
    badge: 'Redes temáticas',
    eyebrow: 'Comunidades vivas',
    title: 'Linguagem simples, RNP Labs e redes de pesquisa',
  },
  {
    id: '/03',
    badge: 'Programas',
    eyebrow: 'Lastro institucional',
    title: 'Programas federais, CNJ e curadorias do LA-BORA!',
  },
  {
    id: '/04',
    badge: 'Contribuir',
    eyebrow: 'Sua rede no mapa',
    title: 'Sugira uma rede, prática ou ferramenta.',
  },
];
---
<section id="ecossistema" class="eco">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/04</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">IV · Ecossistema</span>
      </div>
      <h2 class="section-head-title reveal">
        Construtores de <span class="signal-text">ecossistemas</span>.
      </h2>
    </header>

    <p class="eco-sub reveal delay-1">
      Os 5 verbos são o motor metodológico do lab. Articular cidadãos, academia
      e instituições é o que faz a inovação escalar — e não morrer isolada.
    </p>

    <div class="eco-grid reveal delay-1">
      {cards.map((c) => (
        <a href="/casos" class="eco-card surface">
          <div class="eco-card-top">
            <span class="eco-card-id">{c.id}</span>
            <span class="eco-card-status">{c.badge}</span>
            <span class="eco-card-arrow">→</span>
          </div>

          <div class="eco-card-body">
            <div class="eco-card-label">{c.eyebrow}</div>
            <h3 class="eco-card-title">{c.title}</h3>
          </div>

          <span class="bracket bracket-tl"></span>
          <span class="bracket bracket-tr"></span>
          <span class="bracket bracket-bl"></span>
          <span class="bracket bracket-br"></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .eco {
    padding: 160px 0;
  }

  .eco-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
    font-style: italic;
  }
  @media (min-width: 880px) {
    .eco-sub { margin-left: 25%; }
  }

  /* section-head shared */
  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.2vw, 5.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ---------- GRID 1×4 ---------- */
  .eco-grid {
    margin-top: 96px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 720px) {
    .eco-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
  @media (min-width: 1100px) {
    .eco-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  /* ---------- CARD ---------- */
  .eco-card {
    position: relative;
    overflow: hidden;
    padding: 32px 28px;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: var(--bone);
  }

  .eco-card-top {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    flex-wrap: wrap;
  }

  .eco-card-id { color: var(--signal); }

  .eco-card-status {
    padding: 4px 10px;
    border: 1px solid var(--hairline-2);
    border-radius: 999px;
    color: var(--fg-65);
  }

  .eco-card-arrow {
    margin-left: auto;
    font-size: 18px;
    color: var(--fg-50);
    opacity: 0.7;
    transition: transform 250ms ease, color 250ms ease;
  }
  .eco-card:hover .eco-card-arrow {
    transform: translateX(6px);
    color: var(--signal);
  }

  .eco-card-body {
    margin-top: 32px;
  }

  .eco-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal);
    opacity: 0.85;
    margin-bottom: 14px;
  }

  .eco-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.8vw, 1.55rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.018em;
    color: var(--bone);
    text-wrap: balance;
  }

  @media (max-width: 720px) {
    .eco-card { padding: 32px 24px; }
    .eco-card-body { margin-top: 24px; }
  }
</style>
