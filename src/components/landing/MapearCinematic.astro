---
/**
 * MapearCinematic — cinematic cartográfico para a hero do verbo Mapear.
 * Primo menor e contido do AmbientField da landing:
 * grade de lat/long, isolinhas se traçando em loop, vértices pulsando,
 * rosa-dos-ventos girando, marcador de campo percorrendo a trilha.
 * Decorativo: aria-hidden, pointer-events: none, mascarado nas bordas.
 */
---
<div class="mc-wrap" aria-hidden="true">
  <svg
    viewBox="0 0 600 600"
    preserveAspectRatio="xMidYMid meet"
    role="presentation"
  >
    <defs>
      <radialGradient id="mc-fade" cx="50%" cy="50%" r="58%">
        <stop offset="0%"   stop-color="#fff" stop-opacity="1"/>
        <stop offset="55%"  stop-color="#fff" stop-opacity="0.6"/>
        <stop offset="100%" stop-color="#fff" stop-opacity="0"/>
      </radialGradient>
      <mask id="mc-mask" maskUnits="userSpaceOnUse">
        <rect width="600" height="600" fill="url(#mc-fade)"/>
      </mask>
    </defs>

    <g mask="url(#mc-mask)">
      <!-- ── Grade de lat/long (hairlines) ── -->
      <g class="mc-grid">
        <line x1="100" y1="0" x2="100" y2="600"/>
        <line x1="200" y1="0" x2="200" y2="600"/>
        <line x1="300" y1="0" x2="300" y2="600"/>
        <line x1="400" y1="0" x2="400" y2="600"/>
        <line x1="500" y1="0" x2="500" y2="600"/>
        <line x1="0" y1="100" x2="600" y2="100"/>
        <line x1="0" y1="200" x2="600" y2="200"/>
        <line x1="0" y1="300" x2="600" y2="300"/>
        <line x1="0" y1="400" x2="600" y2="400"/>
        <line x1="0" y1="500" x2="600" y2="500"/>
      </g>

      <!-- ── Isolinhas (topográficas) — traçadas em loop, staggered ── -->
      <path
        class="mc-iso mc-iso-1"
        pathLength="1000"
        d="M20,310 C100,250 170,360 240,310 S360,220 430,260 540,330 590,280"
      />
      <path
        class="mc-iso mc-iso-2"
        pathLength="1000"
        d="M10,400 C110,330 180,440 270,380 S400,280 470,330 560,420 595,370"
      />
      <path
        class="mc-iso mc-iso-3"
        pathLength="1000"
        d="M30,230 C130,150 220,280 300,210 S430,110 500,160 570,230 590,200"
      />

      <!-- ── Trilha de campo (survey path) — fica visível em pontilhado ── -->
      <path
        id="mc-survey-path"
        class="mc-survey"
        d="M70,500 C140,470 180,420 220,370 S290,290 340,260 420,200 470,170 540,120 560,80"
        fill="none"
      />

      <!-- ── Vértices cartográficos ── -->
      <g class="mc-vertices">
        <circle cx="100" cy="420" r="1.6"/>
        <circle cx="180" cy="370" r="1.6" style="animation-delay:-0.7s"/>
        <circle cx="240" cy="320" r="1.6" style="animation-delay:-1.3s"/>
        <circle cx="320" cy="280" r="1.6" style="animation-delay:-1.9s"/>
        <circle cx="400" cy="220" r="1.6" style="animation-delay:-2.4s"/>
        <circle cx="480" cy="170" r="1.6" style="animation-delay:-3.0s"/>
        <circle cx="540" cy="120" r="1.6" style="animation-delay:-3.6s"/>
        <circle cx="150" cy="240" r="1.4" style="animation-delay:-1.1s"/>
        <circle cx="370" cy="430" r="1.4" style="animation-delay:-2.6s"/>
        <circle cx="510" cy="380" r="1.4" style="animation-delay:-3.3s"/>
      </g>

      <!-- ── Rosa dos ventos ── -->
      <g class="mc-compass" transform="translate(495 115)">
        <g class="mc-compass-rotor">
          <animateTransform
            attributeName="transform"
            type="rotate"
            from="0"
            to="360"
            dur="72s"
            repeatCount="indefinite"
          />
          <circle r="32" class="mc-compass-ring"/>
          <circle r="22" class="mc-compass-ring mc-compass-ring--inner"/>
          <line x1="0" y1="-32" x2="0" y2="32" class="mc-compass-axis"/>
          <line x1="-32" y1="0" x2="32" y2="0" class="mc-compass-axis"/>
          <polygon points="0,-32 -3,-22 3,-22" class="mc-compass-needle"/>
        </g>
        <text y="-40" class="mc-compass-label">N</text>
      </g>

      <!-- ── Marcador percorrendo a trilha ── -->
      <g class="mc-marker">
        <circle r="9"  class="mc-marker-ring"/>
        <circle r="2.4" class="mc-marker-dot"/>
        <animateMotion
          dur="26s"
          repeatCount="indefinite"
          rotate="auto"
          calcMode="linear"
        >
          <mpath href="#mc-survey-path"/>
        </animateMotion>
      </g>

      <!-- ── Coordenadas (texto técnico) ── -->
      <g class="mc-coords">
        <text x="22" y="38">15°47′S</text>
        <text x="500" y="38">47°55′W</text>
        <text x="22" y="582">CARTA · DIAGNÓSTICO</text>
        <text x="430" y="582" class="mc-coords--dim">RELEVO IN/CGU</text>
      </g>
    </g>

    <!-- Frame fino externo, fora da máscara — deixa o "papel" delimitado -->
    <rect
      class="mc-frame"
      x="0.5" y="0.5" width="599" height="599"
      fill="none"
    />
  </svg>
</div>

<style>
  .mc-wrap {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .mc-wrap svg {
    position: absolute;
    top: 50%;
    right: -60px;
    transform: translateY(-48%);
    width: clamp(420px, 52vw, 640px);
    height: clamp(420px, 52vw, 640px);
    opacity: 0.85;
    color: var(--signal);
  }

  /* ── Grade ─────────────────────────────────────────────── */
  .mc-grid line {
    stroke: var(--fg-14);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Isolinhas ─────────────────────────────────────────── */
  .mc-iso {
    fill: none;
    stroke: var(--signal);
    stroke-width: 1.1;
    stroke-opacity: 0.48;
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    vector-effect: non-scaling-stroke;
    animation: mc-trace 14s cubic-bezier(0.55, 0.05, 0.35, 1) infinite;
  }
  .mc-iso-1 { animation-delay: 0s; }
  .mc-iso-2 { animation-delay: -4.7s; }
  .mc-iso-3 { animation-delay: -9.3s; }

  @keyframes mc-trace {
    0%   { stroke-dashoffset: 1000; opacity: 0.0; }
    8%   { opacity: 0.9; }
    45%  { stroke-dashoffset: 0;    opacity: 0.9; }
    70%  { stroke-dashoffset: 0;    opacity: 0.9; }
    100% { stroke-dashoffset: -1000; opacity: 0.0; }
  }

  /* ── Trilha de campo ───────────────────────────────────── */
  .mc-survey {
    stroke: var(--signal);
    stroke-opacity: 0.22;
    stroke-width: 0.7;
    stroke-dasharray: 3 5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Vértices ──────────────────────────────────────────── */
  .mc-vertices circle {
    fill: var(--signal);
    fill-opacity: 0.55;
    animation: mc-pulse 4.4s ease-in-out infinite;
  }
  @keyframes mc-pulse {
    0%, 100% { fill-opacity: 0.25; transform: scale(0.8); }
    50%      { fill-opacity: 0.85; transform: scale(1.2); }
  }
  .mc-vertices circle { transform-box: fill-box; transform-origin: center; }

  /* ── Rosa dos ventos ───────────────────────────────────── */
  .mc-compass-ring {
    fill: none;
    stroke: var(--fg-22);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }
  .mc-compass-ring--inner { stroke: var(--fg-14); }
  .mc-compass-axis {
    stroke: var(--fg-30);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }
  .mc-compass-needle {
    fill: var(--signal);
    fill-opacity: 0.7;
  }
  .mc-compass-label {
    fill: var(--fg-50);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-anchor: middle;
  }

  /* ── Marcador ──────────────────────────────────────────── */
  .mc-marker-dot {
    fill: var(--signal);
  }
  .mc-marker-ring {
    fill: none;
    stroke: var(--signal);
    stroke-opacity: 0.55;
    stroke-width: 0.7;
    vector-effect: non-scaling-stroke;
    animation: mc-ring 1.9s ease-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes mc-ring {
    0%   { transform: scale(0.4); stroke-opacity: 0.7; }
    100% { transform: scale(1.8); stroke-opacity: 0; }
  }

  /* ── Coordenadas ───────────────────────────────────────── */
  .mc-coords text {
    fill: var(--fg-30);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.18em;
  }
  .mc-coords--dim { fill: var(--fg-22); }

  /* ── Frame externo ─────────────────────────────────────── */
  .mc-frame {
    stroke: var(--fg-14);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Mobile: esconde — texto da hero ocupa toda a coluna ── */
  @media (max-width: 720px) {
    .mc-wrap { display: none; }
  }

  /* ── Reduced motion ────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .mc-iso,
    .mc-vertices circle,
    .mc-marker-ring,
    .mc-compass-rotor {
      animation: none;
    }
    .mc-iso { stroke-dashoffset: 0; opacity: 0.6; }
  }
</style>
