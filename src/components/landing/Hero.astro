---
/**
 * Hero — landing first viewport.
 * CoreField SVG (concentric rings, ticks, central dot) behind.
 * Headline word-by-word reveal + readouts grid + dual CTAs.
 * Parallax via JS-driven --p custom property tied to scroll.
 */

const headlineWords = [
  { t: 'A força',          italic: false },
  { t: 'que multiplica',   italic: true  },
  { t: 'laboratórios de',  italic: false },
  { t: 'inovação pública.', italic: false },
];

const ticks = Array.from({ length: 60 }, (_, i) => {
  const a = (i / 60) * Math.PI * 2;
  const isMajor = i % 5 === 0;
  const r1 = 390;
  const r2 = isMajor ? 370 : 380;
  const x1 = 400 + Math.cos(a) * r1;
  const y1 = 400 + Math.sin(a) * r1;
  const x2 = 400 + Math.cos(a) * r2;
  const y2 = 400 + Math.sin(a) * r2;
  return { x1, y1, x2, y2, opacity: isMajor ? 0.35 : 0.15 };
});
---
<section class="hero" id="top">
  <div class="hero-corefield" aria-hidden="true">
    <div class="hero-corefield-inner">
      <div class="hero-corefield-blur breathe"></div>
      <svg viewBox="0 0 800 800" class="hero-corefield-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="coreGrad" cx="50%" cy="50%" r="50%">
            <stop offset="0%"  stop-color="oklch(0.82 0.155 78)" stop-opacity="0.35" />
            <stop offset="60%" stop-color="oklch(0.82 0.155 78)" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="ringStroke" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%"   stop-color="currentColor" stop-opacity="0.06" />
            <stop offset="50%"  stop-color="oklch(0.82 0.155 78)" stop-opacity="0.4" />
            <stop offset="100%" stop-color="currentColor" stop-opacity="0.06" />
          </linearGradient>
        </defs>

        <circle cx="400" cy="400" r="380" fill="url(#coreGrad)" />

        {[120, 180, 250, 320, 380].map((r, i) => (
          <circle
            cx="400"
            cy="400"
            r={r}
            fill="none"
            stroke="url(#ringStroke)"
            stroke-width={i === 2 ? 1.2 : 0.6}
            stroke-dasharray={i % 2 ? '2 6' : undefined}
          >
            <animateTransform
              attributeName="transform"
              type="rotate"
              from={i % 2 ? `0 400 400` : `360 400 400`}
              to={i % 2 ? `360 400 400` : `0 400 400`}
              dur={`${60 + i * 20}s`}
              repeatCount="indefinite"
            />
          </circle>
        ))}

        {ticks.map((t) => (
          <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke="currentColor" stroke-opacity={t.opacity} />
        ))}

        <circle cx="400" cy="400" r="3" fill="oklch(0.82 0.155 78)" />
      </svg>
    </div>
  </div>

  <div class="hero-content shell" id="hero-content">
    <div class="hero-edition reveal">
      <span class="hero-edition-dot"></span>
      <span>I · Inovação pública</span>
      <span class="hero-edition-line"></span>
      <span>Edição I · MMXXVI</span>
    </div>

    <p class="hero-eyebrow reveal delay-1">Alavanca</p>

    <h1 class="hero-headline">
      {headlineWords.map((w, i) => (
        <span class={`hero-word reveal delay-${i + 1}`}>
          {w.italic ? <span class="hero-italic signal-text">{w.t}</span> : w.t}{' '}
        </span>
      ))}
    </h1>

    <div class="hero-grid reveal delay-5">
      <div class="hero-grid-premise">
        <p class="hero-label">↑ Premissa</p>
        <p class="hero-premise">
          Mais entrega, com a equipe que você tem. A Alavanca é a plataforma do
          CLIC para apoiar laboratórios de inovação pública — do diagnóstico à
          prova de valor — com IA aplicada e método.
        </p>
        <p class="hero-byline">
          ↳ Por <span>CLIC · Centro de letramento digital</span> · Edição I · Encontro de Labs · MMXXVI
        </p>
      </div>

      <div class="hero-grid-readouts">
        <p class="hero-label">Sistema</p>
        <div class="hero-readout">
          <span>Verbos do método</span>
          <span class="hero-readout-value">05</span>
        </div>
        <div class="hero-readout">
          <span>Frentes do sistema</span>
          <span class="hero-readout-value">04</span>
        </div>
        <div class="hero-readout">
          <span>Casos de prova</span>
          <span class="hero-readout-value">03</span>
        </div>
      </div>

      <div class="hero-grid-ctas">
        <a class="hero-cta hero-cta-primary" href="/diagnostico">
          <span class="hero-cta-label">Diagnóstico</span>
          <span class="hero-cta-arrow">→</span>
        </a>
        <a class="hero-cta hero-cta-secondary" href="/sobre-jo">
          <span class="hero-cta-label">Conheça a Jô</span>
          <span class="hero-cta-arrow">→</span>
        </a>
      </div>
    </div>
  </div>

  <div class="hero-fade"></div>
</section>

<script is:inline>
  (() => {
    const hero = document.querySelector('.hero');
    const content = document.getElementById('hero-content');
    if (!hero || !content) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    let raf = 0;
    const update = () => {
      const rect = hero.getBoundingClientRect();
      const total = rect.height;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const p = total > 0 ? scrolled / total : 0;
      content.style.setProperty('--p', String(p));
      raf = 0;
    };
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    width: 100%;
    overflow: hidden;
  }

  /* ---------- COREFIELD ---------- */
  .hero-corefield {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-corefield-inner {
    position: relative;
    width: 900px;
    height: 900px;
    max-width: 120vw;
    max-height: 120vw;
  }

  .hero-corefield-blur {
    position: absolute;
    inset: 15%;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, oklch(0.82 0.155 78 / 0.18), transparent 60%);
    filter: blur(40px);
  }

  .hero-corefield-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--bone);
  }

  /* ---------- CONTENT ---------- */
  .hero-content {
    position: relative;
    z-index: 10;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px;
    padding-bottom: 80px;
    transform: translateY(calc(var(--p, 0) * 180px));
    opacity: calc(1 - var(--p, 0) * 0.8);
  }

  @media (min-height: 900px) {
    /* Em viewports altos, dá ar acima — evita o conteúdo grudar no topo */
    .hero-content { padding-top: 160px; }
  }

  /* ---------- EDITION ROW ---------- */
  .hero-edition {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-65);
  }

  .hero-edition-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
  }

  .hero-edition-line {
    flex: 0 0 auto;
    width: 128px;
    max-width: 25vw;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }

  /* ---------- EYEBROW (small "Alavanca") ---------- */
  .hero-eyebrow {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.6vw, 3.6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg-40);
    margin-bottom: 14px;
  }

  /* ---------- HEADLINE ---------- */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7.5vw, 7.5rem);
    font-weight: 500;
    line-height: 0.94;
    letter-spacing: -0.04em;
    color: var(--bone);
    text-wrap: balance;
    /* Safe-area pro italic overhang sem alterar balance */
    padding-inline-end: 12px;
  }

  .hero-word {
    display: inline-block;
    margin-right: 0.18em;
  }

  .hero-italic {
    font-style: italic;
    font-weight: 300;
  }

  /* ---------- GRID ---------- */
  .hero-grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 32px 24px;
  }

  .hero-grid-premise   { grid-column: span 12; }
  .hero-grid-readouts  { grid-column: span 12; display: flex; flex-direction: column; gap: 8px; }
  .hero-grid-ctas      { grid-column: span 12; display: flex; flex-direction: column; gap: 12px; align-self: end; }

  @media (min-width: 880px) {
    .hero-grid-premise   { grid-column: span 5; }
    .hero-grid-readouts  { grid-column: 7 / span 3; }
    .hero-grid-ctas      { grid-column: 10 / span 3; }
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 14px;
  }

  .hero-premise {
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg-78);
    text-wrap: pretty;
    max-width: 38ch;
  }

  .hero-byline {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-60);
  }
  .hero-byline span {
    color: var(--bone);
  }

  /* ---------- READOUTS ---------- */
  .hero-readout {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 1px solid var(--hairline);
    padding-top: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }

  .hero-readout-value {
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--bone);
    letter-spacing: 0;
  }

  /* ---------- CTAs ---------- */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 22px;
    border: 1px solid var(--fg-30);
    background: transparent;
    color: var(--bone);
    text-decoration: none;
    transition: border-color 250ms ease, color 250ms ease;
  }

  .hero-cta:hover {
    border-color: var(--signal);
    color: var(--signal);
  }

  .hero-cta-label {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: -0.01em;
  }

  .hero-cta-secondary {
    border-color: var(--hairline);
  }
  .hero-cta-secondary .hero-cta-label {
    font-size: 16px;
  }

  .hero-cta-arrow {
    font-family: var(--font-mono);
    font-size: 20px;
    transition: transform 250ms ease;
  }
  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(4px);
  }

  /* ---------- BOTTOM FADE ---------- */
  .hero-fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 128px;
    background: linear-gradient(to bottom, transparent, var(--background));
    pointer-events: none;
    z-index: 5;
  }
</style>
