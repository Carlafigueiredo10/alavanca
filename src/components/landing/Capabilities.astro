---
/**
 * Capabilities · Seção II — Aplicação.
 * Hero permanece em linguagem manifesto (os seis verbos). Os cards usam
 * linguagem operacional (capacidades institucionais). Agrupados em duas
 * fases: Estratégia (01-03) e Execução (04-06). Todos os cards levam pra
 * /aplicacao — onde fica o detalhamento e o handoff pra cada verbo.
 */

type Block = {
  id: string;
  title: string;
  line: string;
};

type Phase = {
  key: string;       // 'A' | 'B'
  name: string;      // 'Estratégia' | 'Execução'
  caption: string;   // legenda da fase (mono small)
  items: Block[];
};

const phases: Phase[] = [
  {
    key: 'A',
    name: 'Estratégia',
    caption: 'Leitura do terreno, arquitetura e instrumento jurídico',
    items: [
      {
        id: '01',
        title: 'Diagnóstico Institucional',
        line: 'Do cenário difuso ao relatório acionável.',
      },
      {
        id: '02',
        title: 'Arquitetura Operacional',
        line: 'Fluxos, papéis, ritos e backlog estruturados.',
      },
      {
        id: '03',
        title: 'Governança Normativa',
        line: 'Portaria, catálogo, dedicação e critérios formais.',
      },
    ],
  },
  {
    key: 'B',
    name: 'Execução',
    caption: 'Entrega, medição e continuidade institucional',
    items: [
      {
        id: '04',
        title: 'Entrega Assistida',
        line: 'Protótipos validados, fluxos implantados, operação assistida.',
      },
      {
        id: '05',
        title: 'Medição Pública',
        line: 'KPIs, aderência e impacto operacional auditável.',
      },
      {
        id: '06',
        title: 'Sustentação',
        line: 'PPA, sucessão e continuidade institucional documentada.',
      },
    ],
  },
];

const APLICACAO_HREF = '/aplicacao';
---
<section id="aplicacao" class="cap">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/02</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">II · Aplicação</span>
      </div>
      <h2 class="section-head-title reveal">
        Mapear. Estruturar. Formalizar. Construir. Avaliar. Manter.
      </h2>
    </header>

    <p class="cap-sub reveal delay-1">
      Seis verbos. Duas fases. Um método. — IA aplicada institui o que antes
      ficava na cabeça do gestor.
    </p>

    {phases.map((phase, phaseIdx) => (
      <div class="cap-phase reveal" data-phase={phase.key}>
        <div class="cap-phase-head">
          <span class="cap-phase-text">
            <strong>{phase.name}</strong>
            <span class="cap-phase-sep">·</span>
            <span class="cap-phase-caption">{phase.caption}</span>
          </span>
          <span class="cap-phase-rule"></span>
        </div>

        <div class="cap-grid">
          {phase.items.map((b, i) => (
            <a
              href={APLICACAO_HREF}
              class:list={['cap-block', 'surface', 'reveal', `delay-${(phaseIdx * 3 + i + 1)}`]}
              aria-label={`${b.title} — ver detalhamento na página Aplicação`}
            >
              <div class="cap-spot" aria-hidden="true"></div>
              <div class="cap-block-inner">
                <div class="cap-block-top">
                  <span class="cap-block-id">/{b.id}</span>
                  <span class="cap-block-arrow">→</span>
                </div>
                <div class="cap-block-body">
                  <h3 class="cap-block-title">{b.title}</h3>
                  <p class="cap-block-line">{b.line}</p>
                </div>
              </div>
              <span class="bracket bracket-tl"></span>
              <span class="bracket bracket-tr"></span>
              <span class="bracket bracket-bl"></span>
              <span class="bracket bracket-br"></span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="cap-footer reveal delay-2">
      <a href={APLICACAO_HREF} class="cap-footer-link">
        ↳ Aplicação completa · seis capacidades em detalhe
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;
    const blocks = document.querySelectorAll('.cap-block');
    blocks.forEach((el) => {
      el.addEventListener('mousemove', (e) => {
        const r = el.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width  - 0.5) * 8;
        const y = ((e.clientY - r.top)  / r.height - 0.5) * 8;
        el.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        el.style.setProperty('--my', (e.clientY - r.top)  + 'px');
        el.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'translate3d(0,0,0)';
      });
    });
  })();
</script>

<style>
  .cap {
    padding: 160px 0;
  }

  .cap-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
  }

  @media (min-width: 880px) {
    .cap-sub { margin-left: 25%; }
  }

  /* ---------- SECTION HEAD (shared pattern) ---------- */
  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.2vw, 5.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ---------- PHASES ---------- */
  .cap-phase {
    margin-top: 64px;
  }
  .cap-phase + .cap-phase { margin-top: 52px; }

  .cap-phase-head {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 22px;
    flex-wrap: nowrap;
  }
  .cap-phase-rule {
    flex: 1;
    min-width: 24px;
    height: 0.5px;
    background: linear-gradient(to right, transparent, var(--fg-22) 30%, var(--fg-22) 70%, transparent);
  }
  .cap-phase-text {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-65);
    white-space: nowrap;
  }
  .cap-phase-text strong {
    color: var(--signal);
    font-weight: 500;
  }
  .cap-phase-sep { color: var(--fg-30); }
  .cap-phase-caption {
    color: var(--fg-50);
    letter-spacing: 0.14em;
  }

  @media (max-width: 720px) {
    .cap-phase-head { flex-wrap: wrap; gap: 12px; }
    .cap-phase-text { white-space: normal; font-size: 10px; }
  }

  /* ---------- GRID OF BLOCKS ---------- */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 18px;
  }

  .cap-block {
    grid-column: span 12;
    position: relative;
    min-height: 132px;
    overflow: hidden;
    padding: 18px 20px 18px;
    text-decoration: none;
    color: inherit;
    transition:
      transform 500ms cubic-bezier(.2, .8, .2, 1),
      border-color 400ms ease,
      background 400ms ease;
    will-change: transform;
  }

  @media (min-width: 720px) {
    .cap-block { grid-column: span 6; }
  }
  @media (min-width: 880px) {
    .cap-block { grid-column: span 4; }
  }

  /* Sutil diferenciação tonal por fase: Estratégia mais fria, Execução
     mais quente — sem sair da paleta, só re-equilíbrio de alphas. */
  .cap-phase[data-phase='A'] .cap-block {
    background: linear-gradient(180deg, oklch(0.18 0.012 95 / 0.55), oklch(0.13 0.012 95 / 0.35));
  }
  .cap-phase[data-phase='B'] .cap-block {
    background: linear-gradient(180deg, oklch(0.20 0.020 80 / 0.55), oklch(0.13 0.012 95 / 0.35));
  }

  .cap-spot {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 500ms ease;
    background: radial-gradient(240px circle at var(--mx, 50%) var(--my, 50%), oklch(0.82 0.155 78 / 0.16), transparent 60%);
  }
  .cap-block:hover .cap-spot { opacity: 1; }

  .cap-block-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    gap: 14px;
  }

  .cap-block-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .cap-block-id { color: var(--signal); }
  .cap-block-arrow {
    opacity: 0.6;
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .cap-block:hover .cap-block-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .cap-block-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.3rem, 1.8vw, 1.65rem);
    line-height: 1.1;
    letter-spacing: -0.014em;
    color: var(--bone);
    text-wrap: balance;
  }

  .cap-block-line {
    margin-top: 6px;
    max-width: 38ch;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg-65);
  }

  /* ---------- FOOTER LINK ---------- */
  .cap-footer {
    margin-top: 64px;
    text-align: center;
  }
  .cap-footer-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--signal);
    text-decoration: none;
    padding: 6px 4px;
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .cap-footer-link:hover {
    opacity: 0.85;
    transform: translateX(2px);
  }

  @media (max-width: 720px) {
    .cap-phase-head { gap: 10px; }
    .cap-phase-caption { width: 100%; }
  }
</style>
