---
/**
 * Labs — III · Fundamentos
 * Claim institucional + link pra bibliografia. Os cards de bases (ENAP, OCDE,
 * MGI) foram removidos pra desviar atenção do produto pra teoria; quem quer
 * o lastro bibliográfico segue pelo link "Ver bibliografia".
 */
---
<section id="fundamentos" class="labs">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/05</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">V · Fundamentos</span>
      </div>
      <h2 class="section-head-title reveal">
        Ideia não vira entrega sem estrutura.
      </h2>
    </header>

    <div class="labs-claim reveal">
      <p class="labs-claim-text signal-text">
        A Alavanca transforma estrutura em método.
      </p>
      <p class="labs-claim-label">Base institucional</p>
      <a href="/bibliografia" class="labs-claim-link">
        Ver bibliografia <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .labs {
    padding: 160px 0;
  }

  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.2vw, 5.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ---------- CLAIM ---------- */
  .labs-claim {
    margin-top: 80px;
    max-width: 640px;
  }

  @media (min-width: 880px) {
    .labs-claim { margin-left: 25%; }
  }

  .labs-claim-text {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.6vw, 2.4rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.25;
  }

  .labs-claim-label {
    margin-top: 32px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }

  .labs-claim-link {
    margin-top: 12px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg-65);
    font-size: 14px;
    transition: color 200ms ease;
  }
  .labs-claim-link:hover {
    color: var(--signal);
  }
  .labs-claim-link span {
    font-family: var(--font-mono);
  }
</style>
