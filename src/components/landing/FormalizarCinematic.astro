---
/**
 * FormalizarCinematic — grafo de dependências jurídico-institucionais.
 * ICT no centro como pivot do Marco CT&I; 5 frentes autônomas como satélites.
 * Aresta sólida Política → ICT (dependência obrigatória); aresta tracejada
 * NIT → ICT (recomendação). Pulse staggered marca o hub jurídico ativo.
 */
---
<div class="fc-wrap" aria-hidden="true">
  <svg
    viewBox="0 0 600 600"
    preserveAspectRatio="xMidYMid meet"
    role="presentation"
  >
    <defs>
      <radialGradient id="fc-fade" cx="50%" cy="50%" r="58%">
        <stop offset="0%"   stop-color="#fff" stop-opacity="1"/>
        <stop offset="55%"  stop-color="#fff" stop-opacity="0.6"/>
        <stop offset="100%" stop-color="#fff" stop-opacity="0"/>
      </radialGradient>
      <mask id="fc-mask" maskUnits="userSpaceOnUse">
        <rect width="600" height="600" fill="url(#fc-fade)"/>
      </mask>
    </defs>

    <g mask="url(#fc-mask)">
      <!-- ── Grade lat/long ── -->
      <g class="fc-grid">
        <line x1="100" y1="0" x2="100" y2="600"/>
        <line x1="200" y1="0" x2="200" y2="600"/>
        <line x1="300" y1="0" x2="300" y2="600"/>
        <line x1="400" y1="0" x2="400" y2="600"/>
        <line x1="500" y1="0" x2="500" y2="600"/>
        <line x1="0" y1="100" x2="600" y2="100"/>
        <line x1="0" y1="200" x2="600" y2="200"/>
        <line x1="0" y1="300" x2="600" y2="300"/>
        <line x1="0" y1="400" x2="600" y2="400"/>
        <line x1="0" y1="500" x2="600" y2="500"/>
      </g>

      <!-- ── Header band ── -->
      <text class="fc-mono fc-label" x="40" y="50">ATO JURÍDICO · HUB FORMALIZAÇÃO</text>
      <text class="fc-mono fc-label--dim" x="560" y="50" text-anchor="end">MARCO CT&amp;I 13.243/2016</text>
      <line class="fc-rule" x1="40" y1="66" x2="560" y2="66"/>

      <!-- ── Arestas de dependência (atrás dos nós) ── -->
      <!-- Política (430,440) → ICT (300,300): obrigatória, sólida com trace -->
      <line
        class="fc-edge fc-edge--solid"
        x1="421" y1="430"
        x2="332" y2="333"
        pathLength="100"
      />
      <!-- NIT (170,440) → ICT (300,300): recomendação, tracejada -->
      <line
        class="fc-edge fc-edge--dashed"
        x1="180" y1="430"
        x2="268" y2="333"
        pathLength="100"
      />

      <!-- ── Labels das arestas ── -->
      <text class="fc-edge-label" x="395" y="382" text-anchor="middle">REQ</text>
      <text class="fc-edge-label fc-edge-label--dim" x="205" y="382" text-anchor="middle">REC</text>

      <!-- ── Pivot ICT (centro) ── -->
      <g class="fc-pivot">
        <!-- Anel externo girando -->
        <g class="fc-pivot-rotor">
          <animateTransform
            attributeName="transform"
            type="rotate"
            from="0 300 300"
            to="360 300 300"
            dur="48s"
            repeatCount="indefinite"
          />
          <circle cx="300" cy="300" r="46" class="fc-pivot-outer"/>
          <line x1="300" y1="246" x2="300" y2="252" class="fc-pivot-tick"/>
          <line x1="300" y1="348" x2="300" y2="354" class="fc-pivot-tick"/>
          <line x1="246" y1="300" x2="252" y2="300" class="fc-pivot-tick"/>
          <line x1="348" y1="300" x2="354" y2="300" class="fc-pivot-tick"/>
        </g>
        <!-- Anel interno -->
        <circle cx="300" cy="300" r="34" class="fc-pivot-inner"/>
        <!-- Disco central -->
        <circle cx="300" cy="300" r="22" class="fc-pivot-core"/>
        <!-- Label ICT -->
        <text class="fc-pivot-label" x="300" y="304" text-anchor="middle">ICT</text>
      </g>

      <!-- ── Satélites (5 frentes autônomas) ── -->
      <g class="fc-sat" style="animation-delay:0s">
        <circle cx="140" cy="170" r="14" class="fc-sat-ring"/>
        <circle cx="140" cy="170" r="6"  class="fc-sat-core"/>
        <text class="fc-sat-label" x="140" y="200" text-anchor="middle">PORTARIA</text>
        <text class="fc-sat-num"   x="140" y="146" text-anchor="middle">01</text>
      </g>

      <g class="fc-sat" style="animation-delay:-1.4s">
        <circle cx="300" cy="140" r="14" class="fc-sat-ring"/>
        <circle cx="300" cy="140" r="6"  class="fc-sat-core"/>
        <text class="fc-sat-label" x="300" y="116" text-anchor="middle">CATÁLOGO</text>
        <text class="fc-sat-num"   x="300" y="168" text-anchor="middle">02</text>
      </g>

      <g class="fc-sat" style="animation-delay:-2.8s">
        <circle cx="460" cy="170" r="14" class="fc-sat-ring"/>
        <circle cx="460" cy="170" r="6"  class="fc-sat-core"/>
        <text class="fc-sat-label" x="460" y="200" text-anchor="middle">DEDICAÇÃO</text>
        <text class="fc-sat-num"   x="460" y="146" text-anchor="middle">03</text>
      </g>

      <g class="fc-sat fc-sat--dep" style="animation-delay:-4.2s">
        <circle cx="170" cy="440" r="14" class="fc-sat-ring"/>
        <circle cx="170" cy="440" r="6"  class="fc-sat-core"/>
        <text class="fc-sat-label" x="170" y="470" text-anchor="middle">NIT</text>
        <text class="fc-sat-num"   x="170" y="416" text-anchor="middle">05</text>
      </g>

      <g class="fc-sat fc-sat--dep" style="animation-delay:-5.6s">
        <circle cx="430" cy="440" r="14" class="fc-sat-ring"/>
        <circle cx="430" cy="440" r="6"  class="fc-sat-core"/>
        <text class="fc-sat-label" x="430" y="470" text-anchor="middle">POLÍTICA</text>
        <text class="fc-sat-num"   x="430" y="416" text-anchor="middle">06</text>
      </g>

      <!-- ── Footer técnico ── -->
      <text class="fc-coords" x="40" y="572">FRENTES AUTÔNOMAS · 6</text>
      <text class="fc-coords fc-coords--dim" x="560" y="572" text-anchor="end">DEPENDÊNCIAS · 2</text>
    </g>

    <rect class="fc-frame" x="0.5" y="0.5" width="599" height="599" fill="none"/>
  </svg>
</div>

<style>
  .fc-wrap {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .fc-wrap svg {
    position: absolute;
    top: 50%;
    right: -60px;
    transform: translateY(-48%);
    width: clamp(420px, 52vw, 640px);
    height: clamp(420px, 52vw, 640px);
    opacity: 0.85;
    color: var(--signal);
  }

  /* ── Grade ── */
  .fc-grid line {
    stroke: var(--fg-14);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Tipografia técnica ── */
  .fc-mono {
    fill: var(--fg-50);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .fc-label     { fill: var(--signal); }
  .fc-label--dim { fill: var(--fg-30); }
  .fc-rule {
    stroke: var(--fg-14);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Arestas de dependência ── */
  .fc-edge {
    fill: none;
    vector-effect: non-scaling-stroke;
  }
  .fc-edge--solid {
    stroke: var(--signal);
    stroke-width: 1.2;
    stroke-opacity: 0.55;
    stroke-dasharray: 35 100;
    animation: fc-edge-trace 5s linear infinite;
  }
  .fc-edge--dashed {
    stroke: var(--signal);
    stroke-width: 0.9;
    stroke-opacity: 0.35;
    stroke-dasharray: 4 4;
    animation: fc-edge-pulse 4s ease-in-out infinite;
  }
  @keyframes fc-edge-trace {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes fc-edge-pulse {
    0%, 100% { stroke-opacity: 0.18; }
    50%      { stroke-opacity: 0.45; }
  }
  .fc-edge-label {
    fill: var(--signal);
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    fill-opacity: 0.6;
  }
  .fc-edge-label--dim { fill: var(--fg-50); fill-opacity: 0.7; }

  /* ── Pivot · ICT ── */
  .fc-pivot-outer {
    fill: none;
    stroke: var(--signal);
    stroke-width: 0.8;
    stroke-opacity: 0.4;
    stroke-dasharray: 3 5;
    vector-effect: non-scaling-stroke;
  }
  .fc-pivot-tick {
    stroke: var(--signal);
    stroke-width: 1;
    stroke-opacity: 0.7;
    vector-effect: non-scaling-stroke;
  }
  .fc-pivot-inner {
    fill: none;
    stroke: var(--fg-22);
    stroke-width: 0.6;
    vector-effect: non-scaling-stroke;
  }
  .fc-pivot-core {
    fill: var(--signal);
    fill-opacity: 0.18;
    stroke: var(--signal);
    stroke-width: 0.8;
    stroke-opacity: 0.7;
    vector-effect: non-scaling-stroke;
    animation: fc-pivot-breathe 5s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes fc-pivot-breathe {
    0%, 100% { fill-opacity: 0.16; }
    50%      { fill-opacity: 0.38; }
  }
  .fc-pivot-label {
    fill: var(--signal);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.08em;
  }

  /* ── Satélites ── */
  .fc-sat-ring {
    fill: none;
    stroke: var(--fg-30);
    stroke-width: 0.7;
    vector-effect: non-scaling-stroke;
  }
  .fc-sat-core {
    fill: var(--fg-22);
    animation: fc-sat-pulse 7s ease-in-out infinite;
  }
  .fc-sat--dep .fc-sat-ring { stroke: var(--signal); stroke-opacity: 0.5; }
  .fc-sat--dep .fc-sat-core { fill: var(--signal); fill-opacity: 0.4; }

  @keyframes fc-sat-pulse {
    0%, 100% { fill: var(--fg-22); }
    10%, 18% { fill: var(--signal); fill-opacity: 0.85; }
    32%      { fill: var(--signal); fill-opacity: 0.4; }
  }
  .fc-sat-label {
    fill: var(--fg-65);
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
  }
  .fc-sat-num {
    fill: var(--fg-30);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.2em;
  }
  .fc-sat--dep .fc-sat-label { fill: var(--signal); fill-opacity: 0.85; }

  /* ── Coords ── */
  .fc-coords {
    fill: var(--fg-30);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.18em;
  }
  .fc-coords--dim { fill: var(--fg-22); }

  /* ── Frame externo ── */
  .fc-frame {
    stroke: var(--fg-14);
    stroke-width: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* ── Mobile ── */
  @media (max-width: 720px) {
    .fc-wrap { display: none; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .fc-edge--solid,
    .fc-edge--dashed,
    .fc-pivot-core,
    .fc-pivot-rotor,
    .fc-sat-core {
      animation: none;
    }
    .fc-edge--solid { stroke-dashoffset: 0; }
  }
</style>
