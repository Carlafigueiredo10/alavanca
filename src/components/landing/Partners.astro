---
type CaseRef = {
  id: string;
  org: string;
  scope: string;
  result: string;
  href: string;
};

const cases: CaseRef[] = [
  {
    id: '01',
    org: 'Gnova · ENAP',
    scope: 'Método aplicado no governo federal.',
    result: 'Padronização de práticas entre labs.',
    href: '/casos/gnova',
  },
  {
    id: '02',
    org: 'Labori · AGU',
    scope: 'Formalização como ICT.',
    result: 'Viabilizou captação e parcerias.',
    href: '/casos/labori',
  },
  {
    id: '03',
    org: '(011).lab · Prefeitura de SP',
    scope: 'Inovação municipal com participação aberta.',
    result: 'Ampliou escala e engajamento.',
    href: '/casos/011lab',
  },
];
---
<section id="prova" class="part">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/05</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">V · Prova</span>
      </div>
      <h2 class="section-head-title reveal">
        Funciona na prática.
      </h2>
    </header>

    <p class="part-sub reveal delay-1">
      Método, institucionalização e execução.
    </p>

    <div class="part-grid">
      {cases.map((c, i) => (
        <a href={c.href} class:list={['part-card', 'surface', 'reveal', `delay-${i + 1}`]}>
          <div class="part-card-top">
            <span class="part-card-id">/{c.id}</span>
            <span class="part-card-arrow">→</span>
          </div>

          <div>
            <div class="part-card-label">Caso</div>
            <h3 class="part-card-org">{c.org}</h3>
            <p class="part-card-scope">{c.scope}</p>
            <p class="part-card-result">
              <span class="part-card-result-mark">↳</span>
              {c.result}
            </p>
          </div>

          <span class="bracket bracket-tl"></span>
          <span class="bracket bracket-tr"></span>
          <span class="bracket bracket-bl"></span>
          <span class="bracket bracket-br"></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .part {
    padding: 160px 0;
  }

  .part-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
    font-style: italic;
  }
  @media (min-width: 880px) {
    .part-sub { margin-left: 25%; }
  }

  /* section-head shared */
  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.2vw, 5.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ---------- CARDS ---------- */
  .part-grid {
    margin-top: 96px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 720px) {
    .part-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .part-card {
    position: relative;
    overflow: hidden;
    padding: 40px;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: var(--bone);
  }

  .part-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }

  .part-card-id { color: var(--signal); }

  .part-card-arrow {
    opacity: 0.6;
    transition: transform 250ms ease;
  }
  .part-card:hover .part-card-arrow {
    transform: translateX(4px);
  }

  .part-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-60);
    margin-bottom: 12px;
  }

  .part-card-org {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--bone);
  }

  .part-card-scope {
    margin-top: 16px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--fg-78);
  }

  .part-card-result {
    margin-top: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--fg-50);
  }

  .part-card-result-mark {
    color: var(--signal);
    margin-right: 4px;
  }
</style>
