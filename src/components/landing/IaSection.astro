---
/**
 * IaSection — V · IA aplicada
 * Substitui Partners (V · Prova). Card único, conteúdo em curadoria.
 * Headline-pergunta convida a entrar em /ia.
 */
---
<section id="ia" class="ia">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/04</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">IV · Infraestrutura</span>
      </div>
      <h2 class="section-head-title reveal">
        IA como <span class="signal-text">Infraestrutura</span>.
      </h2>
    </header>

    <p class="ia-sub reveal delay-1">
      O braço operacional do seu lab — capacidade da casa, não atalho terceirizado.
    </p>

    <a href="/ia" class="ia-card surface reveal delay-1">
      <div class="ia-card-top">
        <span class="ia-card-id">/04·01</span>
        <span class="ia-card-status">Em curadoria · v1.0</span>
        <span class="ia-card-arrow">→</span>
      </div>

      <div class="ia-card-body">
        <div class="ia-card-label">Módulo · Infraestrutura</div>
        <h3 class="ia-card-title">
          Entrar no módulo de IA aplicada.
        </h3>
        <p class="ia-card-lead">
          Em breve aqui: usos concretos, limites honestos, e onde a IA destrava — ou trava — o trabalho do laboratório.
        </p>
      </div>

      <div class="ia-card-foot">
        <span class="ia-card-foot-mark">↳</span>
        <span>Entrar no módulo</span>
      </div>

      <span class="bracket bracket-tl"></span>
      <span class="bracket bracket-tr"></span>
      <span class="bracket bracket-bl"></span>
      <span class="bracket bracket-br"></span>
    </a>
  </div>
</section>

<style>
  .ia {
    padding: 160px 0;
  }

  .ia-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
    font-style: italic;
  }
  @media (min-width: 880px) {
    .ia-sub { margin-left: 25%; }
  }

  /* section-head shared */
  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.2vw, 5.2rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ---------- CARD ÚNICO ---------- */
  .ia-card {
    position: relative;
    overflow: hidden;
    margin-top: 96px;
    padding: 56px 48px;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: var(--bone);
  }

  .ia-card-top {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    flex-wrap: wrap;
  }

  .ia-card-id { color: var(--signal); }

  .ia-card-status {
    padding: 4px 10px;
    border: 1px solid var(--hairline-2);
    border-radius: 999px;
    color: var(--fg-65);
  }

  .ia-card-arrow {
    margin-left: auto;
    font-size: 18px;
    color: var(--fg-50);
    opacity: 0.7;
    transition: transform 250ms ease, color 250ms ease;
  }
  .ia-card:hover .ia-card-arrow {
    transform: translateX(6px);
    color: var(--signal);
  }

  .ia-card-body {
    margin-top: 56px;
    max-width: 760px;
  }

  .ia-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-60);
    margin-bottom: 16px;
  }

  .ia-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.4vw, 3rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: var(--bone);
    text-wrap: balance;
  }

  .ia-card-lead {
    margin-top: 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-78);
    max-width: 60ch;
  }

  .ia-card-foot {
    margin-top: 56px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-65);
  }

  .ia-card-foot-mark {
    color: var(--signal);
  }

  @media (max-width: 720px) {
    .ia-card { padding: 40px 28px; }
    .ia-card-body { margin-top: 40px; }
    .ia-card-foot { margin-top: 40px; }
  }
</style>
