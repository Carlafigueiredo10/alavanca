---
interface NavLink {
  id: string;
  label: string;
  href: string;
  match: string; // 1º segmento do path (ex: 'mapear' casa /mapear, /mapear/sprint, etc.)
}

interface Props {
  // Aceito mas ignorado: o ativo é derivado do path (Astro.url.pathname).
  // Mantido pra não quebrar páginas que ainda passam current="casos" etc.
  current?: string;
  links?: NavLink[];
}

// 6 seções de topo, fixas em toda a aplicação. Os 6 verbos NÃO ficam aqui —
// eles vivem dentro de /aplicacao (cards). Mapear/Estruturar/.../Manter etc.
// herdam o ativo via match: 'aplicacao' (1º segmento do path bate quando o
// user está em /aplicacao, /mapear, /estruturar, /formalizar, /construir,
// /avaliar, /manter — tratamento especial no script abaixo).
const defaultLinks: NavLink[] = [
  { id: '01', label: 'Diagnóstico', href: '/diagnostico',  match: 'diagnostico' },
  { id: '02', label: 'Aplicação',   href: '/aplicacao',    match: 'aplicacao' },
  { id: '03', label: 'IA',          href: '/ia',           match: 'ia' },
  { id: '04', label: 'Ecossistema', href: '/casos',        match: 'casos' },
  { id: '05', label: 'Fundamentos', href: '/bibliografia', match: 'bibliografia' },
  { id: '06', label: 'Contribuir',  href: '/sugestoes',    match: 'sugestoes' },
];

// Páginas de verbo individual (/mapear, /estruturar, etc.) mantém "Aplicação"
// como item ativo do nav — pertencem ao guarda-chuva da Aplicação.
const VERB_SEGMENTS = new Set(['mapear', 'estruturar', 'formalizar', 'construir', 'avaliar', 'manter']);

const {
  links = defaultLinks,
} = Astro.props;

const rawSegment = (Astro.url.pathname.split('/')[1] || '').toLowerCase();
const activeSegment = VERB_SEGMENTS.has(rawSegment) ? 'aplicacao' : rawSegment;
---
<header class="nav" id="alavanca-nav">
  <div class="nav-inner shell">
    <a class="nav-brand" href="/">
      <svg class="nav-lever" viewBox="0 0 56 24" aria-hidden="true">
        <g class="nav-lever-rotor">
          <line x1="2" y1="12" x2="54" y2="12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="22" y1="12" x2="28" y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="34" y1="12" x2="28" y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <circle cx="28" cy="12" r="1.6" fill="currentColor"/>
        </g>
      </svg>
      <div class="nav-brand-text">
        <div class="nav-brand-title">Alavanca</div>
        <div class="nav-brand-sub">CLIC · Inovação pública</div>
      </div>
    </a>

    <nav class="nav-links" aria-label="Seções">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', { current: l.match === activeSegment }]}
        >
          <span class="nav-link-id">/{l.id}</span>
          <span class="nav-link-label">{l.label}</span>
        </a>
      ))}
    </nav>

    <a class="nav-auth" id="nav-auth" href="/login" data-state="anon">
      <span class="nav-auth-label">Entrar<span class="nav-auth-label-rest"> / Criar conta</span></span>
    </a>

    <a class="nav-jornada" id="nav-jornada" href="/minha-jornada" hidden>Minha jornada</a>

    <form class="nav-logout" id="nav-logout" method="POST" action="/api/auth/logout" hidden>
      <button type="submit" class="nav-logout-btn" aria-label="Sair">Sair</button>
    </form>

    <a class="nav-owner" id="nav-owner" href="/meus-produtos" hidden>
      <span class="nav-owner-dot"></span>
      <span class="nav-owner-label">Meus produtos</span>
    </a>
  </div>
</header>

<script is:inline>
  (() => {
    const nav = document.getElementById('alavanca-nav');
    if (!nav) return;
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<script>
  // Botão único de auth: "Entrar" → /login, ou "Minha jornada" → /minha-jornada
  // se houver sessão. Default SSR aponta pra /login; este script reescreve
  // client-side se Supabase devolver sessão. Flash possível mas curto.
  import { getSupabaseBrowserClient } from '../lib/supabase/browser';

  // Email cujo login destrava o link "Meus produtos" no nav. Hardcoded de
  // propósito: cantinho privado da dona da plataforma, não é multi-tenant.
  const OWNER_EMAIL = 'carlacristinesoares@gmail.com';

  (async () => {
    const el = document.getElementById('nav-auth') as HTMLAnchorElement | null;
    if (!el) return;
    const ownerLink = document.getElementById('nav-owner') as HTMLAnchorElement | null;
    try {
      const sb = getSupabaseBrowserClient();
      const { data } = await sb.auth.getSession();
      if (data?.session) {
        // Authed: esconde "Entrar / Criar conta", mostra "Minha jornada" + "Sair".
        el.hidden = true;

        const jornada = document.getElementById('nav-jornada') as HTMLAnchorElement | null;
        if (jornada) jornada.hidden = false;

        const logout = document.getElementById('nav-logout') as HTMLFormElement | null;
        if (logout) logout.hidden = false;

        const email = data.session.user?.email?.toLowerCase() ?? '';
        if (ownerLink && email === OWNER_EMAIL) {
          ownerLink.hidden = false;
        }
      }
    } catch {
      /* segue como Entrar — fallback seguro */
    }
  })();
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition:
      background-color    500ms ease,
      backdrop-filter     500ms ease,
      border-bottom-color 500ms ease;
  }

  .nav.scrolled {
    background: oklch(0.10 0.010 95 / 0.45);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
            backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--hairline);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 20px 40px;
  }

  /* ---------- BRAND ---------- */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--bone);
  }

  .nav-lever {
    width: 36px;
    height: 16px;
    display: block;
    color: var(--signal);
  }

  .nav-lever-rotor {
    transform-origin: 28px 12px;
    transition: transform 220ms ease-out;
  }

  .nav-brand:hover .nav-lever-rotor {
    transform: rotate(-8deg);
  }

  .nav-brand-text {
    line-height: 1.1;
  }

  .nav-brand-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--bone);
  }

  .nav-brand-sub {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }

  /* ---------- LINKS ---------- */
  .nav-links {
    display: none;
    gap: 32px;
  }

  @media (min-width: 880px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg-65);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    transition: color 220ms ease;
  }

  .nav-link-id {
    color: oklch(0.62 0.16 60 / 0.7);
    transition: color 220ms ease;
  }

  .nav-link:hover,
  .nav-link.current {
    color: var(--signal);
  }
  .nav-link:hover .nav-link-id,
  .nav-link.current .nav-link-id {
    color: var(--signal);
  }

  /* ---------- AUTH (Entrar / Minha jornada) ---------- */
  .nav-auth[hidden] { display: none; }
  .nav-auth {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--bone);
    background: oklch(0.82 0.155 78 / 0.10);
    border: 1px solid oklch(0.82 0.155 78 / 0.55);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 16px;
    transition: background-color 220ms ease, border-color 220ms ease, color 220ms ease;
  }
  .nav-auth::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 6px oklch(0.82 0.155 78 / 0.6);
  }
  .nav-auth:hover {
    color: var(--signal);
    border-color: var(--signal);
    background: oklch(0.82 0.155 78 / 0.18);
  }
  .nav-auth[data-state="authed"] {
    color: var(--signal);
    border-color: oklch(0.82 0.155 78 / 0.4);
    background: transparent;
  }

  /* ---------- MINHA JORNADA (authed) ---------- */
  .nav-jornada[hidden] { display: none; }
  .nav-jornada {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--fg-65);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 6px;
    transition: color 220ms ease;
  }
  .nav-jornada:hover { color: var(--signal); }

  /* ---------- LOGOUT (botão "Sair") ---------- */
  .nav-logout {
    display: inline-flex;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .nav-logout[hidden] { display: none; }
  .nav-logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: oklch(0.82 0.155 78 / 0.08);
    border: 1px solid oklch(0.82 0.155 78 / 0.4);
    border-radius: 999px;
    color: var(--bone);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 16px;
    cursor: pointer;
    transition: background-color 220ms ease, border-color 220ms ease, color 220ms ease;
  }
  .nav-logout-btn::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
  }
  .nav-logout-btn:hover {
    color: var(--signal);
    border-color: var(--signal);
    background: oklch(0.82 0.155 78 / 0.16);
  }

  /* ---------- OWNER LINK (Carla) ---------- */
  .nav-owner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--signal);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 12px;
    border: 0.5px solid oklch(0.82 0.155 78 / 0.4);
    border-radius: 999px;
    transition: border-color 220ms ease, background-color 220ms ease;
  }
  .nav-owner:hover {
    border-color: var(--signal);
    background: oklch(0.82 0.155 78 / 0.08);
  }
  .nav-owner-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--signal);
  }
  @media (max-width: 640px) {
    .nav-owner { display: none; }
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 640px) {
    .nav-inner { padding: 16px 24px; gap: 14px; }
    .nav-brand-sub { display: none; }
    .nav-auth-label-rest { display: none; }
    .nav-auth { padding: 8px 12px; }
    .nav-logout-btn { padding: 8px 12px; }
  }
</style>
