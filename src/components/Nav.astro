---
interface NavLink {
  id: string;
  label: string;
  href: string;
  match?: string;
}

interface Props {
  current?: 'diagnostico' | 'trilhas' | 'assistente' | 'casos' | 'jo';
  links?: NavLink[];
  cta?: { label: string; href: string } | null;
}

const defaultLinks: NavLink[] = [
  { id: '01', label: 'Diagnóstico', href: '/mapear/sprint', match: 'mapear' },
  { id: '02', label: 'Trilhas',     href: '/trilhas',       match: 'trilhas' },
  { id: '03', label: 'Assistente',  href: '/assistente',    match: 'assistente' },
  { id: '04', label: 'Ecossistema', href: '/casos',         match: 'casos' },
];

const {
  current,
  links = defaultLinks,
  cta = { label: 'Iniciar diagnóstico', href: '/mapear/sprint' },
} = Astro.props;
---
<header class="nav" id="alavanca-nav">
  <div class="nav-inner shell">
    <a class="nav-brand" href="/">
      <svg class="nav-lever" viewBox="0 0 56 24" aria-hidden="true">
        <g class="nav-lever-rotor">
          <line x1="2" y1="12" x2="54" y2="12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="22" y1="12" x2="28" y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <line x1="34" y1="12" x2="28" y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <circle cx="28" cy="12" r="1.6" fill="currentColor"/>
        </g>
      </svg>
      <div class="nav-brand-text">
        <div class="nav-brand-title">Alavanca</div>
        <div class="nav-brand-sub">CLIC · Inovação pública</div>
      </div>
    </a>

    <nav class="nav-links" aria-label="Seções">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', { current: current && l.match === current }]}
        >
          <span class="nav-link-id">/{l.id}</span>
          <span class="nav-link-label">{l.label}</span>
        </a>
      ))}
    </nav>

    <a class="nav-auth" id="nav-auth" href="/login" data-state="anon">
      <span class="nav-auth-label">Entrar</span>
    </a>

    {cta && (
      <a class="nav-cta" href={cta.href}>
        <span class="nav-cta-dot"></span>
        <span class="nav-cta-label">{cta.label}</span>
        <span class="nav-cta-arrow">→</span>
      </a>
    )}
  </div>
</header>

<script is:inline>
  (() => {
    const nav = document.getElementById('alavanca-nav');
    if (!nav) return;
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<script>
  // Botão único de auth: "Entrar" → /login, ou "Minha jornada" → /minha-jornada
  // se houver sessão. Default SSR aponta pra /login; este script reescreve
  // client-side se Supabase devolver sessão. Flash possível mas curto.
  import { getSupabaseBrowserClient } from '../lib/supabase/browser';

  (async () => {
    const el = document.getElementById('nav-auth') as HTMLAnchorElement | null;
    if (!el) return;
    const label = el.querySelector<HTMLSpanElement>('.nav-auth-label');
    try {
      const sb = getSupabaseBrowserClient();
      const { data } = await sb.auth.getSession();
      if (data?.session) {
        el.href = '/minha-jornada';
        el.dataset.state = 'authed';
        if (label) label.textContent = 'Minha jornada';
      }
    } catch {
      /* segue como Entrar — fallback seguro */
    }
  })();
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition:
      background-color    500ms ease,
      backdrop-filter     500ms ease,
      border-bottom-color 500ms ease;
  }

  .nav.scrolled {
    background: oklch(0.10 0.010 95 / 0.45);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
            backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--hairline);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 20px 40px;
  }

  /* ---------- BRAND ---------- */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--bone);
  }

  .nav-lever {
    width: 36px;
    height: 16px;
    display: block;
    color: var(--signal);
  }

  .nav-lever-rotor {
    transform-origin: 28px 12px;
    transition: transform 220ms ease-out;
  }

  .nav-brand:hover .nav-lever-rotor {
    transform: rotate(-8deg);
  }

  .nav-brand-text {
    line-height: 1.1;
  }

  .nav-brand-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--bone);
  }

  .nav-brand-sub {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }

  /* ---------- LINKS ---------- */
  .nav-links {
    display: none;
    gap: 32px;
  }

  @media (min-width: 880px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg-65);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    transition: color 220ms ease;
  }

  .nav-link-id {
    color: oklch(0.62 0.16 60 / 0.7);
    transition: color 220ms ease;
  }

  .nav-link:hover,
  .nav-link.current {
    color: var(--signal);
  }
  .nav-link:hover .nav-link-id,
  .nav-link.current .nav-link-id {
    color: var(--signal);
  }

  /* ---------- AUTH (Entrar / Minha jornada) ---------- */
  .nav-auth {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--fg-65);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 6px;
    transition: color 220ms ease;
  }
  .nav-auth:hover { color: var(--signal); }
  .nav-auth[data-state="authed"] { color: var(--signal); }

  /* ---------- CTA ---------- */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--hairline);
    padding: 10px 16px;
    text-decoration: none;
    color: var(--bone);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: border-color 250ms ease, color 250ms ease;
  }

  .nav-cta:hover {
    border-color: oklch(0.82 0.155 78 / 0.6);
  }

  .nav-cta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    animation: blink 3.4s steps(1) infinite;
  }

  .nav-cta-arrow {
    color: var(--signal);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 250ms ease, transform 250ms ease;
  }

  .nav-cta:hover .nav-cta-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 640px) {
    .nav-inner { padding: 16px 24px; }
    .nav-brand-sub { display: none; }
    .nav-cta-label { display: none; }
    .nav-cta { padding: 10px 12px; }
    .nav-auth { display: none; }
  }
</style>
