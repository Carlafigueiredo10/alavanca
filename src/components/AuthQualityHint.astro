---
// AuthQualityHint
// -----------------------------------------------------------------
// Card-convite mostrado **só pra anônimo**, dentro dos wizards que
// geram documento. Em modo demo (sessão Supabase ausente), a Jô não
// recebe [CONTEXTO_PRÉVIO] e o output cai do caminho sections-first
// pro chat livre /jo — fica menos estruturado. Aqui convidamos pra
// entrar sem bloquear o fluxo.
//
// Render SSR com hidden=true; o script tira o hidden só depois de
// confirmar `getSession()` vazio. Logado → componente desaparece.
---
<aside class="auth-quality-hint" id="auth-quality-hint" hidden aria-live="polite">
  <div class="aqh-label">↳ Convite</div>
  <p class="aqh-headline">
    Entrar com Google ajuda a gerar materiais mais estruturados.
  </p>
  <p class="aqh-dek">
    Com a jornada salva, a Jô consegue lembrar o contexto entre os verbos,
    versionar as peças geradas e organizar os materiais por laboratório.
  </p>
  <a class="aqh-btn" id="auth-quality-hint-btn" href="/login">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" class="aqh-google">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.15-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.86-2.6 3.29-4.53 6.16-4.53z"/>
    </svg>
    <span>Continuar com Google</span>
  </a>
</aside>

<style>
  .auth-quality-hint {
    max-width: 720px;
    margin: 0 auto 24px;
    padding: 20px 22px 22px;
    border: 0.5px solid var(--fg-22);
    border-left: 2px solid var(--amber);
    border-radius: 10px;
    background: rgba(245, 242, 235, 0.03);
  }
  .aqh-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 12px;
  }
  .aqh-headline {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    line-height: 1.35;
    color: var(--fg);
    margin: 0 0 10px;
  }
  .aqh-dek {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
    margin: 0 0 18px;
  }
  .aqh-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--bg);
    background: var(--amber);
    text-decoration: none;
    border-radius: 999px;
    padding: 10px 18px;
    transition: filter 200ms ease, transform 200ms ease;
  }
  .aqh-btn:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .aqh-google {
    background: var(--bg);
    border-radius: 50%;
    padding: 2px;
    box-sizing: content-box;
  }
</style>

<script>
  import { getSupabaseBrowserClient } from '../lib/supabase/browser';

  const hint = document.getElementById('auth-quality-hint');
  const btn = document.getElementById('auth-quality-hint-btn') as HTMLAnchorElement | null;
  if (hint && btn) {
    // Preserva URL atual no `next` pra voltar pro mesmo wizard após login.
    const here = window.location.pathname + window.location.search;
    btn.href = `/login?next=${encodeURIComponent(here)}`;

    (async () => {
      try {
        const sb = getSupabaseBrowserClient();
        const { data } = await sb.auth.getSession();
        if (!data?.session) hint.hidden = false;
      } catch {
        // Se falhar, melhor revelar — anônimo é o caso default
        hint.hidden = false;
      }
    })();
  }
</script>
