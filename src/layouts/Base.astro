---
import Nav from '../components/Nav.astro';
import JoFab from '../components/JoFab.astro';
import JoDrawer from '../components/JoDrawer.astro';
import JourneyBadge from '../components/JourneyBadge.astro';
import '../styles/tokens.css';

interface NavLink {
  id: string;
  label: string;
  href: string;
  match: string;
}

interface Props {
  title: string;
  description?: string;
  current?: string; // ignorado — Nav detecta ativo via Astro.url.pathname
  navLinks?: NavLink[];
  bodyClass?: string;
}

const {
  title,
  description = 'Plataforma do CLIC para apoio a laboratórios de inovação pública: diagnóstico, trilhas, assistente e casos.',
  current,
  navLinks,
  bodyClass,
} = Astro.props;

const path = Astro.url.pathname;
const showJo = !path.startsWith('/jo') && !path.startsWith('/login');

// Wizards onde o badge "Jornada salva" aparece. Mesma lista do antigo
// AuthQualityHint, mas inversa: lá era convite a logar; aqui é reforço
// de que está logada. Middleware garante sessão antes de chegar aqui.
const WIZARD_PATHS = new Set([
  '/mapear/sprint',
  '/estruturar/sprint',
  '/formalizar/sprint',
  '/formalizar/politica-inovacao',
  '/formalizar/nit',
  '/formalizar/enquadramento-ict',
  '/formalizar/catalogo',
  '/formalizar/portaria',
  '/formalizar/dedicacao',
  '/construir/sprint',
  '/avaliar/sprint',
  '/manter/sprint',
]);
const isWizard = WIZARD_PATHS.has(path);

// Flash single-use: cookie setado pelo /auth/callback após exchange OK.
// Lido SSR + deletado na mesma request. Páginas estáticas não veem cookie,
// mas após login o destino é sempre rota privada (SSR), então funciona.
let flashMessage: string | null = null;
const flashCookie = Astro.cookies.get('alavanca_flash');
if (flashCookie?.value) {
  flashMessage = flashCookie.value;
  Astro.cookies.delete('alavanca_flash', { path: '/' });
}
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body class={bodyClass}>
  <Nav current={current} links={navLinks} />

  {flashMessage && (
    <aside class="flash-toast" id="alavanca-flash" role="status" aria-live="polite">
      <span class="flash-toast-dot" aria-hidden="true"></span>
      <span class="flash-toast-text">{flashMessage}</span>
    </aside>
  )}

  {isWizard && (
    <div class="journey-badge-host">
      <JourneyBadge />
    </div>
  )}

  <main>
    <slot />
  </main>
  {showJo && <JoFab />}
  {showJo && <JoDrawer />}

  <style>
    .flash-toast {
      position: fixed;
      top: 88px;
      left: 50%;
      transform: translateX(-50%);
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      max-width: 560px;
      border: 0.5px solid oklch(0.82 0.155 78 / 0.4);
      border-left: 2px solid var(--amber, #d97706);
      border-radius: 12px;
      background: oklch(0.12 0.012 95 / 0.92);
      -webkit-backdrop-filter: blur(14px) saturate(140%);
              backdrop-filter: blur(14px) saturate(140%);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
      font-family: var(--font-sans, sans-serif);
      font-size: 13.5px;
      line-height: 1.45;
      color: var(--fg-86, #d4ccbe);
      z-index: 1000;
      animation: flashIn 320ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    }
    .flash-toast.is-fade {
      animation: flashOut 600ms ease both;
    }
    .flash-toast-dot {
      flex-shrink: 0;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--amber, #d97706);
      box-shadow: 0 0 8px oklch(0.82 0.155 78 / 0.7);
    }
    .flash-toast-text {
      font-style: italic;
    }
    @keyframes flashIn {
      from { opacity: 0; transform: translate(-50%, -8px); }
      to   { opacity: 1; transform: translate(-50%, 0); }
    }
    @keyframes flashOut {
      from { opacity: 1; }
      to   { opacity: 0; transform: translate(-50%, -8px); }
    }
  </style>

  <script is:inline>
    (() => {
      const flash = document.getElementById('alavanca-flash');
      if (!flash) return;
      // 4.5s visível, depois fade de 600ms, depois remove do DOM.
      setTimeout(() => flash.classList.add('is-fade'), 4500);
      setTimeout(() => flash.remove(), 5200);
    })();
  </script>

  <script is:inline>
    // ============================================================
    // Wizard UX global: foco automático + Enter avança
    // Ativado em qualquer página que tenha .step-input (todos os
    // 6 sprints). Listeners no document — zero por-wizard.
    // ============================================================
    (() => {
      // Quando um textarea de wizard ganha foco, rola pro topo do step
      // inteiro (mostra pergunta + caixa + ações sem corte).
      document.addEventListener('focusin', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLTextAreaElement)) return;
        if (!t.classList.contains('step-input')) return;
        const step = t.closest('.wizard-step');
        if (!step) return;
        // Pequeno delay pra deixar a transição de visibilidade do step
        // terminar antes do scroll (evita "salta-volta").
        setTimeout(() => {
          step.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 60);
      });

      // Enter no textarea: avança pro próximo step (ou dispara gerar
      // no último). Shift+Enter mantém quebra de linha normal.
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' || e.shiftKey) return;
        const t = e.target;
        if (!(t instanceof HTMLTextAreaElement)) return;
        if (!t.classList.contains('step-input')) return;
        const step = t.closest('.wizard-step');
        if (!step) return;
        const next = step.querySelector('[data-step-next], [data-generate]');
        if (!(next instanceof HTMLButtonElement)) return;
        if (next.disabled) return;
        e.preventDefault();
        next.click();
      });
    })();
  </script>
</body>
</html>
