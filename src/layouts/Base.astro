---
import Nav from '../components/Nav.astro';
import JoFab from '../components/JoFab.astro';
import JoDrawer from '../components/JoDrawer.astro';
import '../styles/tokens.css';

interface NavLink {
  id: string;
  label: string;
  href: string;
  match: string;
}

interface Props {
  title: string;
  description?: string;
  current?: string; // ignorado — Nav detecta ativo via Astro.url.pathname
  navLinks?: NavLink[];
  bodyClass?: string;
}

const {
  title,
  description = 'Plataforma do CLIC para apoio a laboratórios de inovação pública: diagnóstico, trilhas, assistente e casos.',
  current,
  navLinks,
  bodyClass,
} = Astro.props;

const path = Astro.url.pathname;
const showJo = !path.startsWith('/jo') && !path.startsWith('/login');
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body class={bodyClass}>
  <Nav current={current} links={navLinks} />
  <main>
    <slot />
  </main>
  {showJo && <JoFab />}
  {showJo && <JoDrawer />}

  <script is:inline>
    // ============================================================
    // Wizard UX global: foco automático + Enter avança
    // Ativado em qualquer página que tenha .step-input (todos os
    // 6 sprints). Listeners no document — zero por-wizard.
    // ============================================================
    (() => {
      // Quando um textarea de wizard ganha foco, rola pro topo do step
      // inteiro (mostra pergunta + caixa + ações sem corte).
      document.addEventListener('focusin', (e) => {
        const t = e.target;
        if (!(t instanceof HTMLTextAreaElement)) return;
        if (!t.classList.contains('step-input')) return;
        const step = t.closest('.wizard-step');
        if (!step) return;
        // Pequeno delay pra deixar a transição de visibilidade do step
        // terminar antes do scroll (evita "salta-volta").
        setTimeout(() => {
          step.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 60);
      });

      // Enter no textarea: avança pro próximo step (ou dispara gerar
      // no último). Shift+Enter mantém quebra de linha normal.
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' || e.shiftKey) return;
        const t = e.target;
        if (!(t instanceof HTMLTextAreaElement)) return;
        if (!t.classList.contains('step-input')) return;
        const step = t.closest('.wizard-step');
        if (!step) return;
        const next = step.querySelector('[data-step-next], [data-generate]');
        if (!(next instanceof HTMLButtonElement)) return;
        if (next.disabled) return;
        e.preventDefault();
        next.click();
      });
    })();
  </script>
</body>
</html>
