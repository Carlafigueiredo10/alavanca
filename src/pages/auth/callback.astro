---
import Base from '../../layouts/Base.astro';
---
<Base title="Entrando…" description="Validando seu link de acesso.">
  <main class="callback-main">
    <div class="callback-card">
      <div class="callback-id">↳ Validando</div>
      <h1 class="callback-title">Entrando na Jô…</h1>
      <p class="callback-status" id="callback-status">Confirmando o link.</p>
      <noscript>
        <p class="callback-status">
          Esta página precisa de JavaScript pra validar o login. Habilita e abra
          o link de novo, ou volte pra <a href="/login">/login</a>.
        </p>
      </noscript>
    </div>
  </main>

  <style>
    .callback-main {
      min-height: calc(100vh - 80px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 24px;
    }
    .callback-card { max-width: 440px; width: 100%; }
    .callback-id {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--fg-50);
      margin-bottom: 28px;
    }
    .callback-title {
      font-family: var(--serif);
      font-weight: 500;
      font-size: clamp(36px, 5vw, 48px);
      line-height: 1.04;
      letter-spacing: -0.024em;
      margin-bottom: 16px;
    }
    .callback-status {
      font-family: var(--sans);
      font-size: 14px;
      color: var(--fg-86);
      line-height: 1.5;
    }
  </style>

  <script>
    import { getSupabaseBrowserClient } from '../../lib/supabase/browser';

    const statusEl = document.getElementById('callback-status') as HTMLElement;
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');
    const next = params.get('next') ?? '/jo';
    const errParam = params.get('error_description') ?? params.get('error');

    function fail(detail: string) {
      window.location.replace(`/login?error=${encodeURIComponent(detail)}`);
    }

    async function run() {
      if (errParam) return fail(errParam);
      if (!code) return fail('Link inválido ou expirado. Peça um novo.');

      try {
        const supabase = getSupabaseBrowserClient();
        const { error } = await supabase.auth.exchangeCodeForSession(code);
        if (error) return fail(error.message);

        statusEl.textContent = 'Pronto. Redirecionando…';
        window.location.replace(next);
      } catch (e) {
        const msg = e instanceof Error ? e.message : 'falha ao validar link';
        fail(msg);
      }
    }

    run();
  </script>
</Base>
