---
export const prerender = false;
import Base from '../layouts/Base.astro';
import MapearCinematic from '../components/landing/MapearCinematic.astro';

const SPRINT_HREF = '/mapear/sprint';
---
<Base
  title="Mapear · O Passo 0 da Inovação Pública · Alavanca"
  description="Diagnóstico institucional preciso para separar problemas reais de Estado de meros sintomas burocráticos. Descubra se o seu laboratório tem jurisdição, capacidade e sustentação institucional antes de gastar tempo, energia e recursos públicos."
  bodyClass="film-grain"
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="m-hero">
    <MapearCinematic />
    <div class="container">
      <div class="m-eyebrow animate-in">
        <span class="m-eyebrow-id">/ 01</span>
        <span class="m-eyebrow-line"></span>
        <span class="m-eyebrow-tag">II · Aplicação · Passo 0</span>
      </div>

      <h1 class="m-verb animate-in delay-100">Mapear.</h1>

      <p class="m-hero-headline animate-in delay-180">
        O Passo 0 da Inovação Pública.
      </p>

      <p class="m-hero-body animate-in delay-260">
        Diagnóstico institucional preciso para separar problemas reais de Estado
        de meros sintomas burocráticos.
      </p>

      <p class="m-hero-body m-hero-body--soft animate-in delay-340">
        Descubra se o seu laboratório tem jurisdição, capacidade e sustentação
        institucional para atuar — antes de gastar tempo, energia e recursos
        públicos.
      </p>

      <div class="m-hero-cta animate-in delay-420">
        <a href={SPRINT_HREF} class="m-cta m-cta-primary">
          Iniciar Diagnóstico com a Jô →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       POR QUE MAPEAR
       ============================================================ -->
  <section class="m-section m-section--why">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Por que Mapear</div>
        <h2 class="m-section-headline">
          Inovar exige direção, não apenas ideação.
        </h2>
        <p class="m-lead">
          Muitos projetos no setor público falham porque tentam desenhar soluções
          para problemas que ainda não foram compreendidos, estão fora da alçada
          institucional do laboratório, dependem de atores sem governabilidade ou
          são sintomas operacionais de causas estruturais maiores.
        </p>
      </div>

      <div class="m-why-grid">
        <div class="m-why-block">
          <div class="m-why-label m-why-label--neg">↳ Falham porque tentam resolver problemas que</div>
          <ul class="m-list m-list--neg">
            <li>ainda não foram compreendidos;</li>
            <li>estão fora da alçada institucional do laboratório;</li>
            <li>dependem de atores sem governabilidade;</li>
            <li>são sintomas operacionais de causas estruturais maiores.</li>
          </ul>
        </div>

        <div class="m-why-block">
          <div class="m-why-label">↳ O módulo Mapear é um roteador estratégico — ajuda a</div>
          <ul class="m-list">
            <li>compreender o cenário institucional;</li>
            <li>localizar riscos;</li>
            <li>identificar gargalos reais;</li>
            <li>avaliar viabilidade;</li>
            <li>produzir um diagnóstico inicial utilizável.</li>
          </ul>
        </div>
      </div>

      <p class="m-pull">
        A proposta não é gerar entusiasmo vazio.<br />
        <span class="m-pull--strong">É oferecer clareza suficiente para decidir se vale a pena avançar.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       COMO A JÔ TRABALHA
       ============================================================ -->
  <section class="m-section m-section--jo">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Como a Jô trabalha</div>
        <h2 class="m-section-headline">
          A Jô é uma assistente de inteligência artificial orientada à produção
          institucional.
        </h2>
        <p class="m-lead">
          Ela não conduz brainstormings genéricos. Ela transforma contexto
          disperso em estrutura operacional. Para produzir diagnósticos
          consistentes, precisa compreender quatro elementos fundamentais do
          cenário.
        </p>
      </div>

      <div class="m-pillars-grid">
        <div class="m-pillar">
          <div class="m-pillar-num">01</div>
          <h3 class="m-pillar-title">O Processo</h3>
          <p class="m-pillar-q">
            Qual fluxo, serviço ou operação pública apresenta falha, lentidão,
            risco ou fricção?
          </p>
        </div>
        <div class="m-pillar">
          <div class="m-pillar-num">02</div>
          <h3 class="m-pillar-title">Os Atores</h3>
          <p class="m-pillar-q">
            Quem decide, quem opera e quem é impactado pelo problema?
          </p>
        </div>
        <div class="m-pillar">
          <div class="m-pillar-num">03</div>
          <h3 class="m-pillar-title">O Gargalo</h3>
          <p class="m-pillar-q">
            Em qual etapa o processo trava técnica, operacional ou
            normativamente?
          </p>
        </div>
        <div class="m-pillar">
          <div class="m-pillar-num">04</div>
          <h3 class="m-pillar-title">O Risco</h3>
          <p class="m-pillar-q">
            Qual o impacto institucional, operacional, reputacional ou financeiro
            se nada mudar?
          </p>
        </div>
      </div>

      <p class="m-foot-note">
        Quanto mais concreto for o contexto informado, melhor será o resultado
        produzido.
      </p>
    </div>
  </section>

  <!-- ============================================================
       O QUE VOCÊ RECEBE
       ============================================================ -->
  <section class="m-section m-section--deliverables">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ O que você recebe</div>
        <h2 class="m-section-headline">
          Um pacote pronto para tramitação administrativa — não conselhos
          genéricos.
        </h2>
        <p class="m-lead">
          Ao concluir o módulo Mapear, a Jô devolve um conjunto institucional
          coerente e utilizável, formatado para encaminhamento direto.
        </p>
      </div>

      <div class="m-deliv-grid">
        <div>
          <div class="m-deliv-label">↳ Entregas do diagnóstico</div>
          <ul class="m-deliv-list">
            <li>
              <h3>Relatório de Diagnóstico Institucional</h3>
              <p>SEI-Ready — pronto pra encaminhamento administrativo.</p>
            </li>
            <li>
              <h3>Matriz de Riscos Embutida</h3>
              <p>Com probabilidade e impacto declarados, lastreados no input.</p>
            </li>
            <li>
              <h3>Diretriz de Decisão</h3>
              <p>Veredito explícito: <strong>GO</strong>, <strong>GO com mitigação</strong> ou <strong>NO-GO</strong>.</p>
            </li>
            <li>
              <h3>Ordem de Ataque (Roteamento)</h3>
              <p>A rota exata de quais módulos acionar a seguir.</p>
            </li>
          </ul>
        </div>

        <div>
          <div class="m-deliv-label m-deliv-label--neg">↳ Conforme o cenário, a Jô também pode indicar</div>
          <ul class="m-list m-list--neg">
            <li>inviabilidade institucional;</li>
            <li>ausência de governabilidade;</li>
            <li>necessidade de refinamento;</li>
            <li>riscos impeditivos;</li>
            <li>necessidade de articulação prévia.</li>
          </ul>
          <p class="m-deliv-quote">
            <em>Nem todo problema deve virar projeto.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INICIE SEU DIAGNÓSTICO — VITRINE DAS 4 PERGUNTAS
       ============================================================ -->
  <section class="m-section m-section--start" id="iniciar">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Inicie seu diagnóstico</div>
        <h2 class="m-section-headline">
          Seja direto. Clareza acelera a precisão da Jô.
        </h2>
        <p class="m-lead">
          As quatro perguntas abaixo estruturam o cenário antes de a Jô iniciar
          a análise. Quando clicar em <strong>Submeter</strong>, você é levado à
          conversa guiada — uma pergunta por vez, com chips de apoio e validação.
        </p>
      </div>

      <div class="m-preview-grid">
        <article class="m-preview-card">
          <div class="m-preview-num">01</div>
          <h3 class="m-preview-title">O Cenário</h3>
          <p class="m-preview-q">
            Qual é o serviço, fluxo ou operação que apresenta falha, risco ou
            fricção?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              Em vez de <em>"problemas no RH"</em>, prefira: <em>"o fluxo de
              concessão de aposentadorias está acumulando seis meses de atraso
              devido à baixa integração entre sistemas."</em>
            </p>
          </div>
        </article>

        <article class="m-preview-card">
          <div class="m-preview-num">02</div>
          <h3 class="m-preview-title">Os Atores</h3>
          <p class="m-preview-q">
            Quem decide, quem executa e quem sofre os impactos?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"Diretor do departamento aprova, três analistas operam
              manualmente o fluxo, e os servidores próximos da aposentadoria são
              os principais impactados."</em>
            </p>
          </div>
        </article>

        <article class="m-preview-card">
          <div class="m-preview-num">03</div>
          <h3 class="m-preview-title">O Gargalo</h3>
          <p class="m-preview-q">
            Em qual ponto o processo trava?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"O sistema legado não integra com o SEI, exigindo retrabalho
              manual em múltiplas etapas."</em>
            </p>
          </div>
        </article>

        <article class="m-preview-card">
          <div class="m-preview-num">04</div>
          <h3 class="m-preview-title">O Risco</h3>
          <p class="m-preview-q">
            Se nada mudar, qual o impacto provável?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"Risco de acúmulo progressivo de passivo processual e aumento
              da exposição aos órgãos de controle."</em>
            </p>
          </div>
        </article>
      </div>

      <div class="m-submit-block">
        <a href={SPRINT_HREF} class="m-cta m-cta-primary m-cta-large">
          Submeter Cenário à Jô →
        </a>
        <p class="m-submit-note">
          A partir daqui, a Jô inicia a conversa guiada para estruturar
          tecnicamente o diagnóstico do seu cenário institucional.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RODAPÉ DE NAVEGAÇÃO
       ============================================================ -->
  <section class="m-bottom">
    <div class="container">
      <a href="/aplicacao" class="m-back">↩ voltar pra Aplicação</a>
    </div>
  </section>

</Base>

<style>
  /* ============================================================
     CONTAINER
     ============================================================ */
  .container { max-width: 920px; }

  /* ============================================================
     HERO
     ============================================================ */
  .m-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 88px;
  }
  .m-hero > .container { position: relative; z-index: 1; }

  .m-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 36px;
  }
  .m-eyebrow-id { color: var(--amber); }
  .m-eyebrow-line {
    flex: 0 0 auto;
    width: 56px;
    height: 0.5px;
    background: var(--fg-22);
  }

  .m-verb {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(56px, 9vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.032em;
    color: var(--fg);
    margin-bottom: 24px;
  }

  .m-hero-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(26px, 3.4vw, 36px);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--fg);
    max-width: 640px;
    margin-bottom: 28px;
    text-wrap: balance;
  }

  .m-hero-body {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg-86);
    max-width: 580px;
    margin-bottom: 16px;
  }
  .m-hero-body--soft { color: var(--fg-65); }

  .m-hero-cta { margin-top: 36px; }

  /* ============================================================
     SECTIONS · BASE
     ============================================================ */
  .m-section {
    position: relative;
    padding: 88px 0;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-section--why         { background: rgba(0, 0, 0, 0.18); }
  .m-section--deliverables { background: rgba(0, 0, 0, 0.18); }

  .m-section-head { max-width: 720px; margin-bottom: 52px; }

  .m-section-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 24px;
  }

  .m-section-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(30px, 4.2vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.022em;
    color: var(--fg);
    margin-bottom: 22px;
    text-wrap: balance;
  }

  .m-lead {
    font-family: var(--sans);
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--fg-86);
    max-width: 640px;
  }
  .m-lead strong { color: var(--fg); font-weight: 500; }

  /* ============================================================
     LISTS
     ============================================================ */
  .m-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .m-list li {
    font-family: var(--sans);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--fg-86);
    padding-left: 18px;
    position: relative;
  }
  .m-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    top: -1px;
    color: var(--amber);
    font-weight: 700;
  }
  .m-list--neg li { color: var(--fg-50); }
  .m-list--neg li::before { color: var(--fg-22); }

  /* ============================================================
     POR QUE MAPEAR · GRID
     ============================================================ */
  .m-why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .m-why-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
  }
  .m-why-label--neg { color: var(--fg-50); }

  .m-pull {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(18px, 2.2vw, 22px);
    line-height: 1.5;
    color: var(--fg-86);
    max-width: 640px;
    padding-top: 32px;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-pull--strong { color: var(--amber); }

  /* ============================================================
     PILARES (COMO A JÔ TRABALHA)
     ============================================================ */
  .m-pillars-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 36px;
  }
  .m-pillar {
    position: relative;
    padding: 24px 22px 26px;
    border: 0.5px solid var(--fg-14);
    background: rgba(245, 242, 235, 0.025);
    border-radius: 10px;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .m-pillar:hover {
    border-color: var(--fg-30);
    background: rgba(245, 242, 235, 0.04);
  }
  .m-pillar-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--amber);
    margin-bottom: 14px;
  }
  .m-pillar-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--fg);
    margin-bottom: 12px;
  }
  .m-pillar-q {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
  }
  .m-foot-note {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-65);
    max-width: 640px;
    padding-top: 28px;
    border-top: 0.5px solid var(--fg-14);
  }

  /* ============================================================
     DELIVERABLES GRID
     ============================================================ */
  .m-deliv-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: start;
  }
  .m-deliv-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
  }
  .m-deliv-label--neg { color: var(--fg-50); }
  .m-deliv-quote {
    margin-top: 28px;
    padding-top: 22px;
    border-top: 0.5px solid var(--fg-14);
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.4;
    color: var(--amber);
  }
  .m-deliv-quote em { font-style: italic; }

  /* Lista de entregas com nome forte + descrição */
  .m-deliv-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .m-deliv-list li {
    position: relative;
    padding-left: 24px;
  }
  .m-deliv-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 14px;
    height: 0.5px;
    background: var(--amber);
  }
  .m-deliv-list h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
    margin-bottom: 6px;
  }
  .m-deliv-list p {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-65);
  }
  .m-deliv-list strong {
    color: var(--amber);
    font-weight: 600;
  }

  /* ============================================================
     INICIAR · VITRINE DAS 4 PERGUNTAS
     ============================================================ */
  .m-preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-bottom: 56px;
  }
  .m-preview-card {
    position: relative;
    padding: 28px 26px 26px;
    border: 0.5px solid var(--fg-22);
    background: rgba(245, 242, 235, 0.03);
    border-radius: 12px;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .m-preview-card:hover {
    border-color: var(--amber-faint);
    background: rgba(245, 242, 235, 0.05);
  }
  .m-preview-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--amber);
    margin-bottom: 14px;
  }
  .m-preview-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.014em;
    color: var(--fg);
    margin-bottom: 12px;
  }
  .m-preview-q {
    font-family: var(--sans);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--fg-86);
    margin-bottom: 20px;
  }
  .m-preview-eg {
    padding: 14px 16px;
    border-left: 2px solid var(--amber-faint);
    background: rgba(0, 0, 0, 0.22);
    border-radius: 0 6px 6px 0;
  }
  .m-preview-eg-label {
    display: block;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 8px;
  }
  .m-preview-eg p {
    font-family: var(--sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--fg-65);
  }
  .m-preview-eg em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-86);
  }

  .m-submit-block {
    text-align: center;
    padding-top: 24px;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-submit-note {
    margin-top: 22px;
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--fg-65);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================================================
     CTAs
     ============================================================ */
  .m-cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 999px;
    padding: 14px 28px;
    transition: filter 180ms ease, transform 180ms ease, box-shadow 200ms ease;
  }
  .m-cta-primary {
    color: var(--bg);
    background: var(--amber);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }
  .m-cta-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow:
      0 10px 28px -10px oklch(0.82 0.155 78 / 0.4),
      0 1px 0 rgba(255, 255, 255, 0.08) inset;
  }
  .m-cta-large {
    padding: 16px 34px;
    font-size: 15px;
  }

  /* ============================================================
     RODAPÉ
     ============================================================ */
  .m-bottom { padding: 48px 0 80px; }
