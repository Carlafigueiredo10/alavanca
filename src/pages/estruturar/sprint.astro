---
import Base from '../../layouts/Base.astro';
import BackBar from '../../components/BackBar.astro';
import AuthQualityHint from '../../components/AuthQualityHint.astro';
---
<Base
  title="Blueprint do Sprint · Estruturar · Alavanca"
  description="Três respostas. A Jô devolve um Blueprint de Sprint SEI-Ready, ancorado no MINDS e nas três fases do InovaGov."
>

<!-- ============================================================
     INTRO
     ============================================================ -->
<section class="intro">
  <div class="container">
    <div class="section-label animate-in">/ Estruturar · Blueprint</div>
    <h1 class="intro-headline animate-in delay-100">Do problema ao plano de fases.</h1>
    <p class="subhead-italic intro-subhead animate-in delay-180">Três respostas estruturam o método.</p>
    <p class="kicker intro-kicker animate-in delay-260">↓ Problema · Hipótese · Experimento</p>
    <div class="intro-meta animate-in delay-340">
      <div class="intro-meta-text">
        Motor metodológico: <strong>Projeto MINDS</strong> (GNova/OCDE) e<br />
        <strong>Guia de Facilitadores InovaGov/ENAP</strong> · Design Sprint setor público.<br />
        <strong>O método permanece — o tempo encolhe.</strong>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     STEPPER
     ============================================================ -->
<section class="stepper-bar">
  <div class="container">
    <div class="stepper" id="stepper">
      <div class="step is-active" data-step="1">
        <span class="step-num">01</span>
        <span class="step-label">Problema</span>
      </div>
      <div class="step-divider"></div>
      <div class="step" data-step="2">
        <span class="step-num">02</span>
        <span class="step-label">Hipótese</span>
      </div>
      <div class="step-divider"></div>
      <div class="step" data-step="3">
        <span class="step-num">03</span>
        <span class="step-label">Experimento</span>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     WIZARD STEPS
     ============================================================ -->
<section class="wizard">
  <div class="container">

    <!-- ── 01 · PROBLEMA ── -->
    <div class="wizard-step is-active" data-step="1">
      <div class="step-header">
        <div class="step-tag">01 · <span class="verb">Problema</span></div>
        <h2 class="step-headline">Qual a dor pública concreta?</h2>
        <p class="step-hint">
          Especifique o serviço, o órgão e o impacto observável. Quanto mais
          concreto, melhor o plano. Os chips ajudam a montar o pacote.
        </p>
      </div>

      <textarea
        class="step-input"
        data-step-input="1"
        rows="4"
        maxlength="600"
        placeholder="Ex: evasão de 40% no agendamento de perícias médicas oficiais, gerando ociosidade de servidores médicos da junta pericial."
      ></textarea>
      <div class="step-counter"><span data-step-counter="1">0</span> / 600</div>
      <div data-chip-palette="1"></div>

      <div class="step-actions">
        <span class="step-back-placeholder"></span>
        <button class="cta cta-primary" data-step-next="1" disabled>Continuar →</button>
      </div>
    </div>

    <!-- ── 02 · HIPÓTESE ── -->
    <div class="wizard-step" data-step="2">
      <div class="step-header">
        <div class="step-tag">02 · <span class="verb">Hipótese</span></div>
        <h2 class="step-headline">Qual a sua hipótese de causa-raiz?</h2>
        <p class="step-hint">
          O que você acredita que está por trás do problema? Formato útil:
          <em>"Se [intervenção], então [resultado], porque [mecanismo]"</em>.
          A Jô vai checar se a sua hipótese é, de verdade, uma hipótese — ou uma solução
          já comprada disfarçada de experimento (viés de confirmação invalida o método).
        </p>
      </div>

      <textarea
        class="step-input"
        data-step-input="2"
        rows="4"
        maxlength="600"
        placeholder="Ex: o servidor não lê o e-mail institucional a tempo. Notificá-lo pelo WhatsApp corporativo reduzirá o absenteísmo, porque é o canal que ele já usa diariamente."
      ></textarea>
      <div class="step-counter"><span data-step-counter="2">0</span> / 600</div>
      <div data-chip-palette="2"></div>

      <div class="step-actions">
        <button class="cta cta-secondary" data-step-back="2">← Voltar</button>
        <button class="cta cta-primary" data-step-next="2" disabled>Continuar →</button>
      </div>
    </div>

    <!-- ── 03 · EXPERIMENTO ── -->
    <div class="wizard-step" data-step="3">
      <div class="step-header">
        <div class="step-tag">03 · <span class="verb">Experimento</span></div>
        <h2 class="step-headline">Como testar essa hipótese?</h2>
        <p class="step-hint">
          Diga a amostra, a duração e o sinal de sucesso. Se não cabe num piloto controlado,
          a Jô vai reduzir o escopo antes de cravar fases. Métrica observável > métrica
          ambiciosa.
        </p>
      </div>

      <textarea
        class="step-input"
        data-step-input="3"
        rows="4"
        maxlength="600"
        placeholder="Ex: enviar aviso via WhatsApp para amostra de 100 servidores e comparar a taxa de evasão com grupo de controle do e-mail, durante 30 dias. Sucesso: redução de pelo menos 15 pontos percentuais na evasão."
      ></textarea>
      <div class="step-counter"><span data-step-counter="3">0</span> / 600</div>
      <div data-chip-palette="3"></div>

      <AuthQualityHint />

      <div class="step-actions">
        <button class="cta cta-secondary" data-step-back="3">← Voltar</button>
        <button class="cta cta-primary cta-large" data-generate disabled>Gerar Blueprint →</button>
      </div>
    </div>

  </div>
</section>

<!-- ============================================================
     RODAPÉ TÉCNICO
     ============================================================ -->
<section class="footnote">
  <div class="container">
    <div class="footnote-grid">
      <div>
        <div class="footnote-label">↳ Saída</div>
        <p>Minuta de Blueprint SEI-Ready com Fase 1 (Entender) · Fase 2 (Explorar) · Fase 3 (Entregar), papéis necessários, fundamentação normativa tripartite e caveat de validação jurídica.</p>
      </div>
      <div>
        <div class="footnote-label">↳ Princípio</div>
        <p>O método do GNova/OCDE permanece. A IA atua como o braço operacional que comprime o tempo de planejamento de meses para horas. Você decide. A Jô redige.</p>
      </div>
    </div>
  </div>
</section>


<BackBar href="/estruturar" label="voltar pra Estruturar" />
</Base>

<style>
  /* ============================================================
     OVERRIDE — Sprint usa coluna estreita pra leitura.
     ============================================================ */
  .container { max-width: 760px; }

  /* ============================================================
     INTRO
     ============================================================ */
  .intro { padding-top: 80px; padding-bottom: 60px; }

  .intro-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(48px, 7vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.028em;
    color: var(--fg);
    margin-bottom: 26px;
    max-width: 640px;
  }

  .intro-subhead { margin-bottom: 18px; }
  .intro-kicker { margin-bottom: 56px; }

  .intro-meta {
    padding-top: 22px;
    border-top: 0.5px solid var(--fg-14);
  }
  .intro-meta-text {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-45);
    line-height: 1.7;
  }
  .intro-meta-text strong {
    font-weight: 500;
    color: var(--fg-86);
  }

  /* ============================================================
     STEPPER
     ============================================================ */
  .stepper-bar {
    padding: 16px 0 32px;
    border-top: 0.5px solid var(--fg-14);
    border-bottom: 0.5px solid var(--fg-14);
    background: rgba(0, 0, 0, 0.18);
  }
  .stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 8px 0;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0.4;
    transition: opacity 240ms ease, color 240ms ease;
  }
  .step.is-active,
  .step.is-done {
    opacity: 1;
  }
  .step-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    transition: color 240ms ease;
  }
  .step.is-active .step-num { color: var(--amber); }
  .step.is-done .step-num { color: var(--fg-86); }
  .step-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-50);
    transition: color 240ms ease;
  }
  .step.is-active .step-label { color: var(--fg); }
  .step-divider {
    width: 36px;
    height: 0.5px;
    background: var(--fg-22);
  }

  @media (max-width: 540px) {
    .stepper { gap: 8px; }
    .step-divider { width: 18px; }
    .step-label { font-size: 10px; letter-spacing: 0.1em; }
  }

  /* ============================================================
     WIZARD STEPS
     ============================================================ */
  .wizard { padding: 56px 0 64px; min-height: 60vh; }

  .wizard-step {
    display: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 360ms cubic-bezier(0.25, 0.1, 0.25, 1),
                transform 360ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  .wizard-step.is-active {
    display: block;
  }
  .wizard-step.is-active.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .step-header { margin-bottom: 26px; }

  .step-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 22px;
  }
  .step-tag .verb { color: var(--amber); }

  .step-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(28px, 3.6vw, 40px);
    line-height: 1.18;
    letter-spacing: -0.018em;
    color: var(--fg);
    margin-bottom: 18px;
    max-width: 640px;
  }

  .step-hint {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-86);
    max-width: 600px;
    margin-bottom: 24px;
  }
  .step-hint em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg);
  }

  .step-input {
    width: 100%;
    background: rgba(245, 242, 235, 0.04);
    border: 0.5px solid var(--fg-22);
    border-radius: 12px;
    padding: 16px 18px;
    color: var(--fg);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.55;
    resize: vertical;
    min-height: 120px;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .step-input:focus {
    outline: none;
    border-color: var(--amber);
    background: rgba(245, 242, 235, 0.06);
  }
  .step-input::placeholder {
    color: var(--fg-45);
    font-style: italic;
  }

  .step-counter {
    margin-top: 8px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: var(--fg-45);
    text-align: right;
  }

  .step-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
  }
  .step-back-placeholder {
    /* Reservado pra equilibrar layout no Step 1 (sem botão Voltar) */
    display: inline-block;
    width: 1px;
  }

  /* ============================================================
     RODAPÉ TÉCNICO
     ============================================================ */
  .footnote {
    padding: 56px 0 80px;
    border-top: 0.5px solid var(--fg-14);
  }
  .footnote-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .footnote-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 12px;
  }
  .footnote p {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--fg-86);
  }
  @media (max-width: 640px) {
    .footnote-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

<script>
  // ============================================================
  // WIZARD · 3 telas → consolidação → handoff pro modo Estruturar
  // ============================================================
  import { getSupabaseBrowserClient } from '../../lib/supabase/browser';
  import { submitWizard } from '../../lib/journey/wizard-submit';
  import { attachChipPalette } from '../../lib/wizard/chips';
  import { ESTRUTURAR_PALETTES } from '../../lib/wizard/chip-palettes';
  import type { ChipPalette } from '../../lib/wizard/chip-palettes';

  type StepNum = 1 | 2 | 3;

  const STATE_KEY = 'alavanca:wizard-state';

  const stepNums: StepNum[] = [1, 2, 3];
  const answers: Record<StepNum, string> = { 1: '', 2: '', 3: '' };
  let current: StepNum = 1;
  // Modo demo aberto: pula o gate de login. Original era `boolean | null`
  // com checkAuth() abaixo — desativado até a demo.
  let isAuthed: boolean = true;

  const steps = document.querySelectorAll<HTMLDivElement>('.wizard-step');
  const stepperItems = document.querySelectorAll<HTMLDivElement>('.stepper .step');

  function showStep(n: StepNum) {
    current = n;
    steps.forEach((el) => {
      const num = Number(el.dataset.step) as StepNum;
      const isActive = num === n;
      el.classList.toggle('is-active', isActive);
      el.classList.remove('is-visible');
      if (isActive) {
        // pequeno atraso pra disparar transição
        requestAnimationFrame(() => el.classList.add('is-visible'));
        const input = el.querySelector<HTMLTextAreaElement>('.step-input');
        setTimeout(() => input?.focus(), 80);
      }
    });
    stepperItems.forEach((el) => {
      const num = Number(el.dataset.step) as StepNum;
      el.classList.toggle('is-active', num === n);
      el.classList.toggle('is-done', num < n);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // bind inputs
  stepNums.forEach((n) => {
    const input = document.querySelector<HTMLTextAreaElement>(`[data-step-input="${n}"]`)!;
    const counter = document.querySelector<HTMLSpanElement>(`[data-step-counter="${n}"]`)!;
    const chipContainer = document.querySelector<HTMLDivElement>(`[data-chip-palette="${n}"]`);
    const palette = ESTRUTURAR_PALETTES[n - 1];
    if (chipContainer && palette) {
      attachChipPalette({ container: chipContainer, textarea: input, palette });
    }
    const nextBtn =
      document.querySelector<HTMLButtonElement>(`[data-step-next="${n}"]`) ||
      (n === 3 ? document.querySelector<HTMLButtonElement>('[data-generate]') : null);

    function refresh() {
      const val = input.value.trim();
      answers[n] = val;
      counter.textContent = String(input.value.length);
      if (nextBtn) nextBtn.disabled = val.length < 12; // exige resposta minimamente substantiva
    }

    input.addEventListener('input', refresh);

    const backBtn = document.querySelector<HTMLButtonElement>(`[data-step-back="${n}"]`);
    backBtn?.addEventListener('click', () => {
      if (n > 1) showStep((n - 1) as StepNum);
    });

    if (n < 3) {
      nextBtn?.addEventListener('click', () => {
        if (answers[n].length < 12) return;
        showStep((n + 1) as StepNum);
      });
    }
  });

  // ── Geração final ──
  const generateBtn = document.querySelector<HTMLButtonElement>('[data-generate]')!;

  function setGenerateLabel() {
    generateBtn.textContent = 'Gerar Blueprint →';
  }

  // Cadeia de versão: setado pelo prefillFromArtifact quando o user chega via
  // /jornada/<id> com ?from=<id>. submitWizard repassa pro backend.
  let editingArtifactId: string | null = null;

  const FIELD_LABELS = ['Problema', 'Hipótese', 'Experimento'];

  function buildArgs(vals: [string, string, string]) {
    return {
      verb: 'estruturar' as const,
      wizardInput: { 1: vals[0], 2: vals[1], 3: vals[2] },
      fallbackText: buildPrompt(vals[0], vals[1], vals[2]),
      fallbackSource: 'wizard-sprint',
      replacesArtifactId: editingArtifactId,
      refine: {
        fieldLabels: FIELD_LABELS,
        fieldPalettes: ESTRUTURAR_PALETTES as (ChipPalette | null)[],
        currentValues: vals as unknown as string[],
        rebuild: (updated: string[]) => {
          stepNums.forEach((n, idx) => {
            const v = updated[idx] ?? '';
            answers[n] = v;
            const ta = document.querySelector<HTMLTextAreaElement>(`[data-step-input="${n}"]`);
            const counter = document.querySelector<HTMLSpanElement>(`[data-step-counter="${n}"]`);
            if (ta) ta.value = v;
            if (counter) counter.textContent = String(v.length);
          });
          return buildArgs([updated[0] ?? '', updated[1] ?? '', updated[2] ?? '']);
        },
      },
    };
  }

  generateBtn.addEventListener('click', async () => {
    if (answers[1].length < 12 || answers[2].length < 12 || answers[3].length < 12) return;

    generateBtn.disabled = true;
    generateBtn.textContent = 'Encaminhando à Jô…';

    await submitWizard(buildArgs([answers[1], answers[2], answers[3]]));
  });

  function buildPrompt(problema: string, hipotese: string, experimento: string): string {
    return [
      '[ Contexto · Wizard Estruturar / Sprint ]',
      '',
      'Cenário pré-estruturado pelo gestor público nas três variáveis canônicas:',
      '',
      `Problema: ${problema}`,
      `Hipótese: ${hipotese}`,
      `Experimento: ${experimento}`,
      '',
      '[ Pedido ]',
      'Redija um Blueprint de Sprint SEI-Ready, aplicando o Paradigma MINDS (foco no cidadão real)',
      'e a tríade do InovaGov (Fase 1: Entender · Fase 2: Explorar · Fase 3: Entregar).',
      'Inclua a Camada Normativa Tripartite (Base Estruturante / Norma Operacional / Lacuna)',
      'e o caveat obrigatório de validação jurídica. Linguagem formal de administração pública.',
      'Se a hipótese parecer "solução já comprada", aponte o viés de confirmação antes do plano.',
    ].join('\n');
  }

  // ── Restauração após login ──
  // Se voltamos do /login com state preservado, repõe os 3 campos e abre
  // direto no Step 3 — usuário só precisa clicar "Gerar Blueprint" de novo.
  function restoreState(): boolean {
    try {
      const raw = localStorage.getItem(STATE_KEY);
      if (!raw) return false;
      // limpa imediatamente — uso único, mesmo que parsing falhe a chave some
      localStorage.removeItem(STATE_KEY);

      const saved = JSON.parse(raw) as Record<string, string | number>;
      // TTL de 1h — espelha vida do magic link. Após isso, descarta.
      const ts = typeof saved.ts === 'number' ? saved.ts : 0;
      if (Date.now() - ts > 3_600_000) return false;

      let restored = false;
      stepNums.forEach((n) => {
        const val = typeof saved[String(n)] === 'string' ? (saved[String(n)] as string) : '';
        if (val.length === 0) return;
        answers[n] = val;
        const input = document.querySelector<HTMLTextAreaElement>(`[data-step-input="${n}"]`);
        const counter = document.querySelector<HTMLSpanElement>(`[data-step-counter="${n}"]`);
        if (input) {
          input.value = val;
          input.dispatchEvent(new Event('input'));
        }
        if (counter) counter.textContent = String(val.length);
        restored = true;
      });
      return restored;
    } catch {
      return false;
    }
  }

  // ── Auth check (não-bloqueante) ──
  // Deixa o wizard renderizar primeiro; só ajusta o label do botão final
  // quando souber o estado de sessão. Se rede falhar, assume não-autenticado
  // (fail-safe pro usuário: no clique, vai pro login → restaura tudo).
  async function checkAuth() {
    try {
      const sb = getSupabaseBrowserClient();
      const { data } = await sb.auth.getSession();
      isAuthed = !!data?.session;
    } catch {
      isAuthed = false;
    }
    setGenerateLabel();
  }

  // ── Pre-fill via ?from=<artifactId> (edição) ────────────────────
  // Tem precedência sobre o restoreState. Se a fetch falhar, segue silencioso.
  async function prefillFromArtifact(artifactId: string): Promise<boolean> {
    try {
      const resp = await fetch(`/api/journey/artifacts/${encodeURIComponent(artifactId)}`);
      if (!resp.ok) return false;
      const data = await resp.json() as { artifact?: { wizard_input?: unknown } };
      const wi = data.artifact?.wizard_input as Record<string, unknown> | undefined;
      if (!wi) return false;
      let any = false;
      stepNums.forEach((n) => {
        const v = wi[String(n)];
        if (typeof v !== 'string' || v.length === 0) return;
        answers[n] = v;
        const ta = document.querySelector<HTMLTextAreaElement>(`[data-step-input="${n}"]`);
        const counter = document.querySelector<HTMLSpanElement>(`[data-step-counter="${n}"]`);
        if (ta) {
          ta.value = v;
          ta.dispatchEvent(new Event('input'));
        }
        if (counter) counter.textContent = String(v.length);
        any = true;
      });
      if (any) {
        editingArtifactId = artifactId;
        showEditingBanner();
      }
      return any;
    } catch {
      return false;
    }
  }

  function showEditingBanner(): void {
    if (document.getElementById('editing-banner')) return;
    const banner = document.createElement('div');
    banner.id = 'editing-banner';
    banner.style.cssText = 'max-width:760px;margin:24px auto 0;padding:12px 18px;border:0.5px solid var(--amber);border-radius:10px;background:rgba(217,119,6,0.08);font-family:var(--sans);font-size:13.5px;color:var(--fg);display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;';
    banner.innerHTML =
      '<span><strong>Editando peça anterior.</strong> Ao gerar, cria uma nova versão (rastreabilidade preservada).</span>' +
      '<a href="/minha-jornada" style="font-family:var(--mono);font-size:11px;letter-spacing:0.14em;color:var(--fg-65);text-decoration:none;">Cancelar ↩</a>';
    const stepperBar = document.querySelector('.stepper-bar');
    if (stepperBar?.parentElement) {
      stepperBar.parentElement.insertBefore(banner, stepperBar);
    } else {
      document.body.prepend(banner);
    }
  }

  const urlParams = new URLSearchParams(window.location.search);
  const fromId = urlParams.get('from');

  async function bootstrap(): Promise<void> {
    let prefilled = false;
    if (fromId) {
      prefilled = await prefillFromArtifact(fromId);
    }
    const restored = !prefilled && restoreState();
    if ((prefilled || restored) && Object.values(answers).every((v) => v.length >= 12)) {
      showStep(3);
    } else {
      showStep(1);
    }
    setGenerateLabel();
  }
  void bootstrap();
  // checkAuth(); // desativado em modo demo aberto
</script>
