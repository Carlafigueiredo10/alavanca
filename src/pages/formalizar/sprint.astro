---
import Base from '../../layouts/Base.astro';

interface Frente {
  num: string;
  slug: string;
  title: string;
  tagline: string;
  body: string;
  meta: string;
  prereq?: 'soft' | 'hard' | null;
}

const frentes: Frente[] = [
  {
    num: '01',
    slug: 'portaria',
    title: 'Portaria de Criação / Institucionalização',
    tagline: 'O ato fundacional. Sem ele, a Procuradoria trava parceria externa.',
    body: 'Minuta SEI-Ready de portaria com vinculação, mandato, competências, composição e vigência. Lastro: Lei 14.129/2021, CF/88 art. 37, decreto interno da casa.',
    meta: '3 telas · 5 a 8 minutos',
  },
  {
    num: '02',
    slug: 'catalogo',
    title: 'Catálogo de Serviços',
    tagline: 'O antídoto do "balcão de pedidos". Define o que o lab faz e o que NÃO faz.',
    body: 'Documento de governança com Ofertas explícitas + Anti-balcão obrigatório + Critérios de Acionamento + SLA. Lastro: Sano (2020), I.LAB, Lei 13.460/2017.',
    meta: '3 telas · 6 a 10 minutos',
  },
  {
    num: '03',
    slug: 'dedicacao',
    title: 'Nota Técnica de Dedicação Exclusiva',
    tagline: 'A defesa da carga horária. RH lê legalidade, não consultoria internacional.',
    body: 'NT fundamentando dedicação primeiro pelo Marco CT&I (art. 9º-A bolsa, art. 14-A afastamento) e depois por OCDE/ENAP. Inclui análise de risco pela IN 01/2016 CGU/MP.',
    meta: '3 telas · 6 a 8 minutos',
  },
  {
    num: '04',
    slug: 'enquadramento-ict',
    title: 'Ato de Enquadramento como ICT',
    tagline: 'O passaporte do Marco CT&I. Sem ICT, não há Encomenda Tecnológica nem NIT.',
    body: 'Alteração de regimento incluindo PD&I entre as competências do órgão. Anti-fachada: só enquadra se houver atividade-meio de PD&I declarada. Lastro: Lei 10.973/2004 art. 2º IV.',
    meta: '3 telas · 7 a 10 minutos',
  },
  {
    num: '05',
    slug: 'nit',
    title: 'Criação do NIT',
    tagline: 'O núcleo obrigatório do art. 16. Com cláusula condicional para não prevaricar.',
    body: 'Portaria + Regimento Interno do Núcleo de Inovação Tecnológica, com as atribuições do art. 17. Embute cláusula condicional suspendendo o funcionamento até a publicação do Ato de Enquadramento como ICT.',
    meta: '4 telas · 8 a 12 minutos',
    prereq: 'soft',
  },
  {
    num: '06',
    slug: 'politica-inovacao',
    title: 'Política de Inovação da ICT',
    tagline: 'A peça do art. 15-A. Modelo Integrado entrega Diretrizes; Fragmentado entrega resoluções.',
    body: 'Trava de pré-requisito (gatekeeper): exige confirmação prévia do Enquadramento como ICT. Modelo Integrado = espinha dorsal de Diretrizes; Modelo Fragmentado = núcleo + 4 resoluções (PI · Transferência · Remuneração · Cooperação). FORMICT embutido.',
    meta: '5 telas · 10 a 15 minutos',
    prereq: 'hard',
  },
];
---
<Base
  title="Frentes do Formalizar · Alavanca"
  description="Seis frentes autônomas: Portaria · Catálogo · Dedicação · Enquadramento ICT · NIT · Política de Inovação. Cada frente é um sub-wizard isolado com base de conhecimento cirúrgica — sem alucinação cruzada entre regras."
>

<section class="intro">
  <div class="container">
    <div class="section-label animate-in">/ Formalizar · Seis Frentes Autônomas</div>
    <h1 class="intro-headline animate-in delay-100">Escolha a peça que vai redigir.</h1>
    <p class="subhead-italic intro-subhead animate-in delay-180">Cada frente é uma chamada isolada da Jô, com escopo cirúrgico — sem confusão de regras entre verbos.</p>
    <p class="kicker intro-kicker animate-in delay-260">↓ 6 frentes · você decide por onde começar</p>
    <div class="intro-meta animate-in delay-340">
      <div class="intro-meta-text">
        A Jô do Catálogo não conhece regras do Marco CT&I.<br />
        A Jô da Política de Inovação não conhece regras de RH.<br />
        <strong>Cada peça com a profundidade que merece.</strong>
      </div>
    </div>
  </div>
</section>

<section class="grid-section">
  <div class="container">
    <div class="grid">
      {frentes.map((f) => (
        <a class="card" href={`/formalizar/${f.slug}`} data-slug={f.slug}>
          <div class="card-top">
            <span class="card-num">/{f.num}</span>
            {f.prereq === 'soft' && (
              <span class="card-prereq card-prereq--soft" title="Recomenda Enquadramento ICT antes">
                ⚠ recomenda 04 antes
              </span>
            )}
            {f.prereq === 'hard' && (
              <span class="card-prereq card-prereq--hard" title="Exige Enquadramento ICT publicado">
                🔒 exige 04 publicado
              </span>
            )}
          </div>
          <h2 class="card-title">{f.title}</h2>
          <p class="card-tagline">{f.tagline}</p>
          <p class="card-body">{f.body}</p>
          <div class="card-foot">
            <span class="card-meta">{f.meta}</span>
            <span class="card-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="footnote">
  <div class="container">
    <div class="footnote-grid">
      <div>
        <div class="footnote-label">↳ Arquitetura</div>
        <p>Seis system prompts isolados (`src/prompts/jo-formalizar-*.md`). Backend escolhe o `.md` exato pela frente declarada — a Jô da peça acionada não tem contexto das outras. Engenharia anti-alucinação cruzada.</p>
      </div>
      <div>
        <div class="footnote-label">↳ Ordem recomendada</div>
        <p>Lab novo: 01 Portaria → 02 Catálogo → 03 Dedicação. Lab buscando segurança jurídica plena: 04 Enquadramento ICT → 05 NIT → 06 Política de Inovação. Você pode rodar uma de cada vez.</p>
      </div>
    </div>
  </div>
</section>

</Base>

<style>
  .container { max-width: 1080px; }

  .intro { padding-top: 80px; padding-bottom: 48px; }
  .intro-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.04;
    letter-spacing: -0.028em;
    color: var(--fg);
    margin-bottom: 22px;
    max-width: 720px;
  }
  .intro-subhead { margin-bottom: 14px; max-width: 720px; }
  .intro-kicker { margin-bottom: 44px; }
  .intro-meta {
    padding-top: 22px;
    border-top: 0.5px solid var(--fg-14);
  }
  .intro-meta-text {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-45);
    line-height: 1.7;
  }
  .intro-meta-text strong {
    font-weight: 500;
    color: var(--fg-86);
  }

  .grid-section { padding: 32px 0 64px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  @media (max-width: 880px) {
    .grid { grid-template-columns: 1fr; }
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: 28px 28px 24px;
    border: 0.5px solid var(--fg-22);
    border-radius: 14px;
    background: rgba(245, 242, 235, 0.02);
    text-decoration: none;
    color: var(--fg);
    transition: border-color 200ms ease, transform 200ms ease, background 200ms ease;
    min-height: 240px;
  }
  .card:hover {
    border-color: var(--amber);
    transform: translateY(-2px);
    background: rgba(245, 242, 235, 0.05);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    gap: 10px;
  }
  .card-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--amber);
  }
  .card-prereq {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 4px 8px;
    border-radius: 4px;
    border: 0.5px solid;
  }
  .card-prereq--soft {
    color: oklch(0.72 0.12 78);
    border-color: oklch(0.72 0.12 78 / 0.45);
    background: oklch(0.72 0.12 78 / 0.06);
  }
  .card-prereq--hard {
    color: oklch(0.65 0.18 28);
    border-color: oklch(0.65 0.18 28 / 0.50);
    background: oklch(0.65 0.18 28 / 0.06);
  }

  .card-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 10px;
  }
  .card-tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--amber);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .card-body {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
    flex-grow: 1;
    margin-bottom: 18px;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 0.5px solid var(--fg-14);
  }
  .card-meta {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    color: var(--fg-50);
  }
  .card-arrow {
    font-family: var(--mono);
    color: var(--amber);
    font-size: 14px;
  }

  .footnote {
    padding: 48px 0 80px;
    border-top: 0.5px solid var(--fg-14);
  }
  .footnote-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .footnote-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 12px;
  }
  .footnote p {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--fg-86);
  }
  @media (max-width: 640px) {
    .footnote-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
</Base>
