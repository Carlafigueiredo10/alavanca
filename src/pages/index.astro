---
import Base from '../layouts/Base.astro';
import AmbientField        from '../components/landing/AmbientField.astro';
import HudFrame            from '../components/landing/HudFrame.astro';
import Hero                from '../components/landing/Hero.astro';
import Capabilities        from '../components/landing/Capabilities.astro';
import IaSection           from '../components/landing/IaSection.astro';
import EcossistemaSection  from '../components/landing/EcossistemaSection.astro';
import Labs                from '../components/landing/Labs.astro';
import Contribute          from '../components/landing/Contribute.astro';
import LandingFooter       from '../components/landing/LandingFooter.astro';

const navLinks = [
  { id: '01', label: 'Diagnóstico', href: '/mapear/sprint'  },
  { id: '02', label: 'Aplicação',   href: '#aplicacao'      },
  { id: '03', label: 'IA',          href: '#ia'             },
  { id: '04', label: 'Ecossistema', href: '#ecossistema'    },
  { id: '05', label: 'Fundamentos', href: '#fundamentos'    },
  { id: '06', label: 'Contribuir',  href: '#contribuir'     },
];

const navCta = { label: 'Iniciar diagnóstico', href: '/mapear/sprint' };
---
<Base
  title="Alavanca · A força que multiplica laboratórios de inovação pública"
  description="Plataforma do CLIC para apoio a laboratórios de inovação pública: diagnóstico, trilhas, assistentes e casos. IA aplicada com método para mapear, estruturar, formalizar, construir, avaliar e manter."
  navLinks={navLinks}
  navCta={navCta}
  bodyClass="film-grain"
>
  <AmbientField />
  <HudFrame />

  <Hero />
  <Capabilities />
  <IaSection />
  <EcossistemaSection />
  <Labs />
  <Contribute />
  <LandingFooter />
</Base>

<script is:inline>
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  })();
</script>

<script is:inline>
  // Auto-intro da Jô — primeiro scroll do visitante mostra uma bolha de fala
  // ancorada no FAB. Dispara uma vez por sessão (sessionStorage). Não abre o
  // chat; só apresenta a Jô e aponta pro ícone.
  (() => {
    const KEY = 'jo-auto-intro-shown';
    if (sessionStorage.getItem(KEY)) return;

    function trigger() {
      try { sessionStorage.setItem(KEY, '1'); } catch {}
      // Pequeno atraso pra rolagem firmar antes da bolha aparecer.
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('jo:intro-bubble'));
      }, 500);
    }

    window.addEventListener('scroll', trigger, { once: true, passive: true });
  })();
</script>
