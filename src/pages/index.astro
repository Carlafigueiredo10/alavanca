---
import Base from '../layouts/Base.astro';
import AmbientField  from '../components/landing/AmbientField.astro';
import HudFrame      from '../components/landing/HudFrame.astro';
import Hero          from '../components/landing/Hero.astro';
import Capabilities  from '../components/landing/Capabilities.astro';
import Labs          from '../components/landing/Labs.astro';
import Projects      from '../components/landing/Projects.astro';
import Partners      from '../components/landing/Partners.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';

const navLinks = [
  { id: '02', label: 'Aplicação',   href: '#aplicacao'  },
  { id: '03', label: 'Fundamentos', href: '#fundamentos' },
  { id: '04', label: 'Sistema',     href: '#sistema'     },
  { id: '05', label: 'Prova',       href: '#prova'       },
];

const navCta = { label: 'Iniciar diagnóstico', href: '/diagnostico' };
---
<Base
  title="Alavanca · A força que multiplica laboratórios de inovação pública"
  description="Plataforma do CLIC para apoio a laboratórios de inovação pública: diagnóstico, trilhas, assistentes e casos. IA aplicada com método para estruturar, formalizar, construir, avaliar e provar."
  navLinks={navLinks}
  navCta={navCta}
  bodyClass="film-grain"
>
  <AmbientField />
  <HudFrame />

  <Hero />
  <Capabilities />
  <Labs />
  <Projects />
  <Partners />
  <LandingFooter />
</Base>

<script is:inline>
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  })();
</script>
