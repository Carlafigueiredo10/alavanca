---
import Base from '../layouts/Base.astro';
---
<Base title="Alavanca · A força que multiplica laboratórios de inovação pública">

<!-- ============================================================
     I · HERO · DECLARAÇÃO
     ============================================================ -->
<section class="hero" id="hero">
  <div class="container">
    <div class="section-label animate-in">01 / Inovação pública</div>

    <svg class="hero-lever animate-in delay-100" viewBox="0 0 84 48" aria-hidden="true">
      <g class="hero-lever-rotor" id="heroLever">
        <line x1="3" y1="18" x2="81" y2="18" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="34" y1="18" x2="42" y2="42" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="50" y1="18" x2="42" y2="42" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="42" cy="18" r="2" fill="#D97706"/>
      </g>
    </svg>

    <h1 class="hero-wordmark animate-in delay-180">Alavanca</h1>

    <p class="hero-subtitle animate-in delay-260">
      A força que multiplica laboratórios<br />de inovação pública.
    </p>

    <p class="hero-kicker animate-in delay-340">↑ Mais entrega, com a equipe que você tem.</p>

    <div class="hero-meta animate-in delay-420">
      <div>
        <div class="hero-meta-by-label">↳ Por</div>
        <div class="hero-meta-by-name">CLIC · Centro de letramento digital</div>
        <div class="hero-meta-edition">Edição I · Encontro de Labs · MMXXVI</div>
      </div>
      <div class="ctas">
        <a href="/diagnostico" class="cta cta-secondary">Diagnóstico</a>
        <a href="/sobre-jo" class="cta cta-primary">Conheça nossa assistente Jô →</a>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     II · APLICAÇÃO
     ============================================================ -->
<section id="aplicacao" class="section-fade">
  <div class="container">
    <div class="section-label">II / Aplicação</div>

    <h2 class="headline-lg section-headline-pair">Estruturar. Formalizar. Construir. Avaliar. Provar.</h2>
    <p class="subhead-italic section-subhead">IA aplicada com método faz os cinco.</p>

    <hr class="divider divider-strong blocks-divider" />

    <a href="/estruturar" class="block-link">
      <article class="block">
        <div class="block-num">01</div>
        <div>
          <div class="block-title">Estruturar</div>
          <p class="block-pull">Do mapeamento ao plano de fases — em horas, não em meses.</p>
          <p class="block-body">IA mapeia capacidades, identifica gargalos e propõe fases. O método permanece — <em>o tempo encolhe.</em></p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/formalizar" class="block-link">
      <article class="block">
        <div class="block-num">02</div>
        <div>
          <div class="block-title">Formalizar</div>
          <p class="block-pull">Do projeto interno à instituição reconhecida.</p>
          <p class="block-body">IA lê portarias, compara arranjos e produz minutas. <em>O técnico decide — o volume deixa de travar.</em></p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/construir" class="block-link">
      <article class="block">
        <div class="block-num">03</div>
        <div>
          <div class="block-title">Construir</div>
          <p class="block-pull">Da ideia ao protótipo — e do protótipo à operação.</p>
          <p class="block-body">Assistentes, dashboards e automações sem fila de TI. Handoff documentado sem o lab virar suporte permanente. <em>O lab entrega e atravessa.</em></p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/avaliar" class="block-link">
      <article class="block">
        <div class="block-num">04</div>
        <div>
          <div class="block-title">Avaliar</div>
          <p class="block-pull">Do achismo à prova de valor público.</p>
          <p class="block-body">IA desenha teorias de mudança, sugere indicadores de outcome e organiza relatórios de impacto a partir do que o lab já gera. <em>O que mostra valor sobrevive ao próximo corte.</em></p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/provar" class="block-link">
      <article class="block">
        <div class="block-num">05</div>
        <div>
          <div class="block-title">Provar</div>
          <p class="block-pull">Da entrega silenciosa à defesa do lab na transição.</p>
          <p class="block-body">Dossiês de transição, dashboards de impacto, pitches adaptáveis para cada audiência. <em>O lab passa a contar a própria história — com lastro.</em></p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>
  </div>
</section>

<!-- ============================================================
     III · FUNDAMENTOS
     ============================================================ -->
<section class="fundamentos section-fade" id="fundamentos">
  <div class="container">
    <div class="section-label">III / Fundamentos</div>

    <p class="fundamentos-headline">Ideia não vira entrega sem estrutura.</p>
    <p class="fundamentos-subhead"><em>A Alavanca transforma estrutura em método.</em></p>

    <hr class="divider divider-strong" />

    <div class="fundamentos-base">
      <div class="fundamentos-base-list">Base institucional · ENAP · OCDE · MGI</div>
      <a href="/fundamentos" class="fundamentos-base-link">Ver bibliografia →</a>
    </div>
  </div>
</section>

<!-- ============================================================
     IV · SISTEMA
     ============================================================ -->
<section id="sistema" class="section-fade">
  <div class="container">
    <div class="section-label">IV / Sistema</div>

    <h2 class="headline-lg section-headline-pair">Diagnosticar. Orientar. Construir. Referenciar.</h2>
    <p class="subhead-italic section-subhead"><em>Do diagnóstico à execução.</em></p>

    <hr class="divider divider-strong blocks-divider" />

    <a href="/diagnostico" class="block-link">
      <article class="block">
        <div class="block-num block-num--muted">01</div>
        <div>
          <div class="block-title">Diagnóstico</div>
          <p class="block-pull block-pull--small">Saber onde está, em três respostas.</p>
          <p class="block-body">Questionário curto com saída em uma página.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/trilhas" class="block-link">
      <article class="block">
        <div class="block-num block-num--muted">02</div>
        <div>
          <div class="block-title">Trilhas</div>
          <p class="block-pull block-pull--small">Leituras-chave, organizadas por verbo.</p>
          <p class="block-body">Conteúdo direto, com próximos passos.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/assistente" class="block-link">
      <article class="block">
        <div class="block-num block-num--muted">03</div>
        <div>
          <div class="block-title">Assistentes de laboratório</div>
          <p class="block-pull block-pull--small">Assistentes prontos para uso.</p>
          <p class="block-body">Prompts estruturados para aplicar método no mesmo dia.</p>
          <div class="block-meta">15 prompts disponíveis</div>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/casos" class="block-link">
      <article class="block">
        <div class="block-num block-num--muted">04</div>
        <div>
          <div class="block-title">Casos</div>
          <p class="block-pull block-pull--small">Inspiração com lastro.</p>
          <p class="block-body">Exemplos reais com decisões e resultados.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>
  </div>
</section>

<!-- ============================================================
     V · PROVA
     ============================================================ -->
<section id="prova" class="section-fade">
  <div class="container">
    <div class="section-label">V / Prova</div>

    <h2 class="headline-lg section-headline-pair">Funciona na prática.</h2>
    <p class="subhead-italic section-subhead"><em>Método, institucionalização e execução.</em></p>

    <hr class="divider divider-strong blocks-divider" />

    <a href="/casos/gnova" class="block-link">
      <article class="block">
        <div class="block-num">01</div>
        <div>
          <div class="block-title-mono">Gnova · ENAP</div>
          <p class="block-pull block-pull--small">Método aplicado no governo federal.</p>
          <p class="block-body"><span class="result-prefix">↳</span>padronização de práticas entre labs.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/casos/labori" class="block-link">
      <article class="block">
        <div class="block-num">02</div>
        <div>
          <div class="block-title-mono">Labori · AGU</div>
          <p class="block-pull block-pull--small">Formalização como ICT.</p>
          <p class="block-body"><span class="result-prefix">↳</span>viabilizou captação e parcerias.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>

    <hr class="divider divider-soft block-divider" />

    <a href="/casos/011lab" class="block-link">
      <article class="block">
        <div class="block-num">03</div>
        <div>
          <div class="block-title-mono">(011).lab · Prefeitura de SP</div>
          <p class="block-pull block-pull--small">Inovação municipal com participação aberta.</p>
          <p class="block-body"><span class="result-prefix">↳</span>ampliou escala e engajamento.</p>
        </div>
        <span class="block-arrow" aria-hidden="true">→</span>
      </article>
    </a>
  </div>
</section>

<!-- ============================================================
     VI · AÇÃO
     ============================================================ -->
<section class="acao section-fade" id="acao">
  <div class="container">
    <div class="section-label">VI / Ação</div>

    <p class="headline-lg section-headline-pair acao-headline">Pronto para operar.</p>
    <p class="fundamentos-subhead"><em>Escolha por onde começar.</em></p>

    <hr class="divider divider-strong acao-divider" />

    <div class="acao-ctas">
      <a href="/diagnostico" class="cta cta-primary cta-large">Iniciar diagnóstico →</a>
      <a href="/assistente" class="cta cta-secondary cta-large">Falar com o assistente</a>
    </div>

    <div class="colofao">
      <div class="colofao-left">
        <div class="colofao-label">↳ Por</div>
        <div class="colofao-name">CLIC · Centro de letramento digital</div>
      </div>
      <div class="colofao-right">
        <svg class="colofao-lever" viewBox="0 0 56 32" aria-hidden="true">
          <g class="colofao-lever-rotor" transform="rotate(-4.5, 28, 12)">
            <line x1="2" y1="12" x2="54" y2="12" stroke="#D97706" stroke-width="1.4" stroke-linecap="round" opacity="0.7"/>
            <line x1="22" y1="12" x2="28" y2="28" stroke="#D97706" stroke-width="1.4" stroke-linecap="round" opacity="0.7"/>
            <line x1="34" y1="12" x2="28" y2="28" stroke="#D97706" stroke-width="1.4" stroke-linecap="round" opacity="0.7"/>
            <circle cx="28" cy="12" r="1.6" fill="#D97706" opacity="0.7"/>
          </g>
        </svg>
        <div class="colofao-edition">Edição I · MMXXVI</div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     VII · CONSTRUÇÃO COLETIVA · última seção, convite a contribuir
     ============================================================ -->
<section class="contribute section-fade" aria-label="Sugestões da comunidade">
  <div class="container">
    <a href="/sugestoes?from=/" class="contribute-link">
      <h2 class="contribute-headline">Como o Alavanca pode melhorar?</h2>
      <p class="contribute-tagline">Plataforma de construção coletiva.</p>
      <span class="contribute-cta">
        Clique aqui e deixe sua sugestão
        <span class="contribute-cta-arrow" aria-hidden="true">→</span>
      </span>
    </a>
  </div>
</section>

</Base>

<style>
  /* I · HERO */
  .hero {
    padding: 88px 0 64px;
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-lever {
    width: 84px;
    height: 48px;
    margin-bottom: 32px;
    display: block;
  }

  .hero-lever-rotor {
    transform-origin: 42px 18px;
    transition: transform 300ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-wordmark {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(72px, 11vw, 116px);
    line-height: 0.94;
    letter-spacing: -0.034em;
    margin-bottom: 30px;
  }

  .hero-subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.8vw, 28px);
    line-height: 1.34;
    margin-bottom: 18px;
    max-width: 520px;
  }

  .hero-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--amber);
    margin-bottom: 56px;
  }

  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 28px;
    flex-wrap: wrap;
    padding-top: 22px;
    border-top: 0.5px solid var(--fg-14);
  }

  .hero-meta-by-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-45);
    margin-bottom: 4px;
  }

  .hero-meta-by-name {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--fg-86);
    margin-bottom: 8px;
  }

  .hero-meta-edition {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: rgba(245, 242, 235, 0.36);
  }

  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* II · APLICAÇÃO / IV · SISTEMA / V · PROVA — block grid */
  .section-headline-pair {
    margin-bottom: 22px;
  }

  .section-subhead {
    margin-bottom: 60px;
  }

  .blocks-divider {
    margin-bottom: 44px;
  }

  .block {
    display: grid;
    grid-template-columns: 60px 1fr 32px;
    gap: 24px;
    align-items: start;
    position: relative;
  }

  .block + .block-divider {
    margin: 44px 0;
  }

  .block-divider {
    margin: 44px 0;
  }

  .block-num {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 500;
    color: var(--amber-soft);
    padding-top: 2px;
  }

  .block-num--muted {
    color: var(--fg-45);
  }

  .block-title {
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 16px;
    letter-spacing: 0.01em;
  }

  .block-title-mono {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 14px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .block-pull {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.4;
    color: var(--fg);
    margin-bottom: 16px;
    max-width: 520px;
  }

  .block-pull--small {
    font-size: 20px;
    margin-bottom: 12px;
  }

  .block-body {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--fg-78);
    max-width: 520px;
  }

  .block-body em {
    font-style: italic;
    color: var(--fg-94);
  }

  .result-prefix {
    color: var(--amber-faint);
    margin-right: 6px;
  }

  .block-meta {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    color: var(--fg-45);
    margin-top: 14px;
    text-transform: uppercase;
  }

  .block-arrow {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--amber);
    text-align: right;
    padding-top: 4px;
    transition: transform 250ms ease;
    text-decoration: none;
    display: block;
  }

  .block-link {
    display: contents;
    cursor: pointer;
  }

  .block-link:hover :global(.block-arrow) {
    transform: translateX(4px);
  }

  .block-link:hover :global(.block-title-mono),
  .block-link:hover :global(.block-title) {
    color: var(--fg);
  }

  @media (max-width: 640px) {
    .block {
      grid-template-columns: 36px 1fr 24px;
      gap: 14px;
    }
    .block-num { font-size: 18px; }
    .block-pull { font-size: 18px; }
    .block-pull--small { font-size: 17px; }
  }

  /* III · FUNDAMENTOS */
  .fundamentos {
    padding: 86px 0 82px;
  }

  .fundamentos-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 60px);
    line-height: 1.06;
    letter-spacing: -0.026em;
    margin-bottom: 28px;
    max-width: 640px;
  }

  .fundamentos-subhead {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.8vw, 30px);
    line-height: 1.32;
    margin-bottom: 64px;
    max-width: 540px;
  }

  .fundamentos-base {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 28px;
    gap: 20px;
    flex-wrap: wrap;
  }

  .fundamentos-base-list {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
  }

  .fundamentos-base-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--amber);
    text-decoration: none;
    transition: opacity 200ms ease, transform 200ms ease;
    display: inline-flex;
    gap: 4px;
  }

  .fundamentos-base-link:hover {
    opacity: 0.85;
    transform: translateX(2px);
  }

  /* V.5 · CONSTRUÇÃO COLETIVA — interlúdio entre Prova e Ação */
  .contribute {
    padding: 64px 0;
    border-top: 0.5px solid var(--fg-22);
  }

  .contribute-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    max-width: 640px;
  }

  .contribute-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(28px, 4vw, 38px);
    line-height: 1.18;
    letter-spacing: -0.018em;
    color: var(--fg);
    margin-bottom: 10px;
  }

  .contribute-tagline {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .contribute-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--amber);
    border: 0.5px solid var(--amber);
    padding: 12px 24px;
    border-radius: 999px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: background 250ms ease, color 250ms ease, transform 250ms ease, box-shadow 250ms ease;
  }

  .contribute-cta-arrow {
    font-family: var(--mono);
    font-size: 16px;
    transition: transform 250ms ease;
  }

  .contribute-link:hover .contribute-cta {
    background: var(--amber);
    color: var(--bg);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -8px rgba(217, 119, 6, 0.35);
  }

  .contribute-link:hover .contribute-cta-arrow {
    transform: translateX(4px);
  }

  .contribute-link:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 6px;
  }

  /* VI · AÇÃO */
  .acao {
    padding: 96px 0 88px;
  }

  .acao-headline {
    font-size: clamp(48px, 7vw, 64px);
  }

  .acao-divider {
    margin-bottom: 44px;
  }

  .acao-ctas {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 88px;
  }

  .colofao {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 0.5px solid var(--fg-22);
  }

  .colofao-left .colofao-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 6px;
  }

  .colofao-left .colofao-name {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--fg);
  }

  .colofao-right {
    text-align: right;
  }

  .colofao-lever {
    width: 56px;
    height: 32px;
    display: inline-block;
    margin-bottom: 8px;
  }

  .colofao-lever-rotor {
    transform-origin: 28px 12px;
  }

  .colofao-edition {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--fg-45);
  }

  @media (max-width: 640px) {
    .colofao { flex-direction: column; }
    .colofao-right { text-align: left; }
  }
</style>

<script>
  // ============================================================
  // CINÉTICA DA ALAVANCA NO SCROLL
  // hero: -1.2° → -5.0° conforme o leitor desce a página
  // nav:  -2.0° → -5.0° (eco discreto)
  // ============================================================

  const heroLever = document.getElementById('heroLever');
  const navLever = document.getElementById('navLever');

  const clamp = (v: number, min: number, max: number) => Math.min(Math.max(v, min), max);

  function updateLevers() {
    const doc = document.documentElement;
    const scrollTop = window.scrollY || doc.scrollTop;
    const scrollHeight = (doc.scrollHeight - doc.clientHeight) || 1;
    const pct = clamp(scrollTop / scrollHeight, 0, 1);

    const heroAngle = -1.2 - (pct * 3.8);
    const navAngle = -2.0 - (pct * 3.0);

    if (heroLever) heroLever.setAttribute('transform', `rotate(${heroAngle.toFixed(2)} 42 18)`);
    if (navLever) navLever.setAttribute('transform', `rotate(${navAngle.toFixed(2)} 28 12)`);
  }

  let ticking = false;
  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateLevers();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  updateLevers();

  // ============================================================
  // FADE-IN DE SEÇÕES NO SCROLL
  // ============================================================
  if ('IntersectionObserver' in window) {
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            sectionObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
    );

    document.querySelectorAll('.section-fade').forEach((el) => {
      sectionObserver.observe(el);
    });
  } else {
    document.querySelectorAll('.section-fade').forEach((el) => {
      el.classList.add('visible');
    });
  }
</script>
