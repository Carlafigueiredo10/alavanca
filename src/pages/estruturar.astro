---
import Base from '../layouts/Base.astro';
import EstruturarCinematic from '../components/landing/EstruturarCinematic.astro';

const SPRINT_HREF = '/estruturar/sprint';
---
<Base
  title="Estruturar · Onde a ideia vira método · Alavanca"
  description="Transforme o diagnóstico em um roteiro de prototipagem claro e executável. A Jô estrutura Sprints de Inovação — Entender, Explorar, Entregar — antes de gastar recursos públicos em larga escala."
  bodyClass="film-grain"
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="m-hero">
    <EstruturarCinematic />
    <div class="container">
      <div class="m-eyebrow animate-in">
        <span class="m-eyebrow-id">/ 02</span>
        <span class="m-eyebrow-line"></span>
        <span class="m-eyebrow-tag">II · Aplicação · Método I.LAB</span>
      </div>

      <h1 class="m-verb animate-in delay-100">Estruturar.</h1>

      <p class="m-hero-headline animate-in delay-180">
        Onde a ideia vira método e o problema vira teste.
      </p>

      <p class="m-hero-body animate-in delay-260">
        Transforme o seu diagnóstico em um roteiro de prototipagem claro e
        executável.
      </p>

      <p class="m-hero-body m-hero-body--soft animate-in delay-340">
        Planeje como o laboratório vai entender o usuário, explorar soluções e
        entregar um experimento — antes de gastar recursos públicos em larga
        escala.
      </p>

      <div class="m-hero-cta animate-in delay-420">
        <a href={SPRINT_HREF} class="m-cta m-cta-primary">
          Iniciar Estruturação com a Jô →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       POR QUE ESTRUTURAR
       ============================================================ -->
  <section class="m-section m-section--why">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Por que Estruturar</div>
        <h2 class="m-section-headline">
          Inovação sem método é apenas improviso.
        </h2>
        <p class="m-lead">
          Muitas iniciativas públicas falham porque a equipe pula do problema
          direto para a implementação, sem testar suas premissas. O módulo
          Estruturar funciona como o <strong>freio metodológico</strong> do
          projeto.
        </p>
      </div>

      <div class="m-why-grid">
        <div class="m-why-block">
          <div class="m-why-label m-why-label--neg">↳ Impede que equipes</div>
          <ul class="m-list m-list--neg">
            <li>construam sistemas inteiros antes de validar hipóteses;</li>
            <li>escalem soluções sem evidência;</li>
            <li>confundam desejo institucional com necessidade do usuário;</li>
            <li>executem projetos sem lógica experimental.</li>
          </ul>
        </div>

        <div class="m-why-block">
          <div class="m-why-label">↳ Em troca, garante</div>
          <ul class="m-list">
            <li>roteiro experimental antes da implementação;</li>
            <li>foco em hipóteses arriscadas e testáveis;</li>
            <li>validação rápida com cidadão, servidor ou usuário final;</li>
            <li>plano de trabalho metodológico justificável institucionalmente.</li>
          </ul>
        </div>
      </div>

      <p class="m-pull">
        A proposta não é desacelerar a inovação.<br />
        <span class="m-pull--strong">É reduzir desperdício antes da implementação.</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       COMO A JÔ TRABALHA
       ============================================================ -->
  <section class="m-section m-section--jo">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Como a Jô trabalha</div>
        <h2 class="m-section-headline">
          A Jô não desenha projetos tradicionais. Ela estrutura Sprints de
          Inovação.
        </h2>
        <p class="m-lead">
          A lógica parte de uma premissa simples: antes de construir algo
          grande, o laboratório precisa testar as hipóteses mais arriscadas da
          solução.
        </p>
      </div>

      <div class="m-method-stack">
        <span class="m-method-label">↳ Motor metodológico</span>
        <ul class="m-method-list">
          <li><strong>Design Sprint</strong> · InovaGov</li>
          <li><strong>Projeto MINDS</strong> · GNova / OCDE</li>
          <li><strong>SIMPLES MENTE</strong> · ciências comportamentais</li>
        </ul>
      </div>

      <div class="m-pillars-grid m-pillars-grid--two">
        <div class="m-pillar">
          <div class="m-pillar-num">A</div>
          <h3 class="m-pillar-title">Foco no Usuário</h3>
          <p class="m-pillar-q">
            A Jô não aprova soluções desenhadas apenas para melhorar o conforto
            interno da burocracia. A experiência do cidadão, servidor ou
            usuário final precisa fazer parte da hipótese.
          </p>
        </div>
        <div class="m-pillar">
          <div class="m-pillar-num">B</div>
          <h3 class="m-pillar-title">Testabilidade</h3>
          <p class="m-pillar-q">
            Se a proposta depender imediatamente de um grande sistema,
            contratação extensa ou implementação massiva, a Jô exigirá
            redução de escopo. Toda solução precisa poder ser prototipada,
            observada e validada rapidamente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       O QUE VOCÊ RECEBE
       ============================================================ -->
  <section class="m-section m-section--deliverables">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ O que você recebe</div>
        <h2 class="m-section-headline">
          Um plano metodológico pronto para aplicação prática.
        </h2>
        <p class="m-lead">
          Ao concluir a estruturação, a Jô devolve um Blueprint operacional —
          plano de trabalho inicial do laboratório, justificável pra alocação
          de equipe e direcionamento metodológico.
        </p>
      </div>

      <div class="m-deliv-grid">
        <div>
          <div class="m-deliv-label">↳ Entrega da estruturação</div>
          <ul class="m-deliv-list">
            <li>
              <h3>Blueprint de Sprint (SEI-Ready)</h3>
              <p>
                Documento detalhando o ciclo da intervenção nas três fases
                canônicas da inovação pública:
                <strong>Entender</strong> · <strong>Explorar</strong> ·
                <strong>Entregar</strong>.
              </p>
            </li>
            <li>
              <h3>Lógica Experimental</h3>
              <p>Hipótese central, riscos a testar e critérios de validação.</p>
            </li>
            <li>
              <h3>Plano de Trabalho Inicial</h3>
              <p>
                Base institucional pra alocação de equipe, organização do
                sprint e direcionamento metodológico.
              </p>
            </li>
          </ul>
        </div>

        <div>
          <div class="m-deliv-label m-deliv-label--neg">↳ Conforme o cenário, a Jô também pode indicar</div>
          <ul class="m-list m-list--neg">
            <li>hipótese mal formulada;</li>
            <li>ausência de testabilidade;</li>
            <li>solução excessivamente ampla;</li>
            <li>desconexão com o usuário final;</li>
            <li>necessidade de simplificação do experimento.</li>
          </ul>
          <p class="m-deliv-quote">
            <em>Nem toda ideia está pronta para ser validada.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INICIE SUA ESTRUTURAÇÃO — VITRINE DAS 3 PERGUNTAS
       ============================================================ -->
  <section class="m-section m-section--start" id="iniciar">
    <div class="container">
      <div class="m-section-head">
        <div class="m-section-label">/ Inicie sua estruturação</div>
        <h2 class="m-section-headline">
          Estruture seu pensamento científico.
        </h2>
        <p class="m-lead">
          Respostas vagas serão devolvidas para refinamento. Quando clicar em
          <strong>Submeter</strong>, você é levado à conversa guiada — uma
          pergunta por vez, com chips de apoio e validação.
        </p>
      </div>

      <div class="m-preview-grid m-preview-grid--three">
        <article class="m-preview-card">
          <div class="m-preview-num">01</div>
          <h3 class="m-preview-title">O Problema</h3>
          <p class="m-preview-q">
            O que foi diagnosticado e precisa ser resolvido?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"Os cidadãos estão abandonando o preenchimento do formulário
              de licença ambiental na metade do processo devido ao excesso de
              jargão jurídico."</em>
            </p>
          </div>
        </article>

        <article class="m-preview-card">
          <div class="m-preview-num">02</div>
          <h3 class="m-preview-title">A Hipótese</h3>
          <p class="m-preview-q">
            Qual é a aposta de solução que será validada?
            <span class="m-preview-q-aside">Lembre-se: uma hipótese não é uma certeza.</span>
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"Acreditamos que reescrever o formulário usando linguagem
              simples reduzirá o abandono em 40%."</em>
            </p>
          </div>
        </article>

        <article class="m-preview-card">
          <div class="m-preview-num">03</div>
          <h3 class="m-preview-title">O Experimento</h3>
          <p class="m-preview-q">
            Como essa hipótese pode ser testada de forma barata, rápida e
            observável?
          </p>
          <div class="m-preview-eg">
            <span class="m-preview-eg-label">Exemplo</span>
            <p>
              <em>"Realizaremos um teste A/B em PDF com vinte cidadãos no
              balcão de atendimento durante uma manhã."</em>
            </p>
          </div>
        </article>
      </div>

      <div class="m-submit-block">
        <a href={SPRINT_HREF} class="m-cta m-cta-primary m-cta-large">
          Submeter Estrutura à Jô →
        </a>
        <p class="m-submit-note">
          A partir daqui, a Jô inicia a conversa guiada para estruturar
          metodologicamente o experimento do laboratório.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       RODAPÉ
       ============================================================ -->
  <section class="m-bottom">
    <div class="container">
      <a href="/aplicacao" class="m-back">↩ voltar pra Aplicação</a>
    </div>
  </section>

</Base>

<style>
  /* ============================================================
     CONTAINER
     ============================================================ */
  .container { max-width: 920px; }

  /* ============================================================
     HERO
     ============================================================ */
  .m-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 0 88px;
  }
  .m-hero > .container { position: relative; z-index: 1; }

  .m-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 36px;
  }
  .m-eyebrow-id { color: var(--amber); }
  .m-eyebrow-line {
    flex: 0 0 auto;
    width: 56px;
    height: 0.5px;
    background: var(--fg-22);
  }

  .m-verb {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(56px, 9vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.032em;
    color: var(--fg);
    margin-bottom: 24px;
  }

  .m-hero-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(26px, 3.4vw, 36px);
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--fg);
    max-width: 640px;
    margin-bottom: 28px;
    text-wrap: balance;
  }

  .m-hero-body {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg-86);
    max-width: 580px;
    margin-bottom: 16px;
  }
  .m-hero-body--soft { color: var(--fg-65); }

  .m-hero-cta { margin-top: 36px; }

  /* ============================================================
     SECTIONS · BASE
     ============================================================ */
  .m-section {
    position: relative;
    padding: 88px 0;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-section--why          { background: rgba(0, 0, 0, 0.18); }
  .m-section--deliverables { background: rgba(0, 0, 0, 0.18); }

  .m-section-head { max-width: 720px; margin-bottom: 52px; }

  .m-section-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 24px;
  }

  .m-section-headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(30px, 4.2vw, 44px);
    line-height: 1.12;
    letter-spacing: -0.022em;
    color: var(--fg);
    margin-bottom: 22px;
    text-wrap: balance;
  }

  .m-lead {
    font-family: var(--sans);
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--fg-86);
    max-width: 640px;
  }
  .m-lead strong { color: var(--fg); font-weight: 500; }

  /* ============================================================
     LISTS
     ============================================================ */
  .m-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .m-list li {
    font-family: var(--sans);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--fg-86);
    padding-left: 18px;
    position: relative;
  }
  .m-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    top: -1px;
    color: var(--amber);
    font-weight: 700;
  }
  .m-list--neg li { color: var(--fg-50); }
  .m-list--neg li::before { color: var(--fg-22); }

  /* ============================================================
     POR QUE · GRID
     ============================================================ */
  .m-why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .m-why-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
  }
  .m-why-label--neg { color: var(--fg-50); }

  .m-pull {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(18px, 2.2vw, 22px);
    line-height: 1.5;
    color: var(--fg-86);
    max-width: 640px;
    padding-top: 32px;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-pull--strong { color: var(--amber); }

  /* ============================================================
     MÉTODO STACK (motor metodológico — lastros)
     ============================================================ */
  .m-method-stack {
    margin-bottom: 44px;
    padding: 20px 0;
    border-top: 0.5px solid var(--fg-14);
    border-bottom: 0.5px solid var(--fg-14);
  }
  .m-method-label {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 14px;
  }
  .m-method-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 32px;
  }
  .m-method-list li {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.4;
    color: var(--fg-65);
  }
  .m-method-list strong {
    color: var(--fg);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* ============================================================
     PILARES
     ============================================================ */
  .m-pillars-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .m-pillars-grid--two {
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .m-pillar {
    position: relative;
    padding: 26px 24px 28px;
    border: 0.5px solid var(--fg-14);
    background: rgba(245, 242, 235, 0.025);
    border-radius: 10px;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .m-pillar:hover {
    border-color: var(--fg-30);
    background: rgba(245, 242, 235, 0.04);
  }
  .m-pillar-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--amber);
    margin-bottom: 14px;
  }
  .m-pillar-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--fg);
    margin-bottom: 12px;
  }
  .m-pillar-q {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
  }

  /* ============================================================
     DELIVERABLES
     ============================================================ */
  .m-deliv-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: start;
  }
  .m-deliv-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 20px;
  }
  .m-deliv-label--neg { color: var(--fg-50); }
  .m-deliv-quote {
    margin-top: 28px;
    padding-top: 22px;
    border-top: 0.5px solid var(--fg-14);
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.4;
    color: var(--amber);
  }
  .m-deliv-quote em { font-style: italic; }

  .m-deliv-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .m-deliv-list li {
    position: relative;
    padding-left: 24px;
  }
  .m-deliv-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 14px;
    height: 0.5px;
    background: var(--amber);
  }
  .m-deliv-list h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--fg);
    margin-bottom: 6px;
  }
  .m-deliv-list p {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-65);
  }
  .m-deliv-list strong {
    color: var(--amber);
    font-weight: 600;
  }

  /* ============================================================
     INICIAR · VITRINE
     ============================================================ */
  .m-preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-bottom: 56px;
  }
  .m-preview-grid--three {
    grid-template-columns: repeat(3, 1fr);
  }
  .m-preview-card {
    position: relative;
    padding: 28px 26px 26px;
    border: 0.5px solid var(--fg-22);
    background: rgba(245, 242, 235, 0.03);
    border-radius: 12px;
    transition: border-color 200ms ease, background 200ms ease;
    display: flex;
    flex-direction: column;
  }
  .m-preview-card:hover {
    border-color: var(--amber-faint);
    background: rgba(245, 242, 235, 0.05);
  }
  .m-preview-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--amber);
    margin-bottom: 14px;
  }
  .m-preview-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.014em;
    color: var(--fg);
    margin-bottom: 12px;
  }
  .m-preview-q {
    font-family: var(--sans);
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--fg-86);
    margin-bottom: 20px;
  }
  .m-preview-q-aside {
    display: block;
    margin-top: 6px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--fg-65);
  }
  .m-preview-eg {
    margin-top: auto;
    padding: 14px 16px;
    border-left: 2px solid var(--amber-faint);
    background: rgba(0, 0, 0, 0.22);
    border-radius: 0 6px 6px 0;
  }
  .m-preview-eg-label {
    display: block;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 8px;
  }
  .m-preview-eg p {
    font-family: var(--sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--fg-65);
  }
  .m-preview-eg em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-86);
  }

  .m-submit-block {
    text-align: center;
    padding-top: 24px;
    border-top: 0.5px solid var(--fg-14);
  }
  .m-submit-note {
    margin-top: 22px;
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--fg-65);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================================================
     CTAs
     ============================================================ */
  .m-cta {
    display: inline-block;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 999px;
    padding: 14px 28px;
    transition: filter 180ms ease, transform 180ms ease, box-shadow 200ms ease;
  }
  .m-cta-primary {
    color: var(--bg);
    background: var(--amber);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }
  .m-cta-primary:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow:
