---
import Base from '../layouts/Base.astro';

const error = Astro.url.searchParams.get('error');
const next = Astro.url.searchParams.get('next') ?? '/jo';
---
<Base
  title="Entrar · Jô"
  description="Entre na Jô — assistente de inovação institucional da Alavanca."
>
  <main class="login-main">
    <div class="login-card">
      <div class="login-id">↳ Entrar na Jô</div>
      <h1 class="login-title">A Jô precisa<br/>te conhecer.</h1>
      <p class="login-dek">
        Pra salvar sua jornada e continuar de onde parou.
      </p>

      {error && (
        <div class="login-error">{error}</div>
      )}

      <button class="login-btn" id="login-btn" type="button">
        <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.15-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.86-2.6 3.29-4.53 6.16-4.53z"/>
        </svg>
        <span id="login-btn-label">Entrar com Google</span>
      </button>

      <input type="hidden" id="next" value={next} />

      <div class="login-status" id="login-status" hidden></div>

      <p class="login-footnote">
        Sua jornada (lab nomeado, peças geradas, conversas com a Jô)<br/>
        fica salva pra você consultar. Nada é compartilhado.
      </p>
    </div>
  </main>

  <style>
    .login-main {
      min-height: calc(100vh - 80px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 24px;
    }
    .login-card {
      max-width: 440px;
      width: 100%;
    }
    .login-id {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--fg-50);
      margin-bottom: 28px;
    }
    .login-title {
      font-family: var(--serif);
      font-weight: 500;
      font-size: clamp(40px, 6vw, 56px);
      line-height: 1.02;
      letter-spacing: -0.026em;
      margin-bottom: 18px;
    }
    .login-dek {
      font-family: var(--serif);
      font-style: italic;
      font-size: 18px;
      line-height: 1.45;
      color: var(--fg-86);
      margin-bottom: 36px;
    }
    .login-error {
      font-family: var(--sans);
      font-size: 13px;
      color: var(--fg);
      background: rgba(217, 119, 6, 0.10);
      border: 0.5px solid var(--amber);
      border-radius: 6px;
      padding: 12px 14px;
      margin-bottom: 22px;
    }
    .login-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--bg);
      background: var(--amber);
      border: 0;
      border-radius: 999px;
      padding: 14px 24px;
      cursor: pointer;
      transition: filter 200ms ease, transform 200ms ease;
      margin-bottom: 24px;
    }
    .login-btn:hover:not(:disabled) {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }
    .login-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .google-icon {
      display: block;
      background: var(--bg);
      border-radius: 50%;
      padding: 2px;
      box-sizing: content-box;
    }
    .login-status {
      font-family: var(--sans);
      font-size: 13.5px;
      color: var(--fg-86);
      background: rgba(245, 242, 235, 0.04);
      border: 0.5px solid var(--fg-22);
      border-radius: 8px;
      padding: 14px 16px;
      margin-bottom: 24px;
      line-height: 1.5;
    }
    .login-status.success { border-color: var(--amber); }
    .login-status.error { border-color: rgba(255, 100, 100, 0.5); }
    .login-footnote {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      color: var(--fg-45);
      line-height: 1.6;
    }
  </style>

  <script>
    import { getSupabaseBrowserClient } from '../lib/supabase/browser';

    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const btnLabel = document.getElementById('login-btn-label') as HTMLSpanElement;
    const status = document.getElementById('login-status') as HTMLDivElement;
    const nextInput = document.getElementById('next') as HTMLInputElement;

    function setStatus(text: string, kind: 'success' | 'error' = 'error') {
      status.textContent = text;
      status.classList.remove('success', 'error');
      status.classList.add(kind);
      status.hidden = false;
    }

    btn?.addEventListener('click', async () => {
      btn.disabled = true;
      btnLabel.textContent = 'Abrindo Google…';

      try {
        const supabase = getSupabaseBrowserClient();
        const next = nextInput?.value ?? '/jo';
        const redirectTo = `${window.location.origin}/auth/callback?next=${encodeURIComponent(next)}`;
        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: { redirectTo },
        });
        if (error) {
          setStatus(`Não consegui abrir o Google: ${error.message}`, 'error');
          btn.disabled = false;
          btnLabel.textContent = 'Entrar com Google';
          return;
        }
        // Se chegou aqui sem erro, o browser navega pra accounts.google.com.
      } catch (e) {
        const msg = e instanceof Error ? e.message : 'falha ao iniciar login';
        setStatus(`Erro: ${msg}`, 'error');
        btn.disabled = false;
        btnLabel.textContent = 'Entrar com Google';
      }
    });
  </script>
</Base>
