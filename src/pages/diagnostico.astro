    text-align: right;
    color: var(--fg-86);
    letter-spacing: 0.04em;
  }

  .derivation-pts.is-zero { color: var(--fg-45); }
  .derivation-pts.is-strong { color: var(--amber); }

  .derivation-total {
    padding-top: 14px;
    text-align: right;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg-50);
  }

  .derivation-total strong {
    color: var(--amber);
    font-weight: 500;
  }

  @media (max-width: 540px) {
    .derivation-table { grid-template-columns: 90px 1fr 60px; }
    .derivation-dim { font-size: 9.5px; letter-spacing: 0.1em; }
    .derivation-resp { font-size: 12.5px; }
  }

  /* CTA do Blueprint — peça-síntese quando verbo = Estruturar */
  .blueprint-cta { margin-bottom: 48px; }

  .blueprint-cta-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .blueprint-cta-label .verb { color: var(--amber); }

  .blueprint-cta-card {
    display: grid;
    grid-template-columns: auto 1fr 28px;
    gap: 22px;
    align-items: center;
    padding: 24px 26px;
    border: 0.5px solid var(--amber);
    border-radius: 14px;
    background: rgba(217, 119, 6, 0.08);
    text-decoration: none;
    color: var(--fg);
    transition: background 200ms ease, transform 200ms ease;
  }
  .blueprint-cta-card:hover {
    background: rgba(217, 119, 6, 0.14);
    transform: translateY(-1px);
  }
  .blueprint-cta-card:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }

  .blueprint-cta-chip {
    align-self: flex-start;
    padding: 5px 12px;
    border-radius: 999px;
    background: var(--amber);
    color: var(--bg);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    font-weight: 600;
    text-transform: uppercase;
  }

  .blueprint-cta-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.25;
    color: var(--fg);
    margin-bottom: 8px;
  }
  .blueprint-cta-text {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
  }
  .blueprint-cta-text em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg);
  }

  .blueprint-cta-arrow {
    font-family: var(--mono);
    font-size: 22px;
    color: var(--amber);
    align-self: center;
    transition: transform 200ms ease;
  }
  .blueprint-cta-card:hover .blueprint-cta-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 540px) {
    .blueprint-cta-card {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 20px;
    }
    .blueprint-cta-arrow { display: none; }
    .blueprint-cta-title { font-size: 19px; }
  }

  /* cards de ganchos */
  .hooks-section { margin-bottom: 60px; }

  .hooks-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 14px;
  }

  .hooks-intro {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--fg-86);
    margin-bottom: 24px;
    max-width: 580px;
  }

  .hooks-intro em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg);
  }

  .hooks-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hook-card {
    display: grid;
    grid-template-columns: 1fr 24px;
    gap: 18px;
    padding: 18px 22px;
    border: 0.5px solid var(--fg-22);
    border-radius: 14px;
    background: transparent;
    text-align: left;
    cursor: pointer;
    font-family: var(--sans);
    color: var(--fg-86);
    transition: border-color 200ms ease, background 200ms ease, color 200ms ease;
    width: 100%;
  }

  .hook-card:hover {
    border-color: var(--amber);
    background: rgba(217, 119, 6, 0.06);
    color: var(--fg);
  }

  .hook-card:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
    border-color: var(--amber);
  }

  .hook-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-50);
    flex-wrap: wrap;
  }

  .hook-card-num {
    color: var(--fg-86);
    letter-spacing: 0.16em;
  }

  .hook-card-chip {
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(217, 119, 6, 0.12);
    color: var(--amber);
    letter-spacing: 0.14em;
    font-size: 9.5px;
    font-weight: 500;
  }

  .hook-card-verb {
    padding: 3px 10px;
    border-radius: 999px;
    border: 0.5px solid var(--fg-22);
    background: transparent;
    color: var(--fg-86);
    letter-spacing: 0.14em;
    font-size: 9.5px;
    font-weight: 500;
  }

  .hook-card-resp {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--fg-45);
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .hook-card-resp strong {
    color: var(--fg-86);
    font-weight: 500;
  }

  .hook-card-label {
    font-family: var(--sans);
    font-size: 14.5px;
    font-weight: 500;
    color: var(--fg);
    line-height: 1.45;
  }

  .hook-card-cross {
    margin-top: 8px;
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--fg-50);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  .hook-card-arrow {
    align-self: center;
    font-family: var(--mono);
    font-size: 16px;
    color: var(--fg-45);
    transition: color 200ms ease, transform 200ms ease;
  }

  .hook-card:hover .hook-card-arrow {
    color: var(--amber);
    transform: translateX(3px);
  }

  @media (max-width: 540px) {
    .hook-card { padding: 16px 18px; }
    .hook-card-label { font-size: 13.5px; }
  }

  /* meta */
  .result-meta {
    padding-top: 28px;
    border-top: 0.5px solid var(--fg-22);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-45);
  }

  .result-meta-id { color: var(--fg-86); }

  .result-restart {
    color: var(--fg-50);
    text-decoration: none;
    transition: color 200ms ease;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .result-restart:hover { color: var(--fg); }
</style>

<script>
  // ============================================================
  // DIAGNÓSTICO · 6 dimensões → 1 verbo + cards de peças (deduped)
  // ============================================================
  import {
    buildHooksFromAnswers,
    dedupeHooks,
    buildPrefillText,
    PIECE_TYPE_LABEL,
    VERB_LABEL,
    type Dim,
    type Answers,
  } from '../lib/diagnostico/hooks';

  type Verb = 'formalizar' | 'estruturar' | 'construir';

  const answers: Answers = {
    vocacao: null,
    gargalo: null,
    governanca: null,
    equipe: null,
    abertura: null,
    identidade: null,
  };

  // matriz de scoring — cada resposta atribui pontos a verbo(s)
  const SCORING: Record<Dim, Record<string, Partial<Record<Verb, number>>>> = {
    vocacao: {
      desenvolvedor: { construir: 1 },
      facilitador:   { estruturar: 1 },
      educador:      { estruturar: 1, construir: 1 },
      arquiteto:     { formalizar: 1 },
    },
    gargalo: {
      ideacao:       { estruturar: 3 },
      prototipo:     { construir: 3 },
      implementacao: { formalizar: 2, construir: 1 },
      escala:        { formalizar: 3 },
    },
    governanca: {
      balcao:      { formalizar: 3 },
      programa:    { formalizar: 1 },
      estrategico: {},
      patrocinado: {},
    },
    equipe: {
      conselheiro:          { formalizar: 2 },
      'facilitador-equipe': { formalizar: 1, estruturar: 1 },
      'lab-autonomo':       { formalizar: 1 },
      'lab-pleno':          {},
    },
    abertura: {
      interna:   { estruturar: 2 },
      rede:      { estruturar: 1 },
      cocriacao: {},
      misto:     { estruturar: 1 },
    },
    identidade: {
      invisivel:           { formalizar: 3 },
      vitrine:             { formalizar: 2 },
      'catalogo-informal': { formalizar: 1 },
      'catalogo-formal':   {},
    },
  };

  // máximos teóricos por verbo (worst case do usuário)
  const MAX: Record<Verb, number> = { formalizar: 12, estruturar: 7, construir: 4 };

  const DIM_LABEL: Record<Dim, string> = {
    vocacao: 'Vocação',
    gargalo: 'Gargalo',
    governanca: 'Governança',
    equipe: 'Equipe',
    abertura: 'Abertura',
    identidade: 'Identidade',
  };

  const LABELS: Record<Dim, Record<string, string>> = {
    vocacao: {
      desenvolvedor: 'Desenvolvedor',
      facilitador:   'Facilitador',
      educador:      'Educador',
      arquiteto:     'Arquiteto',
    },
    gargalo: {
      ideacao:       'Ideação',
      prototipo:     'Protótipo',
      implementacao: 'Implementação',
      escala:        'Escala / replicação',
    },
    governanca: {
      balcao:      'Balcão de pedidos',
      programa:    'Programa estabelecido',
      estrategico: 'Estratégico',
      patrocinado: 'Estratégico com patrocínio',
    },
    equipe: {
      conselheiro:          'Conselheiro',
      'facilitador-equipe': 'Facilitador',
      'lab-autonomo':       'Lab autônomo',
      'lab-pleno':          'Lab pleno (dedicação exclusiva)',
    },
    abertura: {
      interna:   'Interna',
      rede:      'Em rede',
      cocriacao: 'Cocriação aberta',
      misto:     'Varia por projeto',
    },
    identidade: {
      invisivel:           'Invisível na casa',
      vitrine:             'Vitrine de cases',
      'catalogo-informal': 'Catálogo informal',
      'catalogo-formal':   'Catálogo formal publicado',
    },
  };

  const VERB_COPY: Record<Verb, { name: string; diag: string; action: string; cta: string; href: string }> = {
    formalizar: {
      name: 'Formalizar',
      diag: 'Sua equipe tem capacidade técnica e de método, mas o arranjo institucional ainda não sustenta o trabalho — limita captação, contratação e durabilidade entre ciclos de gestão.',
      action: 'O caminho é virar ICT (ou equivalente jurídico), abrir captação via FNDCT, formalizar parcerias e construir governança que sobreviva a mudança de gestão.',
      cta: 'Ver caminho de Formalizar →',
      href: '/formalizar',
    },
    estruturar: {
      name: 'Estruturar',
      diag: 'Sua instituição reconhece o lab e há capacidade técnica disponível, mas o método não está consolidado — cada projeto reinventa seu fluxo, e ideias não viram ciclos contínuos de melhoria.',
      action: 'O caminho é desenhar como o lab decide: critérios de priorização, ritmo de sprints, indicadores de impacto, ciclos de revisão. Sem isso, a entrega depende de heroísmo individual.',
      cta: 'Ver caminho de Estruturar →',
      href: '/estruturar',
    },
    construir: {
      name: 'Construir',
      diag: 'Seu lab tem instituição sólida e método claro, mas depende de fila de TI ou contratação externa para construir o que usa — segura o ciclo no ritmo dos atravessadores.',
      action: 'O caminho é capacitar a equipe em IA e no-code para que o próprio lab construa assistentes, dashboards e automações. A autoria das ferramentas é o que garante autonomia operacional.',
      cta: 'Ver caminho de Construir →',
      href: '/construir',
    },
  };

  const questionSections = document.querySelectorAll<HTMLElement>('.question');
  const resultEl = document.getElementById('result') as HTMLElement;

  function scrollToNextUnanswered(currentSection: HTMLElement) {
    const all = Array.from(questionSections);
    const idx = all.indexOf(currentSection);
    for (let i = idx + 1; i < all.length; i++) {
      const dim = all[i].getAttribute('data-question') as Dim;
      if (answers[dim] === null) {
        all[i].scrollIntoView({ behavior: 'smooth', block: 'start' });
        return;
      }
    }
  }

  questionSections.forEach((section) => {
    const dim = section.getAttribute('data-question') as Dim;
    const buttons = section.querySelectorAll<HTMLButtonElement>('.option');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const wasUnanswered = answers[dim] === null;

        buttons.forEach((b) => {
          b.classList.remove('selected');
          b.setAttribute('aria-checked', 'false');
        });
        btn.classList.add('selected');
        btn.setAttribute('aria-checked', 'true');
        answers[dim] = btn.getAttribute('data-key');

        const allFilled = (Object.keys(answers) as Dim[]).every((k) => answers[k] !== null);

        if (allFilled) {
          renderResult();
        } else if (wasUnanswered) {
          // momentum gentil para baixo, mas só na primeira vez —
          // re-edição não força scroll para evitar incomodar.
          setTimeout(() => scrollToNextUnanswered(section), 280);
        }
      });
    });
  });

  function buildProfileLine(answers: Answers): string {
    const parts: string[] = [];
    (Object.keys(answers) as Dim[]).forEach((dim) => {
      const r = answers[dim];
      if (!r) return;
      parts.push(`${DIM_LABEL[dim]}: ${LABELS[dim][r]}`);
    });
    return parts.join(' · ') + '.';
  }

  function renderDerivation(answers: Answers, primary: Verb) {
    (document.getElementById('derivation-verb') as HTMLElement).textContent = VERB_COPY[primary].name;

    const tableEl = document.getElementById('derivation-table') as HTMLElement;
    tableEl.innerHTML = '';

    let total = 0;

    (Object.keys(answers) as Dim[]).forEach((dim) => {
      const key = answers[dim];
      if (!key) return;
      const pts = (SCORING[dim][key] || {})[primary] || 0;
      total += pts;

      const row = document.createElement('div');
      row.className = 'derivation-row';

      const dimEl = document.createElement('div');
      dimEl.className = 'derivation-dim';
      dimEl.textContent = DIM_LABEL[dim];

      const respEl = document.createElement('div');
      respEl.className = 'derivation-resp';
      respEl.textContent = LABELS[dim][key];

      const ptsEl = document.createElement('div');
      ptsEl.className = 'derivation-pts';
      if (pts === 0) ptsEl.classList.add('is-zero');
      else if (pts >= 3) ptsEl.classList.add('is-strong');
      ptsEl.textContent = pts === 0 ? '0 pts' : '+' + pts + ' pts';

      row.appendChild(dimEl);
      row.appendChild(respEl);
      row.appendChild(ptsEl);
      tableEl.appendChild(row);
    });

    (document.getElementById('derivation-total-pts') as HTMLElement).textContent = String(total);
    (document.getElementById('derivation-total-max') as HTMLElement).textContent = String(MAX[primary]);
  }

  const DIM_ORDER: Dim[] = ['vocacao', 'gargalo', 'governanca', 'equipe', 'abertura', 'identidade'];

  function renderHooks(answers: Answers) {
    const listEl = document.getElementById('hooks-list') as HTMLElement;
    listEl.innerHTML = '';

    const all = buildHooksFromAnswers(answers);
    const deduped = dedupeHooks(all);
    deduped.sort((a, b) => DIM_ORDER.indexOf(a.fromDims[0]) - DIM_ORDER.indexOf(b.fromDims[0]));

    const profileLine = buildProfileLine(answers);

    deduped.forEach((hook, idx) => {
      const card = document.createElement('button');
      card.className = 'hook-card';
      card.type = 'button';

      const main = document.createElement('div');

      const header = document.createElement('div');
      header.className = 'hook-card-header';

      const num = document.createElement('span');
      num.className = 'hook-card-num';
      const dimsLabel = hook.fromDims.map((d) => DIM_LABEL[d]).join(' + ');
      num.textContent = String(idx + 1).padStart(2, '0') + ' · ' + dimsLabel;

      const chip = document.createElement('span');
      chip.className = 'hook-card-chip';
      chip.textContent = PIECE_TYPE_LABEL[hook.pieceType];

      const verbChip = document.createElement('span');
      verbChip.className = 'hook-card-verb';
      verbChip.textContent = VERB_LABEL[hook.verb];

      header.appendChild(num);
      header.appendChild(chip);
      header.appendChild(verbChip);
      main.appendChild(header);

      const resp = document.createElement('div');
      resp.className = 'hook-card-resp';
      if (hook.fromDims.length === 1) {
        const d = hook.fromDims[0];
        resp.innerHTML = 'Você marcou: <strong>' + LABELS[d][hook.responsesByDim[d]!] + '</strong>';
      } else {
        resp.innerHTML = hook.fromDims
          .map((d) => DIM_LABEL[d] + ': <strong>' + LABELS[d][hook.responsesByDim[d]!] + '</strong>')
          .join(' · ');
      }
      main.appendChild(resp);

      const label = document.createElement('div');
      label.className = 'hook-card-label';
      label.textContent = hook.label;
      main.appendChild(label);

      if (hook.fromDims.length > 1) {
        const cross = document.createElement('div');
        cross.className = 'hook-card-cross';
        cross.textContent = '↳ Esta peça apoia ' + hook.fromDims.length + ' frentes do seu diagnóstico.';
        main.appendChild(cross);
      }

      const arrow = document.createElement('div');
      arrow.className = 'hook-card-arrow';
      arrow.textContent = '→';

      card.appendChild(main);
      card.appendChild(arrow);

      card.addEventListener('click', () => {
        const prefillText = buildPrefillText({ hook, profileLine });
        try {
          sessionStorage.setItem('alavanca:diag-prefill', JSON.stringify({
            text: prefillText,
            hookId: hook.hookId,
            pieceKey: hook.pieceKey,
            ts: Date.now(),
          }));
        } catch {
          /* ignore */
        }
        window.location.href = '/jo';
      });

      listEl.appendChild(card);
    });
  }

  function renderResult() {
    const scores: Record<Verb, number> = { formalizar: 0, estruturar: 0, construir: 0 };

    (Object.keys(answers) as Dim[]).forEach((dim) => {
      const key = answers[dim];
      if (!key) return;
      const addition = SCORING[dim][key] || {};
      (Object.keys(addition) as Verb[]).forEach((v) => {
        scores[v] += addition[v] || 0;
      });
    });

    const urgency: Record<Verb, number> = {
      formalizar: scores.formalizar / MAX.formalizar,
      estruturar: scores.estruturar / MAX.estruturar,
      construir:  scores.construir  / MAX.construir,
    };

    const maturity: Record<Verb, number> = {
      formalizar: Math.round((1 - urgency.formalizar) * 100),
      estruturar: Math.round((1 - urgency.estruturar) * 100),
      construir:  Math.round((1 - urgency.construir)  * 100),
    };

    const verbs: Verb[] = ['formalizar', 'estruturar', 'construir'];
    const primary = verbs.reduce((best, v) => (urgency[v] > urgency[best] ? v : best), verbs[0]);
    const pool = verbs.filter((v) => v !== primary);
    const secondary = pool.reduce((best, v) => (urgency[v] > urgency[best] ? v : best), pool[0]);

    const copy = VERB_COPY[primary];

    (document.getElementById('result-verb') as HTMLElement).textContent = copy.name;
    (document.getElementById('result-diag') as HTMLElement).textContent = copy.diag;
    (document.getElementById('result-action') as HTMLElement).textContent = copy.action;
    (document.getElementById('result-secondary') as HTMLElement).innerHTML =
      'Depois disso, fortaleça <span class="verb">' + VERB_COPY[secondary].name + '</span>.';

    const ctaPrimary = document.getElementById('result-cta-primary') as HTMLAnchorElement;
    ctaPrimary.textContent = copy.cta;
    ctaPrimary.setAttribute('href', copy.href);

    (document.getElementById('prof-vocacao') as HTMLElement).textContent    = LABELS.vocacao[answers.vocacao!];
    (document.getElementById('prof-gargalo') as HTMLElement).textContent    = LABELS.gargalo[answers.gargalo!];
    (document.getElementById('prof-governanca') as HTMLElement).textContent = LABELS.governanca[answers.governanca!];
    (document.getElementById('prof-equipe') as HTMLElement).textContent     = LABELS.equipe[answers.equipe!];
    (document.getElementById('prof-abertura') as HTMLElement).textContent   = LABELS.abertura[answers.abertura!];
    (document.getElementById('prof-identidade') as HTMLElement).textContent = LABELS.identidade[answers.identidade!];

    document.querySelectorAll<HTMLElement>('.bar-row').forEach((row) => {
      const v = row.getAttribute('data-verb') as Verb;
      const pct = maturity[v];
      const fill = row.querySelector<HTMLElement>('.bar-fill')!;
      const name = row.querySelector<HTMLElement>('.bar-name')!;
      const value = row.querySelector<HTMLElement>('.bar-value')!;

      value.textContent = pct + '%';
      name.classList.toggle('is-recommended', v === primary);
      fill.classList.toggle('is-recommended', v === primary);
      value.classList.toggle('is-recommended', v === primary);

      // reset → animar
      fill.style.width = '0%';
      requestAnimationFrame(() => {
        fill.style.width = pct + '%';
      });
    });

    renderDerivation(answers, primary);
    renderHooks(answers);

    // Mostra CTA do Blueprint só quando o verbo recomendado for Estruturar.
    const blueprintCta = document.getElementById('blueprint-cta');
    if (blueprintCta) {
      blueprintCta.hidden = primary !== 'estruturar';
    }

    const d = new Date();
    const pad = (n: number) => (n < 10 ? '0' + n : '' + n);
    const id =
      'DIAG · ' + pad(d.getDate()) + '.' + pad(d.getMonth() + 1) + '.' + d.getFullYear() +
      ' · ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    (document.getElementById('result-id') as HTMLElement).textContent = id;

    resultEl.classList.add('visible');
    resultEl.setAttribute('aria-hidden', 'false');

    setTimeout(() => {
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 350);
  }

  document.getElementById('result-restart')!.addEventListener('click', (e) => {
    e.preventDefault();
    (Object.keys(answers) as Dim[]).forEach((k) => { answers[k] = null; });
    document.querySelectorAll<HTMLButtonElement>('.option.selected').forEach((o) => {
      o.classList.remove('selected');
      o.setAttribute('aria-checked', 'false');
    });
    resultEl.classList.remove('visible');
    resultEl.setAttribute('aria-hidden', 'true');

    const firstQ = document.getElementById('q1');
    if (firstQ) {
      firstQ.scrollIntoView({ behavior: 'smooth', block: 'start' });
      const firstOption = firstQ.querySelector<HTMLButtonElement>('.option');
      // dá tempo do scroll começar antes de mover o foco, evita salto
      setTimeout(() => firstOption?.focus(), 600);
    }
  });
</script>
