  }

  .derivation-label .verb {
    color: var(--amber);
    text-transform: uppercase;
  }

  .derivation-table {
    display: grid;
    grid-template-columns: 130px 1fr 80px;
    border-top: 0.5px solid var(--fg-14);
  }

  .derivation-row {
    display: contents;
  }

  .derivation-row > * {
    padding: 12px 0;
    border-bottom: 0.5px solid var(--fg-10);
