---
import Base from '../layouts/Base.astro';
import JoChat from '../components/JoChat.astro';

// Modo aberto pré-demo: página acessível a qualquer visitante, sem auth.
// Chat funciona stateless (sem persistência no Supabase, sem sidebar de
// conversas). Para restaurar o fluxo autenticado: git checkout main.
---
<Base title="Jô · Alavanca" description="Assistente embarcada da Alavanca.">
  <main class="jo-page">
    <section class="jo-main">
      <header class="jo-main__header">
        <img
          class="jo-main__avatar"
          src="/jo/jo-avatar-fab.png"
          srcset="/jo/jo-avatar-fab.png 1x, /jo/jo-avatar-fab@2x.png 2x"
          alt="Jô"
        />
        <div class="jo-main__title">
          <h1>Jô</h1>
          <p>A norma fica com ela. A inovação fica com você.</p>
        </div>
      </header>
      <div class="jo-main__chat">
        <JoChat variant="page" />
      </div>
    </section>
  </main>

  <style>
    .jo-page {
      display: flex;
      justify-content: center;
      min-height: calc(100vh - 65px);
      max-height: calc(100vh - 65px);
    }
    .jo-main {
      display: flex;
      flex-direction: column;
      min-height: 0;
      width: 100%;
      max-width: 900px;
    }
    .jo-main__header {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 18px 28px 14px;
      border-bottom: 0.5px solid var(--fg-14);
    }
    .jo-main__avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 0.5px solid var(--fg-22);
    }
    .jo-main__title h1 {
      font-family: var(--serif);
      font-weight: 500;
      font-style: italic;
      font-size: 28px;
      letter-spacing: -0.012em;
      line-height: 1;
      margin-bottom: 4px;
    }
    .jo-main__title p {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--fg-50);
      letter-spacing: 0.06em;
    }
    .jo-main__chat {
      flex: 1 1 auto;
      min-height: 0;
    }
  </style>
</Base>
