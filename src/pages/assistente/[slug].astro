---
import Base from '../../layouts/Base.astro';
import { allPrompts, getPromptBySlug, getNeighbors, eixos } from '../../data/prompts';

export function getStaticPaths() {
  return allPrompts.map((p) => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const prompt = getPromptBySlug(slug!);
if (!prompt) return Astro.redirect('/assistente');
const eixo = eixos.find((e) => e.id === prompt.eixoId)!;
const { prev, next } = getNeighbors(slug!);
---

<Base
  title={`${prompt.title} · Assistentes · Alavanca`}
  description={prompt.purpose}
  current="assistente"
>
  <article class="prompt-page">
    <div class="container">
      <a href="/assistente" class="back">← Voltar ao índice</a>

      <div class="crumb">
        <span class="crumb-num">/{prompt.num}</span>
        <span class="crumb-sep">·</span>
        <span class="crumb-eixo">{eixo.verb}</span>
      </div>

      <div class="head">
        <div class="eyebrow">{prompt.eyebrow}</div>
        <h1 class="title">{prompt.title}</h1>
        <p class="purpose">{prompt.purpose}</p>
      </div>

      <div class="prompt-card">
        <div class="prompt-card-head">
          <span class="prompt-card-label">{prompt.promptLabel}</span>
          <button class="copy-btn" data-target="prompt-body" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span>Copiar</span>
          </button>
        </div>
        <div class="prompt-text" id="prompt-body" set:html={prompt.body}></div>
      </div>

      <div class="when">
        <span class="when-label">Quando usar</span>
        <span class="when-text">{prompt.when}</span>
      </div>

      <nav class="nav" aria-label="Navegação entre prompts do mesmo eixo">
        {prev ? (
          <a href={`/assistente/${prev.id}`} class="nav-link nav-prev">
            <span class="nav-arrow">←</span>
            <span class="nav-block">
              <span class="nav-mono">/{prev.num} · anterior</span>
              <span class="nav-title">{prev.title}</span>
            </span>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={`/assistente/${next.id}`} class="nav-link nav-next">
            <span class="nav-block nav-block-right">
              <span class="nav-mono">/{next.num} · próximo</span>
              <span class="nav-title">{next.title}</span>
            </span>
            <span class="nav-arrow">→</span>
          </a>
        ) : <div></div>}
      </nav>
    </div>
  </article>

  <div class="toast" id="toast">Prompt copiado</div>
</Base>

<style>
  .prompt-page { padding: 88px 0 96px; }

  .back {
    display: inline-flex;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    text-decoration: none;
    margin-bottom: 32px;
    transition: opacity 0.2s ease;
  }
  .back:hover { opacity: 0.78; }

  .crumb {
    display: flex;
    gap: 8px;
    align-items: baseline;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 24px;
  }
  .crumb-num { color: var(--amber); }
  .crumb-eixo { color: var(--fg-78); }

  .head { margin-bottom: 48px; max-width: 70ch; }
  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 16px;
  }
  .title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 18px;
  }
  .purpose {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-78);
    margin: 0;
  }

  /* ============================================================
     PROMPT CARD — copiado verbatim da página antiga
     ============================================================ */
  .prompt-card {
    background: rgba(245, 242, 235, 0.04);
    border: 0.5px solid var(--fg-22);
    border-left: 1.5px solid var(--amber);
    border-radius: 10px;
    overflow: hidden;
    transition: background 0.25s ease;
  }

  .prompt-card:hover {
    background: rgba(245, 242, 235, 0.06);
  }

  .prompt-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 0.5px solid var(--fg-10);
    background: rgba(245, 242, 235, 0.02);
  }

  .prompt-card-label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    color: var(--fg-50);
    text-transform: uppercase;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: transparent;
    border: 0.5px solid var(--amber-faint);
    border-radius: 999px;
    color: var(--amber);
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .copy-btn:hover {
    background: rgba(217, 119, 6, 0.10);
    border-color: var(--amber);
  }

  .copy-btn.copied {
    background: var(--amber);
    color: var(--bg);
    border-color: var(--amber);
  }

  .copy-btn svg { width: 12px; height: 12px; }

  .prompt-text {
    padding: 22px 22px 24px;
    font-family: var(--sans);
    font-size: 14.5px;
    line-height: 1.72;
    color: var(--fg-86);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .prompt-text :global(.placeholder) {
    display: inline;
    background: rgba(217, 119, 6, 0.14);
    color: var(--amber);
    padding: 1px 6px;
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .prompt-text :global(em) {
    font-style: italic;
    color: var(--fg);
  }

  .prompt-text :global(strong) {
    font-weight: 600;
    color: var(--fg);
    font-family: var(--sans);
    letter-spacing: 0.005em;
  }

  .prompt-text :global(code) {
    font-family: var(--mono);
    font-size: 13px;
    background: rgba(217, 119, 6, 0.08);
    color: var(--amber);
    padding: 1px 6px;
    border-radius: 3px;
  }

  /* ============================================================
     WHEN
     ============================================================ */
  .when {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 0.5px solid var(--fg-22);
    display: flex;
    gap: 14px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .when-label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
  }
  .when-text {
    font-family: var(--sans);
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--fg-78);
  }

  /* ============================================================
     NAV prev/next
     ============================================================ */
  .nav {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 0.5px solid var(--fg-22);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    padding: 18px 20px;
    border: 0.5px solid var(--fg-22);
    color: var(--fg);
    transition: border-color 0.2s ease, color 0.2s ease;
    min-width: 0;
  }
  .nav-link:hover { border-color: var(--amber); color: var(--amber); }
  .nav-next { justify-content: flex-end; text-align: right; }
  .nav-arrow { font-family: var(--mono); font-size: 18px; color: var(--amber); flex-shrink: 0; }
  .nav-block { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .nav-block-right { align-items: flex-end; }
  .nav-mono {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .nav-title {
    font-family: var(--serif);
    font-size: 14.5px;
    line-height: 1.25;
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 720px) {
    .nav { grid-template-columns: 1fr; }
  }

  /* ============================================================
     TOAST — copiado verbatim da página antiga
     ============================================================ */
  .toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg);
    color: var(--fg);
    border: 0.5px solid var(--amber);
    padding: 12px 22px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    z-index: 999;
    white-space: nowrap;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .toast::before {
    content: '✓';
    color: var(--amber);
    margin-right: 8px;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      if (!targetId) return;
      const target = document.getElementById(targetId);
      if (!target) return;

      const clone = target.cloneNode(true) as HTMLElement;
      clone.querySelectorAll('.placeholder').forEach((ph) => {
        ph.replaceWith(ph.textContent || '');
      });
      clone.querySelectorAll('em').forEach((em) => {
        em.replaceWith(em.textContent || '');
      });
      const text = (clone.textContent || '').trim().replace(/\n{3,}/g, '\n\n');

      navigator.clipboard.writeText(text).then(() => {
        const label = btn.querySelector('span');
        const originalText = label?.textContent || 'Copiar';
        btn.classList.add('copied');
        if (label) label.textContent = 'Copiado';

        const toast = document.getElementById('toast');
        toast?.classList.add('show');

        setTimeout(() => {
          btn.classList.remove('copied');
          if (label) label.textContent = originalText;
          toast?.classList.remove('show');
        }, 1800);
      }).catch(() => {
        alert('Não foi possível copiar. Selecione o texto manualmente.');
      });
    });
  });
</script>
