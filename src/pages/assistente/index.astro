---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { eixos, allPrompts, promptCount, eixoCount, methodEixoCount, numToPt } from '../../data/prompts';

// Lista plana para o sumário-livro: eixo verbo aparece só na primeira
// linha do grupo (como sumário literário).
const tocRows = eixos.flatMap((eixo) =>
  allPrompts
    .filter((p) => p.eixoId === eixo.id)
    .map((p, idx) => ({
      id: p.id,
      num: p.num,
      title: p.title,
      purpose: p.purpose,
      eixoVerb: eixo.verb,
      isFirstOfEixo: idx === 0,
    })),
);
---
<Base
  title="Assistentes de laboratório · Alavanca"
  description={`${numToPt(promptCount)} prompts pré-configurados para que laboratórios de inovação pública construam no mesmo dia, sem depender da fila da TI.`}
  current="assistente"
>

  <!-- HERO -->
  <header class="ahero">
    <div class="container">
      <div class="ahero-section-id">IV / Sistema · 03 / Assistentes</div>

      <svg class="ahero-lever" viewBox="0 0 84 48" aria-hidden="true">
        <g transform="rotate(-1.2, 42, 18)">
          <line x1="3" y1="18" x2="81" y2="18" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="34" y1="18" x2="42" y2="42" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="50" y1="18" x2="42" y2="42" stroke="#D97706" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="42" cy="18" r="2" fill="#D97706"/>
        </g>
      </svg>

      <h1 class="ahero-title">Assistentes de laboratório.</h1>

      <p class="ahero-dek">{numToPt(promptCount)} prompts para o lab construir<br />no mesmo dia.</p>

      <p class="ahero-kicker">↑ Quem organiza o pensamento, organiza a tecnologia</p>

      <div class="ahero-meta">
        <div class="ahero-meta-block">
          <div class="ahero-meta-label">↳ Por</div>
          <div>CLIC · Centro de letramento digital</div>
          <div class="ahero-meta-sub">Edição I · Encontro de Labs · MMXXVI</div>
        </div>
        <div class="ahero-meta-block ahero-meta-right">
          <div class="ahero-meta-label">↳ Itens</div>
          <div>{promptCount} prompts · {eixoCount} eixos</div>
          <div class="ahero-meta-sub">Estruturar · Formalizar · Construir · Avaliar · Manter · Aplicar</div>
        </div>
      </div>
    </div>
  </header>

  <!-- MÉTODO PTCF -->
  <section class="method">
    <div class="container">
      <div class="method-id">↳ Método PTCF aplicado</div>
      <h2 class="method-title">Quatro variáveis. O resto é fila.</h2>
      <p class="method-dek">Cada prompt abaixo nasce do mesmo gesto: declarar quem fala, o que se pede, o cenário em que a coisa acontece e o formato em que volta.</p>

      <div class="method-grid">
        <div class="method-cell">
          <div class="method-letter">P</div>
          <div class="method-name">Pessoa</div>
          <div class="method-desc">Quem é a IA. Define o tom e a especialidade que ela carrega.</div>
        </div>
        <div class="method-cell">
          <div class="method-letter">T</div>
          <div class="method-name">Tarefa</div>
          <div class="method-desc">O verbo de saída. Diga o que precisa, em uma frase.</div>
        </div>
        <div class="method-cell">
          <div class="method-letter">C</div>
          <div class="method-name">Contexto</div>
          <div class="method-desc">O cenário do lab. A IA não conhece sua repartição — descreva.</div>
        </div>
        <div class="method-cell">
          <div class="method-letter">F</div>
          <div class="method-name">Formato</div>
          <div class="method-desc">A forma da entrega. Lista, tabela, minuta, e-mail, agenda.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ÍNDICE — formato livro -->
  <nav class="toc" aria-label="Índice de prompts">
    <div class="container">
      <div class="toc-head">
        <span class="toc-label">↳ Índice</span>
        <span class="toc-meta">{promptCount} prompts · {eixoCount} eixos · clique para abrir</span>
      </div>
      <ol class="toc-list">
        {tocRows.map((r) => (
          <li class:list={['toc-row', r.isFirstOfEixo && 'toc-row-first']}>
            <a href={`/assistente/${r.id}`} class="toc-row-link">
              <span class="toc-row-eixo">{r.isFirstOfEixo ? r.eixoVerb : ''}</span>
              <span class="toc-row-num">{r.num}</span>
              <span class="toc-row-title">{r.title}</span>
              <span class="toc-row-purpose">{r.purpose}</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </nav>

  <!-- ENCERRAMENTO -->
  <section class="closing">
    <div class="container">
      <div class="closing-id">↳ Próximo passo</div>
      <h2 class="closing-title">Do prompt copiado ao assistente em produção.</h2>
      <p class="closing-dek">{numToPt(promptCount)} prompts em {numToPt(eixoCount).toLowerCase()} eixos. {numToPt(methodEixoCount)} verbos do método — estruturar, formalizar, construir, avaliar, manter — para o trabalho de pensar e escrever; e um sexto eixo, aplicar, com utilitários para sair do prompt copiado direto ao protótipo navegável. O nono ensina o caminho de criar o seu próprio assistente; os demais dão matéria-prima para começar hoje.</p>

      <div class="closing-ctas">
        <a href="#" class="closing-cta">
          Ver método PTCF e templates
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/sobre-jo" class="closing-cta-secondary">
          Conhecer a Jô
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============================================================
     HERO da página de assistentes
     ============================================================ */
  .ahero {
    padding: 88px 0 56px;
  }

  .ahero-section-id {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 44px;
  }

  .ahero-lever {
    width: 84px;
    height: 48px;
    margin-bottom: 32px;
    display: block;
  }

  .ahero-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(56px, 9vw, 92px);
    line-height: 0.96;
    letter-spacing: -0.032em;
    margin-bottom: 28px;
    color: var(--fg);
  }

  .ahero-dek {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.32;
    color: var(--fg);
    max-width: 620px;
    margin-bottom: 22px;
  }

  .ahero-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--amber);
    margin-bottom: 56px;
  }

  .ahero-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 28px;
    border-top: 0.5px solid var(--fg-22);
    gap: 24px;
    flex-wrap: wrap;
  }

  .ahero-meta-block {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--fg-86);
  }

  .ahero-meta-right { text-align: right; }

  .ahero-meta-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-45);
    margin-bottom: 6px;
  }

  .ahero-meta-sub {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--fg-45);
    margin-top: 6px;
  }

  /* ============================================================
     MÉTODO PTCF
     ============================================================ */
  .method {
    padding: 64px 0;
    border-top: 0.5px solid var(--fg-22);
    border-bottom: 0.5px solid var(--fg-22);
  }

  .method-id {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 28px;
  }

  .method-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(32px, 5vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.022em;
    margin-bottom: 14px;
    max-width: 720px;
    color: var(--fg);
  }

  .method-dek {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.45;
    color: var(--fg-86);
    margin-bottom: 44px;
    max-width: 580px;
  }

  .method-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 0.5px solid var(--fg-22);
  }

  .method-cell {
    padding: 28px 22px 28px 0;
    border-right: 0.5px solid var(--fg-10);
  }
  .method-cell:last-child { border-right: none; padding-right: 0; }
  .method-cell:nth-child(n+2) { padding-left: 22px; }

  .method-letter {
    font-family: var(--serif);
    font-style: italic;
    font-size: 38px;
    font-weight: 500;
    line-height: 1;
    color: var(--amber);
    margin-bottom: 12px;
  }

  .method-name {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 8px;
    letter-spacing: 0.01em;
  }

  .method-desc {
    font-family: var(--sans);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--fg-86);
  }

  @media (max-width: 760px) {
    .method-grid { grid-template-columns: repeat(2, 1fr); }
    .method-cell {
      padding: 24px 18px 24px 0 !important;
      border-right: 0.5px solid var(--fg-10);
      border-bottom: 0.5px solid var(--fg-10);
    }
    .method-cell:nth-child(2n) { border-right: none; padding-right: 0 !important; }
    .method-cell:nth-child(2n+1) { padding-left: 0 !important; }
    .method-cell:nth-child(2n) { padding-left: 18px !important; }
    .method-cell:nth-last-child(-n+2) { border-bottom: none; }
  }

  /* ============================================================
     TOC — sumário formato livro
     ============================================================ */
  .toc {
    border-top: 0.5px solid var(--fg-22);
    border-bottom: 0.5px solid var(--fg-22);
    padding: 24px 0 32px;
    margin-top: 40px;
  }

  .toc-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 24px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    flex-wrap: wrap;
  }

  .toc-label { color: var(--amber); }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-row { border-top: 0.5px solid var(--fg-22); }
  .toc-row:first-child { border-top: none; }
  .toc-row-first:not(:first-child) { border-top: 0.5px solid var(--fg-50); }

  .toc-row-link {
    display: grid;
    grid-template-columns: 200px 44px 1fr 1.6fr;
    align-items: baseline;
    gap: 24px;
    padding: 14px 8px;
    margin: 0 -8px;
    text-decoration: none;
    color: var(--fg);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .toc-row-link:hover {
    background-color: color-mix(in srgb, var(--amber) 7%, transparent);
  }

  .toc-row-eixo {
    font-family: var(--serif);
    font-size: 14px;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .toc-row-num {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: var(--amber);
  }

  .toc-row-title {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.28;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .toc-row-link:hover .toc-row-title { color: var(--amber); }

  .toc-row-purpose {
    font-family: var(--sans);
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--fg-65);
  }

  @media (max-width: 900px) {
    .toc-row-link {
      grid-template-columns: 32px 1fr;
      grid-template-areas:
        "eixo eixo"
        "num title"
        ".    purpose";
      gap: 4px 12px;
      padding: 14px 0;
      margin: 0;
    }
    .toc-row-eixo {
      grid-area: eixo;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 4px;
    }
    .toc-row-eixo:empty { display: none; }
    .toc-row-num { grid-area: num; }
    .toc-row-title { grid-area: title; font-size: 14.5px; }
    .toc-row-purpose { grid-area: purpose; font-size: 11.5px; }
  }

  /* ============================================================
     ENCERRAMENTO
     ============================================================ */
  .closing {
    padding: 80px 0 96px;
    border-top: 0.5px solid var(--fg-22);
    margin-top: 32px;
  }

  .closing-id {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-50);
    margin-bottom: 32px;
  }

  .closing-title {
    font-family: var(--serif);
    font-size: clamp(34px, 5vw, 44px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.022em;
    margin-bottom: 18px;
    max-width: 700px;
    color: var(--fg);
  }

  .closing-dek {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--fg-86);
    max-width: 580px;
    margin-bottom: 36px;
  }

  .closing-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .closing-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    background: var(--amber);
    color: var(--bg);
    font-family: var(--sans);
    font-size: 13.5px;
    font-weight: 600;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    letter-spacing: 0.01em;
  }

  .closing-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(217, 119, 6, 0.25);
  }

  .closing-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: transparent;
    color: var(--fg);
    font-family: var(--sans);
    font-size: 13.5px;
    font-weight: 500;
    border: 0.5px solid var(--fg-22);
    border-radius: 999px;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .closing-cta-secondary:hover { border-color: var(--fg-78); }
</style>
