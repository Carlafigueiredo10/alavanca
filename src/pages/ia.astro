---
import Base from '../layouts/Base.astro';

/**
 * /ia · Módulo IA como Infraestrutura
 *
 * Estrutura:
 *   I  · Hero  — declaração + promessa
 *   II · Por quê — 3 dores que travam o lab (Dupla Carga, Vale da Morte, Burocracia Fundacional)
 *   III · Kit — 4 entregas práticas (Caixa de Ferramentas, Aceleração na Prática, Kit de Sobrevivência, Letramento Digital)
 *
 * Copy é preliminar — Carla revisa.
 * Conteúdo de cada card está marcado como "em curadoria" onde ainda não há link/dado real.
 */

type WhyCard = {
  id: string;
  title: string;
  body: string;
  footer: string;
  link?: { label: string; href: string };
};

type KitCard = {
  id: string;
  category: string;     // rótulo pragmático (Caixa de Ferramentas, etc)
  title: string;
  body: string;
  status: 'DISPONÍVEL' | 'EXTERNO · CLIC' | 'EXTERNO · SERVIDORAS' | 'CONSOLIDANDO AQUI' | 'EM BREVE';
  link?: { label: string; href: string; external?: boolean };
};

const whys: WhyCard[] = [
  {
    id: '01',
    title: 'Dupla carga',
    body: 'Burocracia consome o tempo da equipe. A IA absorve a carga pesada — minutas, notas, normas — e libera escuta do cidadão e articulação política.',
    footer: 'Inovação deixa de depender de heroísmo voluntário.',
    link: { label: 'Pegue uma mão', href: '/assistente#p09' },
  },
  {
    id: '02',
    title: 'Vale da morte',
    body: 'Protótipo trava na hora de virar contratação. A IA domina Marco Legal de CT&I, Marco das Startups e Manuais da AGU — gera Sandbox Regulatório, ETEC e CPSI com travas jurídicas e salvaguardas.',
    footer: 'Atravessar a barreira do protótipo à área finalística.',
    link: { label: 'Pegue uma mão', href: '/assistente#p10' },
  },
  {
    id: '03',
    title: 'Burocracia fundacional',
    body: 'Lab morre por invisibilidade. Catálogo de Serviços, Notas Técnicas com parâmetros OCDE, indicadores de valor público — a IA estrutura a defesa institucional do laboratório.',
    footer: 'Sobrevive trocas de gestão.',
    link: { label: 'Pegue uma mão', href: '/assistente#p13' },
  },
];

const kit: KitCard[] = [
  {
    id: '01',
    category: 'Caixa de Ferramentas',
    title: 'Catálogo curado · 70+ ferramentas IA',
    body: 'Mapa por categoria, gratuidade e — o mais importante para o setor público — controle de dados e segurança. Atalho seguro para o servidor saber qual ferramenta usar para qual tarefa.',
    status: 'EXTERNO · CLIC',
    link: { label: 'Abrir catálogo no CLIC', href: 'https://clicedu.com.br/ferramentas', external: true },
  },
  {
    id: '02',
    category: 'Aceleração na Prática',
    title: 'Assistentes de Laboratório',
    body: 'Construa sua equipe digital. Embuta base curada e regras rígidas (estrutura de Nota Técnica, proibição de inventar normas) para que o assistente resolva mapeamento, ideação e formalização.',
    status: 'DISPONÍVEL',
    link: { label: 'Acessar assistentes', href: '/assistente' },
  },
  {
    id: '03',
    category: 'Assistente de linguagem',
    title: 'Adequar a comunicação ao seu público.',
    body: 'Suba Word, PDF ou imagem (com OCR). Diga quem vai ler — cidadão, técnico, gestor, órgão de controle. A Jô lê o documento e devolve sugestões de tom, vocabulário e estrutura para que a mensagem chegue no leitor certo.',
    status: 'DISPONÍVEL',
    link: { label: 'Adequar texto', href: '/ia/linguagem' },
  },
  {
    id: '04',
    category: 'Letramento Digital',
    title: 'Trilhas de cursos',
    body: 'Trilhas progressivas de 6h a 30h — de quem nunca usou IA até quem já constrói sistemas. Da engenharia de prompts à ética algorítmica.',
    status: 'EXTERNO · SERVIDORAS',
    link: { label: 'Acessar trilhas', href: 'https://servidorasnocomando.netlify.app/trilhas', external: true },
  },
];
---
<Base
  title="IA como Infraestrutura · Alavanca"
  description="O braço operacional do seu lab — IA aplicada com método. Comprime planejamento de meses para horas e converte intenção em documentos prontos para execução."
  bodyClass="film-grain"
>

<!-- ============================================================
     I · HERO — declaração + promessa
     ============================================================ -->
<section class="ia-hero">
  <div class="shell">
    <div class="ia-hero-meta reveal">
      <span class="ia-hero-meta-id">/IV</span>
      <span class="ia-hero-meta-line"></span>
      <span class="ia-hero-meta-tag">Módulo · Infraestrutura</span>
    </div>

    <h1 class="ia-hero-headline reveal delay-1">
      IA como <span class="signal-text">Infraestrutura</span>.
    </h1>

    <p class="ia-hero-sub reveal delay-2">
      O braço operacional do seu lab.
    </p>

    <p class="ia-hero-promise reveal delay-3">
      A inteligência artificial na Alavanca <strong>comprime o tempo de planejamento de meses para horas</strong>
      e converte a intenção de inovar em documentos técnicos prontos para assinatura e execução.
      Capacidade da casa, não atalho terceirizado.
    </p>

    <div class="ia-hero-jumps reveal delay-4">
      <a href="#por-que" class="ia-hero-jump">
        <span class="ia-hero-jump-id">/01</span>
        <span class="ia-hero-jump-label">Por quê</span>
        <span class="ia-hero-jump-arrow">↓</span>
      </a>
      <a href="#kit" class="ia-hero-jump">
        <span class="ia-hero-jump-id">/02</span>
        <span class="ia-hero-jump-label">Kit</span>
        <span class="ia-hero-jump-arrow">↓</span>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     II · POR QUÊ — 3 dores que travam o lab
     ============================================================ -->
<section id="por-que" class="ia-why">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/01</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">I · Por quê</span>
      </div>
      <h2 class="section-head-title reveal">
        O que a IA destrava no lab.
      </h2>
    </header>

    <p class="ia-why-sub reveal delay-1">
      Antes de mostrar o kit: três dores reais que a inteligência aplicada combate.
    </p>

    <div class="ia-why-grid">
      {whys.map((w, i) => (
        <article class:list={['ia-why-card', 'surface', 'reveal', `delay-${i + 1}`]}>
          <div class="ia-why-card-id">/{w.id}</div>

          <div class="ia-why-card-body">
            <h3 class="ia-why-card-title">{w.title}</h3>
            <p class="ia-why-card-text">{w.body}</p>
          </div>

          <div class="ia-why-card-foot">
            <p class="ia-why-card-footnote">
              <span class="ia-why-card-mark">↳</span>
              {w.footer}
            </p>
            {w.link && (
              <a class="ia-why-card-link" href={w.link.href}>
                {w.link.label} <span aria-hidden="true">→</span>
              </a>
            )}
          </div>

          <span class="bracket bracket-tl"></span>
          <span class="bracket bracket-tr"></span>
          <span class="bracket bracket-bl"></span>
          <span class="bracket bracket-br"></span>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     III · KIT — 4 entregas práticas
     ============================================================ -->
<section id="kit" class="ia-kit">
  <div class="shell">
    <header class="section-head">
      <div class="section-head-meta">
        <span class="section-head-id">/02</span>
        <span class="section-head-line"></span>
        <span class="section-head-tag">II · Kit</span>
      </div>
      <h2 class="section-head-title reveal">
        Caixa pronta pra abrir hoje.
      </h2>
    </header>

    <p class="ia-kit-sub reveal delay-1">
      Já testamos, curamos as ferramentas, criamos os assistentes, desenhamos os prompts e montamos as aulas.
    </p>

    <div class="ia-kit-grid">
      {kit.map((k, i) => {
        const Tag = k.link ? 'a' : 'div';
        const tagProps = k.link
          ? {
              href: k.link.href,
              ...(k.link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}),
            }
          : {};
        return (
          <Tag class:list={['ia-kit-card', 'surface', 'reveal', `delay-${i + 1}`]} {...tagProps}>
            <div class="ia-kit-card-top">
              <span class="ia-kit-card-id">/{k.id}</span>
              <span class="ia-kit-card-status">{k.status}</span>
              {k.link && <span class="ia-kit-card-arrow">→</span>}
            </div>

            <div class="ia-kit-card-body">
              <div class="ia-kit-card-category">{k.category}</div>
              <h3 class="ia-kit-card-title">{k.title}</h3>
              <p class="ia-kit-card-text">{k.body}</p>
            </div>

            {k.link && (
              <div class="ia-kit-card-foot">
                <span class="ia-kit-card-foot-mark">↳</span>
                {k.link.label}
              </div>
            )}

            <span class="bracket bracket-tl"></span>
            <span class="bracket bracket-tr"></span>
            <span class="bracket bracket-bl"></span>
            <span class="bracket bracket-br"></span>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<!-- ============================================================
     CTA · voltar ao todo
     ============================================================ -->
<section class="ia-coda">
  <div class="shell">
    <a href="/" class="ia-coda-back">↩ Voltar ao índice da Alavanca</a>
  </div>
</section>

</Base>

<script is:inline>
  (() => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      return;
    }
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  })();
</script>

<style>
  /* ============================================================
     SECTION HEAD (compartilhado com landing)
     ============================================================ */
  .section-head {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: end;
    gap: 24px;
  }
  .section-head-meta {
    grid-column: span 12;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
  }
  .section-head-id { color: var(--signal); }
  .section-head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--hairline) 20%, var(--hairline) 80%, transparent);
  }
  .section-head-title {
    grid-column: span 12;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.6vw, 4.4rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--bone);
    text-wrap: balance;
  }
  @media (min-width: 880px) {
    .section-head-meta  { grid-column: span 3; }
    .section-head-title { grid-column: span 9; }
  }

  /* ============================================================
     I · HERO
     ============================================================ */
  .ia-hero {
    padding: 168px 0 96px;
  }
  @media (max-width: 768px) {
    .ia-hero { padding: 128px 0 64px; }
  }

  .ia-hero-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    margin-bottom: 48px;
  }
  .ia-hero-meta-id { color: var(--signal); }
  .ia-hero-meta-line {
    flex: 1;
    max-width: 280px;
    height: 1px;
    background: linear-gradient(to right, var(--hairline), transparent);
  }
  .ia-hero-meta-tag { color: var(--fg-65); }

  .ia-hero-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.96;
    letter-spacing: -0.034em;
    color: var(--bone);
    margin-bottom: 24px;
    text-wrap: balance;
    max-width: 16ch;
  }

  .ia-hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.2rem, 2.4vw, 1.8rem);
    line-height: 1.3;
    color: var(--fg-78);
    margin-bottom: 56px;
    max-width: 40ch;
  }

  .ia-hero-promise {
    font-size: 16px;
    line-height: 1.65;
    color: var(--fg-78);
    max-width: 60ch;
    margin-bottom: 64px;
  }
  .ia-hero-promise strong {
    color: var(--bone);
    font-weight: 500;
  }

  .ia-hero-jumps {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ia-hero-jump {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 16px 24px;
    border: 1px solid var(--hairline-2);
    color: var(--bone);
    text-decoration: none;
    transition: border-color 250ms ease, color 250ms ease;
  }
  .ia-hero-jump:hover {
    border-color: var(--signal);
    color: var(--signal);
  }
  .ia-hero-jump-id {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--signal);
  }
  .ia-hero-jump-label {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  .ia-hero-jump-arrow {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--fg-50);
    transition: transform 250ms ease, color 250ms ease;
  }
  .ia-hero-jump:hover .ia-hero-jump-arrow {
    transform: translateY(3px);
    color: var(--signal);
  }

  /* ============================================================
     II · POR QUÊ
     ============================================================ */
  .ia-why {
    padding: 128px 0;
    border-top: 1px solid var(--hairline);
  }

  .ia-why-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
    font-style: italic;
  }
  @media (min-width: 880px) {
    .ia-why-sub { margin-left: 25%; }
  }

  .ia-why-grid {
    margin-top: 80px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 880px) {
    .ia-why-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .ia-why-card {
    position: relative;
    overflow: hidden;
    padding: 40px;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    color: var(--bone);
  }

  .ia-why-card-id {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal);
  }

  .ia-why-card-body { flex: 1; }

  .ia-why-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--bone);
    margin-bottom: 16px;
  }

  .ia-why-card-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-78);
  }

  .ia-why-card-foot {
    border-top: 1px solid var(--hairline);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ia-why-card-footnote {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-50);
    line-height: 1.5;
  }

  .ia-why-card-mark { color: var(--signal); margin-right: 4px; }

  .ia-why-card-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--signal);
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .ia-why-card-link:hover { opacity: 0.78; }

  /* ============================================================
     III · KIT
     ============================================================ */
  .ia-kit {
    padding: 128px 0;
    border-top: 1px solid var(--hairline);
  }

  .ia-kit-sub {
    margin-top: 32px;
    max-width: 640px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--fg-65);
    font-style: italic;
  }
  @media (min-width: 880px) {
    .ia-kit-sub { margin-left: 25%; }
  }

  .ia-kit-grid {
    margin-top: 80px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 720px) {
    .ia-kit-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .ia-kit-card {
    position: relative;
    overflow: hidden;
    padding: 40px;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    color: var(--bone);
    text-decoration: none;
  }

  .ia-kit-card-top {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-50);
    flex-wrap: wrap;
  }

  .ia-kit-card-id { color: var(--signal); }

  .ia-kit-card-status {
    padding: 4px 10px;
    border: 1px solid var(--hairline-2);
    border-radius: 999px;
    color: var(--fg-65);
  }

  .ia-kit-card-arrow {
    margin-left: auto;
    font-size: 16px;
    color: var(--fg-50);
    transition: transform 250ms ease, color 250ms ease;
  }
  a.ia-kit-card:hover .ia-kit-card-arrow {
    transform: translateX(4px);
    color: var(--signal);
  }

  .ia-kit-card-body { flex: 1; }

  .ia-kit-card-category {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 14px;
  }

  .ia-kit-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.2vw, 1.9rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--bone);
    margin-bottom: 16px;
    text-wrap: balance;
  }

  .ia-kit-card-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-78);
  }

  .ia-kit-card-foot {
    border-top: 1px solid var(--hairline);
    padding-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-65);
  }
  .ia-kit-card-foot-mark { color: var(--signal); margin-right: 6px; }

  /* ============================================================
     CODA
     ============================================================ */
  .ia-coda {
    padding: 64px 0 96px;
    border-top: 1px solid var(--hairline);
  }
  .ia-coda-back {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal);
    text-decoration: none;
    transition: opacity 200ms ease, transform 200ms ease;
    display: inline-block;
  }
  .ia-coda-back:hover {
    opacity: 0.85;
    transform: translateX(-2px);
  }
</style>
