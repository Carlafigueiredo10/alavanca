# Supabase
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (modo Decisão)
GOOGLE_API_KEY=

# DeepSeek (modo Possibilidades)
DEEPSEEK_API_KEY=

# Anthropic (módulo Adequa · assistente de linguagem)
ANTHROPIC_API_KEY=

# Resend — notificação por e-mail quando chega sugestão.
# Cria conta em https://resend.com (free 3k/mês), gera API key.
# Sem domínio próprio, o "from" usa onboarding@resend.dev (ok pra um destinatário).
RESEND_API_KEY=

# URL pública do site (usada no link "Painel" do e-mail). Default: cliclabs.vercel.app.
PUBLIC_SITE_URL=
